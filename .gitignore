*.DotCover
*.coverage
*.coveragexml
*.ncrunch*
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

##############################
# NuGet
##############################
# packages/ is tracked so machines can build without NuGet restore.
# (packages.config solutions; avoid re-downloading SQLite native bits, etc.)
*.nupkg
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# Blanket x64/ / x86/ rules above also match native folders under packages —
# un-ignore them so System.Data.SQLite (and similar) interop DLLs are tracked.
!**/packages/**/x64/
!**/packages/**/x86/
!**/packages/**/x64/**
!**/packages/**/x86/**

##############################
# QuickCross build / installer outputs
##############################
QuickCross/BuildOutput/
# NPOI build output (DLLs/PDBs/XML) — produced from main/, ooxml/, etc.
QuickCross/solution/
QuickCross/Installer/*.msi
QuickCross/Installer/*.exe
QuickCross/Installer/*.dll
QuickCross/Installer/*.zip
QuickCross/Installer/*.z0?
QuickCross/Installer/*.pfx

# Visual Studio Installer / ClickOnce publish leftovers
*.Publish.xml
*.publishproj
*.application
*.appx
*.appxbundle
*.appxupload
publish/

# VS upgrade / migration logs
UpgradeLog*.htm
UpgradeLog*.XML
*_UpgradeReport_Files/
.vscode/

##############################
# Certificates & secrets (do not commit)
##############################
*.pfx
*.p12
*.key
*.cer
*.crt
*.pem
# Keep strong-name keys used by NPOI projects if present in-tree;
# uncomment the next line to ignore all SNK files as well:
# *.snk

##############################
# OS / misc
##############################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
*.swp
*.bak
*.tmp

##############################
# QuickCrossAdmintool
##############################
QuickCrossAdmintool/**/bin/
QuickCrossAdmintool/**/obj/
QuickCrossAdmintool/.vs/
# QuickCrossAdmintool/packages/ is tracked (same as QuickCross/packages)

##############################
# Local / environment
##############################
*.local
*.local.json
appsettings.*.local.json
.env
.env.*
!.env.example
