<Window x:Class="KeyGeneration.ShowKeyWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KeyGeneration"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShowKeyWindow" Height="700" Width="500" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="Header" TargetType="{x:Type Grid}">
                <Setter Property="Background" Value="#3467b0"/>
            </Style>
            <Style x:Key="HeaderText" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Text" Value="Show Activation Key"/>
                <Setter Property="Padding" Value="24,10"/>
                <Setter Property="FontSize" Value="30"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style TargetType="Button" x:Key="Button">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="0" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#aeaeae"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="40*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0"  Style="{StaticResource Header}" MouseDown="DragableGridMouseDown">
                <!-- Window Header -->
                <TextBlock Style="{StaticResource HeaderText}"/>
            </Grid>
            <Grid Grid.Row="1" >
                <Label  x:Name="lbl_ShowKey" Content="Enter the activation key here..." HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,25" TextBlock.FontSize="15"/>
                <TextBox x:Name="txt_ActivationKey" HorizontalAlignment="Left" Height="30"  TextWrapping="Wrap"  Text="" TextAlignment="Left"
                         VerticalAlignment="Center" Width="400" Margin="30,40,0,0"/>
            </Grid>
            <Grid Grid.Row="2" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*"/>
                    <ColumnDefinition Width="50*"/>
                </Grid.ColumnDefinitions>


                <Button x:Name="btn_Decrypt" Content="Show key Info" Click="BtnDecrypt_Click" Style="{StaticResource Button}" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"  VerticalAlignment="Top" Width="80" RenderTransformOrigin="3.614,0.982"/>
                <Label  x:Name="lbl_UserDomain" Content="User Domain" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_UserDomain" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_UserName" Content="User Name" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_UserName" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_ComputerName" Content="Computer Name" Grid.Row="3" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_ComputerName" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_MacAddress" Content="Mac Address" Grid.Row="4" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_MacAddress" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_ExpiryDate" Content="Expiry Date" Grid.Row="5" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_ExpiryDate" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_KeyType" Content="Key Type" Grid.Row="6" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_KeyType" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_GUserDoamin" Content="Generator's User Domain" Grid.Row="7" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_GUserDomain" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Button x:Name="btn_Close" Content="Close" Click="BtnClose_Click" Style="{StaticResource Button}" Grid.Row="10" Grid.Column="1" HorizontalAlignment="Center"  VerticalAlignment="Center" Width="80" RenderTransformOrigin="3.614,0.982"/>
                <Label  x:Name="lbl_GUserName" Content="Generator's User Name" Grid.Row="8" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_GUserName" Grid.Row="8" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
                <Label  x:Name="lbl_GTime" Content="Time of Generation" Grid.Row="9" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="90,0,10,10" Height="30"/>
                <TextBox x:Name="txt_GTime" Grid.Row="9" Grid.Column="1" HorizontalAlignment="Left"  VerticalAlignment="Top"  TextWrapping="Wrap" TextAlignment="Left"
                         Height="30"  Width="200" Margin="10,0,10,10"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
