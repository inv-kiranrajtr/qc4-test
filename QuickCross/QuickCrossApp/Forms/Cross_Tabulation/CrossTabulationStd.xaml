<Window x:Class="Qc4Launcher.Forms.Cross_Tabulation.CrossTabulationStd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
        mc:Ignorable="d"
         xmlns:res="clr-namespace:Qc4Launcher"
                 xmlns:tab="clr-namespace:ScrollableTabControl;assembly=ScrollableTabControl"
       MouseRightButtonDown="DisableRightMenu" MouseRightButtonUp="DisableRightMenu"
         ResizeMode="NoResize" Title="{x:Static res:LocalResource.TITLE_CROSS_TAB}"
        Height="700" BorderBrush="#ADADAD" BorderThickness="1" Closing="Window_Closing" Closed="Window_Closed" Width="1040" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" ShowInTaskbar="True" >

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                          BorderThickness="1" BorderBrush="White"
                          CornerRadius="0,0,0,0">
                                <ContentPresenter 
                          ContentSource="Header"
                          RecognizesAccessKey="True" />
                            </Border>
                            <Border Grid.Row="1" BorderBrush="#D5DFE5"
                                    BorderThickness="1"
                                    CornerRadius="0,0,0,0">
                                <ContentPresenter Margin="4" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="txtStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

        <Style TargetType="{x:Type ComboBox}" x:Key="Combo">
            <Style.Triggers>
                <Trigger Property="Selector.IsSelected" Value="True">
                    <Setter Property="Background" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="QuestionVariabl">
            <Grid Height="15" Width="180" ShowGridLines="false">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="{Binding QuestionVariable}"
                    Style="{StaticResource txtStyle}"/>
                <TextBlock Grid.Column="1"  Text="{Binding QuestionVariableType}"
                    Style="{StaticResource txtStyle}"/>
            </Grid>
        </DataTemplate>

        <TextBlock x:Key="header1" Text="QuestionVariable"/>
        <TextBlock x:Key="header2" Text="QuestionVariableType"/>
        <TextBlock x:Key="header3" Text="Question"/>


        <!--Toggle Button Template-->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid x:Name="gd">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" SnapsToDevicePixels="True" Grid.ColumnSpan="2" Background="White" BorderBrush="LightGray" BorderThickness="1"/>
                <Border x:Name="Boredr1" SnapsToDevicePixels="True" Grid.Column="0"  Margin="1" Background="White" BorderBrush="LightGray" BorderThickness="0,0,1,0" />
                <Path x:Name="Arrow" SnapsToDevicePixels="True" Grid.Column="1" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 6 6 L 12 0 Z"/>
                <ContentPresenter Grid.Column="0" TextElement.Foreground="Orange"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="Black"/>
                    <Setter TargetName="Boredr1" Property="BorderBrush" Value="Black"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Arrow" Property="Data" Value="M 0 0 L 5 5 L 10 0"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="Black"/>
                    <Setter TargetName="Arrow" Property="StrokeThickness" Value="1.5"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="gd" Property="Visibility" Value="Visible"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!--TextBox Template-->
        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="{x:Type TextBox}">
            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" />
        </ControlTemplate>



        <!--combobox item style-->
        <Style x:Key="Column_CmbItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Grid x:Name="Border" Grid.ColumnSpan="2" Margin="1,0,1,1" Background="White">
                            <ContentPresenter/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="Gray"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="LightBlue"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0,0,0,0" Background="#FFF0F0F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="355*"/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="331*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="3" BorderBrush="#F0F0F0" BorderThickness="1 1 1.2 1">
            <TabControl BorderThickness="1, 1, 1.2, 1" BorderBrush="#ACACAC"   x:Name="tabcross" Margin="10,5,10,50" Grid.ColumnSpan="3" Height="570" SelectionChanged="Tabcross_SelectionChanged">
                <TabItem x:Name="Tab_item">
                    <TabItem.Header>
                        <StackPanel x:Name="data" Orientation="Horizontal">
                            <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.HEADER_TABULATION_SETTING}" Foreground="Black" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid x:Name="Tabulation_setting">

                    </Grid>
                </TabItem>

                <TabItem x:Name="Page_Refine">
                    <TabItem.Header>
                        <StackPanel x:Name="Container_panel" Orientation="Horizontal">
                            <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_FILTER_SETTING}" Foreground="Black" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid x:Name="GridContainer">

                    </Grid>

                </TabItem>

                <TabItem x:Name="Page_Summary">
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_TABULATION_OPTION}"/>
                    </TabItem.Header>
                    <Grid  Width="812" HorizontalAlignment="Left">
                        <Grid  Width="800" HorizontalAlignment="Left">
                            <Grid x:Name="Tabulation_options">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="525"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Grid.Row="0" Margin="5">
                                    <GroupBox  Foreground="#FF333333" FontFamily="Arial" x:Name="Output_summary">
                                        <GroupBox.Header>
                                            <TextBlock Style="{StaticResource TextBlockNormal}" Text="{x:Static res:LocalResource.CROSS_OUPUT_SETTINGS}"   Margin="7,0,247,0"/>

                                        </GroupBox.Header>
                                        <Grid Margin="5 5 5 0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0 5 5 5">
                                                <RadioButton TabIndex="1" Style="{StaticResource RadibuttonNormal}" Content="{x:Static res:LocalResource.RB_OUTPUT_SHEET_TYPE_ONE}" x:Name="Option_Output_SheetType_One"  Grid.Row="0" Margin="0,0,0,0"  VerticalAlignment="Center" HorizontalAlignment="Left" Height="15"/>
                                                <RadioButton TabIndex="2" Style="{StaticResource RadibuttonNormal}" Content="{x:Static res:LocalResource.RB_OUTPUT_SHEET_TYPE_PLURAL}" x:Name="Option_Output_SheetType_Plural"  Grid.Row="1" Margin="0,5,0,0"  VerticalAlignment="Center" HorizontalAlignment="Left" Height="15" Checked="Option_Output_SheetType_Plural_Checked" Unchecked="Option_Output_SheetType_Plural_Checked"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <CheckBox Unchecked="Check_Output_Cross_N_Par_Checked" Checked="Check_Output_Cross_N_Par_Checked" TabIndex="3" Style="{StaticResource CheckBoxNormal}" x:Name="Check_Output_Cross_N_Par"  Content="{x:Static res:LocalResource.LABEL_N_PER}"  IsEnabled="True" Margin="0,4,10,0"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19"  />
                                                <CheckBox Unchecked="Check_Output_Cross_N_Par_Checked" Checked="Check_Output_Cross_N_Par_Checked" TabIndex="4"  Style="{StaticResource CheckBoxNormal}" x:Name="Check_Output_Cross_N"  Content="{x:Static res:LocalResource.LABEL_N_}"  IsEnabled="True" Margin="0,4,10,0"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19"  />
                                                <CheckBox Unchecked="Check_Output_Cross_N_Par_Checked" Checked="Check_Output_Cross_N_Par_Checked" TabIndex="5" Style="{StaticResource CheckBoxNormal}" x:Name="Check_Output_Cross_Par"  Content="{x:Static res:LocalResource.LABEL_PER}"  IsEnabled="True" Margin="0,4,0,0"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19"  />
                                            </StackPanel>
                                        </Grid>
                                    </GroupBox>
                                </Grid>
                                <GroupBox Grid.Column="0" Grid.Row="1" Margin="5" x:Name="WeightBack">
                                    <GroupBox.Header>

                                        <CheckBox TabIndex="6" Style="{StaticResource CheckBoxCommon}" x:Name="Check_Summary_WeightBack" Checked="Check_Summary_WeightBack_Checked" Unchecked="Check_Summary_WeightBack_Checked"  Content="{x:Static res:LocalResource.LABEL_SAMPLE_WEIGHTING}" HorizontalAlignment="Left"  Margin="7,0,0,1"/>
                                    </GroupBox.Header>

                                    <Grid Grid.Row="0"  Margin="0,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="1*"/>
                                            <RowDefinition Height="1*"/>
                                            <RowDefinition Height="1*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Row="0"  Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="124*"/>

                                            </Grid.ColumnDefinitions>

                                            <ComboBox TabIndex="7" Style="{StaticResource NormalComboBox}"  ItemsSource="{Binding}"  Height="25" Grid.Column="0" Margin="4,7,0,0" 
                              Loaded="Combo_Classify_Item_Loaded"  
                              PreviewKeyUp="Combo_Summary_WeightBack_PreviewKeyUp" 
                              PreviewKeyDown="Combo_Summary_WeightBack_PreviewKeyDown"
                                  TextSearch.TextPath="QuestionVariable"     
                              IsTextSearchEnabled="True" 
                              IsEditable="True"
                                VerticalAlignment="Top"  
                              Name="Combo_Summary_WeightBack"   
                              SelectionChanged="OnSelectionChanged"                          
                                HorizontalAlignment="Left"  IsEnabled="True"
                              GotKeyboardFocus="Combo_Summary_WeightBack_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="False" 
                              DropDownClosed="Combo_Classify_Item_DropDownClosed"
                                Width="150" ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                                 >
                                                <ComboBox.Resources>
                                                    <Style TargetType="Popup">
                                                        <Setter Property="Width" Value="auto"/>
                                                        <Setter Property="MaxWidth" Value="508"/>
                                                    </Style>
                                                </ComboBox.Resources>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="2" Text="{Binding QuestionVariable}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="{x:Type ComboBoxItem}">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate>
                                                                    <Grid x:Name="gd" TextElement.Foreground="Black">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="auto"/>
                                                                            <ColumnDefinition Width="auto"/>
                                                                            <ColumnDefinition />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Width="100" Margin="5" Grid.Column="0" Text="{Binding QuestionVariable}"/>
                                                                        <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding QuestionVariableType}"/>
                                                                        <TextBlock Width="auto"  Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                                                    </Grid>

                                                                    <ControlTemplate.Triggers >
                                                                        <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                                            <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                                            <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                                        </Trigger>
                                                                        <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                                            <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                                            <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>

                                                                </ControlTemplate>

                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                            </ComboBox>


                                        </Grid>
                                        <Grid Grid.Column="0" Grid.Row="1">
                                            <Button TabIndex="10" ToolTip="{x:Static res:LocalResource.TOOLTIP_WEIGHTBAG}" Style="{StaticResource NormalButton}" x:Name="BTN_WEIGHT" Margin="4,12,0,06" Content="{x:Static res:LocalResource.BTN_SAMPLE_WEIGHT}" HorizontalAlignment="Left"  Height="25" Width="108" Grid.Column="1" Click="BTN_WEIGHT_Click" />
                                        </Grid>
                                        <Grid Grid.Column="1" >
                                            <CheckBox TabIndex="8" VerticalAlignment="Center" Style="{StaticResource CheckBoxNormal}"  Grid.Column="0" x:Name="OutputUnweightbackedTotalCheck"  Unchecked="OutputUnweightbackedTotalCheck_Checked" Checked="OutputUnweightbackedTotalCheck_Checked" Content="{x:Static res:LocalResource.LABEL_OUTPUT_UNWEIGHT_BACKED_TOTAL}"  IsEnabled="True" Margin="10,7,0,0"   HorizontalAlignment="Left"  Height="15" Width="150" />
                                        </Grid>
                                        <Grid Grid.Column="1" Grid.Row="1">
                                            <CheckBox TabIndex="9" VerticalAlignment="Center"  Style="{StaticResource CheckBoxNormal}" Grid.Column="0" x:Name="UnweightbackedBaseCheck"   Content="{x:Static res:LocalResource.LABEL_UNWEIGHT_BACKED_BASE}"  IsEnabled="True" Margin="10,0,0,-5"   HorizontalAlignment="Left"   />
                                        </Grid>
                                        <Grid Grid.Row="1"  Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>

                                            </Grid.ColumnDefinitions>

                                        </Grid>
                                        <Grid Grid.Row="2"  Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="151*"/>
                                                <ColumnDefinition Width="15*"/>
                                            </Grid.ColumnDefinitions>

                                        </Grid>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Grid.Column="0" Grid.Row="2" Margin="5" Foreground="#FF333333" x:Name="Making_group">
                                    <GroupBox.Header>
                                        <TextBlock HorizontalAlignment="Left" x:Name="Frame_Summary_Mark" Text="{x:Static res:LocalResource.LABEL_MARKING}"  Width="50" Margin="7,0,0,1"/>
                                    </GroupBox.Header>

                                    <Grid Grid.Row="0"  Margin="0,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height=".4*"/>
                                            <RowDefinition Height=".25*"/>
                                            <RowDefinition Height=".75*"/>
                                            <RowDefinition Height=".5*"/>
                                            <RowDefinition Height=".5*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="15*"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="244*"/>
                                            </Grid.ColumnDefinitions>
                                            <!--LostFocus-->
                                            <TextBlock x:Name="Label_Summary_Mark_N_Equal" Grid.Column="0" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_N}" Margin="4,5,0,7" HorizontalAlignment="Left" VerticalAlignment="Center" Height="20" Width="16" />
                                            <TextBox TabIndex="12" Padding="0" x:Name="Text_Summary_Mark_N_Equal"  Grid.Column="1" Style="{StaticResource NormalTextBox}" KeyUp="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox"   Margin="0,3,0,9" Width="35" IsEnabled="True" Height="20"    />
                                            <TextBlock x:Name="Label_Summary_Mark_Above" Grid.Column="2" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_EQUALTO_MORETHAN}"  Margin="1,4,0,8" HorizontalAlignment="Left" VerticalAlignment="Center" Height="20" Width="154" />
                                        </Grid>
                                        <Grid Grid.Row="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="19*"/>
                                            </Grid.RowDefinitions>
                                            <CheckBox  TabIndex="13" Style="{StaticResource CheckBoxNormal}" Grid.Column="0" x:Name="Check_Summary_Mark_Ranking" Content="{x:Static res:LocalResource.LABEL_RANKING}"   Margin="4,6,0,1"   HorizontalAlignment="Left" Height="20"  />

                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="126"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="112*"/>

                                            </Grid.ColumnDefinitions>

                                            <CheckBox TabIndex="14" Style="{StaticResource CheckBoxNormal}" Grid.Column="0" x:Name="Check_Summary_Mark_Ratio1"   Content="{x:Static res:LocalResource.LABEL_DIFFERENCE_BETWEEN}" Checked="Check_Difference_Marking_Checked"  Unchecked="Check_Difference_Marking_Checked" Margin="4,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Grid.ColumnSpan="2"/>

                                            <Grid Grid.Column="1" >
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="*"/>

                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="2.5*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox  TabIndex="14"  Grid.Column="0" x:Name="Check_Summary_Rate_Difference1" Unchecked="Check_Summary_Rate_Difference1_Checked" Checked="Check_Summary_Rate_Difference1_Checked"       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,6" />
                                                    <ComboBox TabIndex="15"  Style="{StaticResource NormalComboformat}" FontFamily="Arial" x:Name="Combo_Summary_Rate_Difference1"  IsEnabled="True" Margin="8,0,0,4" Visibility="Visible" Grid.Column="1" Height="22" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="38" >
                                                        <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.LABEL_ADD_MINUS}"/>
                                                        <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_ADD}"/>
                                                        <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_HYPHEN}"/>


                                                    </ComboBox>
                                                    <StackPanel Orientation="Horizontal" Grid.Column="2" >
                                                        <TextBox TabIndex="16"  Style="{StaticResource NormalTxtBoxnopad}" x:Name="Text_Summary_Rate_Difference1" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="3,5,0,5" Width="30" Text="0" TextAlignment="Center" />

                                                        <Grid >
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <Button TabIndex="17"  x:Name="BTN_SET_1_UP" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" Grid.Row="0" x:FieldModifier="private" Margin="0,5,5,0" Content="˄" Width="20" FontSize="5" FontWeight="UltraBold" />
                                                            <Button TabIndex="18"  Grid.Row="1" x:Name="BTN_SET_1_DOWN"  PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,0,5,5"  Content="˅" Width="20" FontSize="5" FontWeight="UltraBold"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Grid.Row="1"  >
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="2.5*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox TabIndex="19"  Grid.Column="0" x:Name="Check_Summary_Rate_Difference2"  Unchecked="Check_Summary_Rate_Difference2_Checked" Checked="Check_Summary_Rate_Difference2_Checked"      IsEnabled="True"    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,6,0,7" />
                                                    <ComboBox TabIndex="20"  Style="{StaticResource NormalComboformat}" FontFamily="Arial" x:Name="Combo_Summary_Rate_Difference2"   Margin="8,4,0,4" Visibility="Visible" Grid.Column="1" Height="22" VerticalAlignment="Center" HorizontalAlignment="Left" Width="38" Grid.ColumnSpan="2" >

                                                        <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.LABEL_ADD_MINUS}"/>
                                                        <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_ADD}"/>
                                                        <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_HYPHEN}"/>


                                                    </ComboBox>
                                                    <StackPanel Orientation="Horizontal" Grid.Column="3" RenderTransformOrigin="-1.063,10.167" Grid.ColumnSpan="3">
                                                        <TextBox TabIndex="21" Style="{StaticResource NormalTxtBoxnopad}" x:Name="Text_Summary_Rate_Difference2" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="3,5,0,5" Width="30" Text="0" TextAlignment="Center"  />
                                                        <Grid >
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="9*"/>
                                                                <ColumnDefinition Width="16*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <Button TabIndex="22"  Grid.Row="0" x:Name="BTN_SET_2_UP" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,5,5,0" Content="˄" Width="20" FontSize="5" FontWeight="UltraBold" />
                                                            <Button TabIndex="23"  Grid.Row="1" x:Name="BTN_SET_2_DOWN" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,0,5,5"  Content="˅" Width="20"  FontSize="5" FontWeight="UltraBold" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="5 0 5 0">
                                                <TextBlock x:Name="Frame_Color_Settings" Style="{StaticResource TxtblockformatWithoutBg}"  Text="{x:Static res:LocalResource.LABEL_COLOR_SETTINGS}" Margin="0 0 10 0" VerticalAlignment="Center" HorizontalAlignment="Center"  />
                                                <ComboBox TabIndex="24"
                                                    x:Name="Combo_Color_Settings_S" 
                                                    Style="{StaticResource NormalComboformat}" 
                                                    Height="25"
                                                    FontFamily="Arial" 
                                                    Width="140"  
                                                    VerticalContentAlignment="Center"
                                                    IsEditable="False"
                                                    SelectedValuePath="Name" 
                                                >
                                                    <ComboBox.Resources>
                                                        <Style TargetType="Popup">
                                                            <Setter Property="Width" Value="auto"/>
                                                            <Setter Property="MaxWidth" Value="508"/>
                                                        </Style>
                                                    </ComboBox.Resources>
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="2" Text="{Binding DisplayName}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                            </StackPanel>
                                        </Grid>
                                        <Grid Grid.Row="3" Height="50">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="289*"/>


                                            </Grid.ColumnDefinitions>


                                            <Grid Grid.Column="0">
                                                <StackPanel Margin="0 12 0 0" Orientation="Horizontal">
                                                    <CheckBox  TabIndex="25"  Style="{StaticResource CheckBoxNormal}" x:Name="Check_Summary_SignificantDifferece_Test" Unchecked="Check_Summary_SignificantDifferece_Test_Checked" Checked="Check_Summary_SignificantDifferece_Test_Checked" Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_TEST}"  IsEnabled="True"  Margin="4,12,0,11.6"   HorizontalAlignment="Left" Width="110" Grid.ColumnSpan="2" />
