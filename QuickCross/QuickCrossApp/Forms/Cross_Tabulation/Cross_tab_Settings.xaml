<UserControl x:Class="Qc4Launcher.Forms.Cross_Tabulation.Cross_tab_Settings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
             mc:Ignorable="d" 
                xmlns:tab="clr-namespace:ScrollableTabControl;assembly=ScrollableTabControl"
             xmlns:res="clr-namespace:Qc4Launcher"
             xmlns:vm="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
             xmlns:view="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
             d:DesignHeight="700" d:DesignWidth="700" Loaded="UserControl_Loaded">
    <UserControl.Resources>
      


       

    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="2*"/>

            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
            <Border Margin="10 0 5 0" BorderBrush="LightGray" BorderThickness="1" Height="40" Width="auto"  VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" >
                    <TextBlock  Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.CROSS_OUTPUT_FORMAT}" VerticalAlignment="Center" Margin="10 0 0 0"/>
                    <RadioButton Style="{StaticResource RadibuttonNormal}"  Margin="10 0 5 0" x:Name="Option_Setting_Output_Lateral"  GroupName="output_format"  Checked="OnRadioClick" Content="{x:Static res:LocalResource.CROSS_ROW_PERCENTAGE}"></RadioButton>
                    <RadioButton  Style="{StaticResource RadibuttonNormal}" Margin="10 0 5 0" GroupName="output_format" x:Name="Option_Setting_Output_Vertical"  Checked="OnRadioClick" Content="{x:Static res:LocalResource.CROSS_COLUMN_PERCENTAGE}" ></RadioButton>
                </StackPanel>
            </Border>


                <Button ToolTip="{x:Static res:LocalResource.TOOLTIP_ADDTAB}" VerticalAlignment="Center"  Margin="5 10 10 10" Name="btn_addtabulation" Content="{x:Static res:LocalResource.BTN_ADD_TABULATION_TAB}" Style="{StaticResource NormalButton}" Width="110" Click="Btn_addtabulation_Click"/>
                <Button ToolTip="{x:Static res:LocalResource.TOOLTIP_EDITTAB}" VerticalAlignment="Center" Margin="0 10 10 10" Name="edit_tabulation" Content="{x:Static res:LocalResource.BTN_EDIT_TABULATION_TAB}" Style="{StaticResource NormalButton}" Width="110" Click="Edit_tabulation_Click"/>
           
            </StackPanel>
            <Grid Grid.Column="1" Height="60" Margin="0 0 10 5"  HorizontalAlignment="Left" VerticalAlignment="Top">
               
            </Grid>
        </Grid>


        <Grid Margin="10 5 10 10" Width="auto" Height="auto" Grid.Row="1" x:Name="tab_grid" >

            <tab:ScrollableTabControl  ItemsSource="{Binding tabItems}" Margin="0" BorderThickness="1,1,1,1" x:Name="tab1" SelectionChanged="Tab1_SelectionChanged" 
                                    BorderBrush="#ACACAC"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                <tab:ScrollableTabControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"  >
                                <TextBlock Text="{Binding Header}" FontFamily="Arial" Foreground="{Binding _Brushes}" />
                                <CheckBox Margin="10 0 0 0" IsChecked="{Binding isactive,Mode=TwoWay}" x:Name="chkbx" Checked="Chkbx_Checked" Unchecked="Chkbx_Unchecked" />
                            </StackPanel>
                        </Grid>

                    </DataTemplate>
                </tab:ScrollableTabControl.ItemTemplate>
                <tab:ScrollableTabControl.ContentTemplate>
                    <DataTemplate>
                        <UserControl Content="{Binding TabConten}"/>
                    </DataTemplate>
                </tab:ScrollableTabControl.ContentTemplate>
            </tab:ScrollableTabControl>

        </Grid>
    </Grid>
</UserControl>
