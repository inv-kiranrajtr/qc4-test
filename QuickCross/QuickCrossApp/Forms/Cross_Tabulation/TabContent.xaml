<UserControl x:Class="Qc4Launcher.Forms.Cross_Tabulation.TabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
             xmlns:res="clr-namespace:Qc4Launcher"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded"
             d:DesignHeight="450" d:DesignWidth="1040">
    <UserControl.Resources>
        <Style x:Key="myHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>




        <DataTemplate x:Key="QuestionVariabl">
            <Grid Height="15" Width="auto" ShowGridLines="false">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock  Grid.Column="0" Background="{x:Null}" Text="{Binding Variable}"></TextBlock>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="List_Source">
            <Grid Height="15" Width="380" ShowGridLines="false">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"></ColumnDefinition>
                    <ColumnDefinition Width="100"></ColumnDefinition>
                    <ColumnDefinition Width="180"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="{Binding Variable}"></TextBlock>
                <TextBlock Grid.Column="1"  Text="{Binding AnswerType}"></TextBlock>
                <TextBlock Grid.Column="2"  Text="{Binding Question}"></TextBlock>
            </Grid>
        </DataTemplate>

    </UserControl.Resources>









    <Grid >

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="75*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="73*"/>
                <ColumnDefinition Width="27*"/>
            </Grid.ColumnDefinitions>


            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="0">
                    <Border Margin="10 10 10 5" BorderBrush="LightGray" BorderThickness="1" Height="40"   VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" >


                            <TextBlock Style="{StaticResource TxtblockformatWithoutBg}"  Text="{x:Static res:LocalResource.TABULATION_GRP_HEAD}" Margin="5 0 0 0"/>
                            <RadioButton  Style="{StaticResource RadibuttonNormal}"     Margin="10 0 0 0" Checked="Rd_gt_Checked_1" Unchecked="Rd_gt_Checked_1" x:Name="Option_Setting_Summary_Single"   Content="{x:Static res:LocalResource.CROSS_RD_BTN_GT}"></RadioButton>
                            <RadioButton   Style="{StaticResource RadibuttonNormal}" Margin="10 0 0 0"  Checked="Rd_2way_Checked" Unchecked="Rd_2way_Checked"  x:Name="Option_Setting_Summary_Double" Content="{x:Static res:LocalResource.CROSS_2WAY_XTAB}"></RadioButton>
                            <RadioButton   Style="{StaticResource RadibuttonNormal}" Margin="10 0 10 0" Unchecked="Rd_3way_Unchecked" Checked="Rd_3way_Unchecked" x:Name="Option_Setting_Summary_Triple" Content="{x:Static res:LocalResource.CROSS_3WAY_XTAB}"></RadioButton>
                        </StackPanel>
                    </Border>
                    <TextBlock  Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.QUSI_VARIABLE}" Margin="25 65 0 0"/>
                    <TextBlock  Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.CROSS_ANSTYPE_NO_OF_CHOICE}" Margin="139 65 0 0" Width="80" TextWrapping="Wrap" HorizontalAlignment="Left"/>
                    <TextBlock  Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_QUESTION}" Margin="242 65 0 0"/>
                    <TextBox  Style="{StaticResource NormalTextBox}" x:Name="txt_source" TextChanged="Txt_source_TextChanged" HorizontalAlignment="Left" Height="25" Width="110" Margin="25,85,0,5"/>
                    <TextBox  Style="{StaticResource NormalTextBox}" TextChanged="TextBox_TextChanged" x:Name="txt_search" Height="25" Width="119" Margin="242,85,0,5" HorizontalAlignment="Left" KeyDown="Txt_search_KeyDown"/>
                </Grid>

                <Border VerticalAlignment="Top" x:Name="border1" Grid.Column="1" Margin="0 10 0 5" BorderBrush="LightGray" BorderThickness="1" Height="112"  Width="226" >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>

                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox IsHitTestVisible="False" IsTabStop="False" TextAlignment="Center" Background="White" Style="{StaticResource NormalTextBox_READONLY_WhiteBG}" FontSize="11" Grid.Column="2" Grid.Row="0" IsReadOnly="True" x:Name="txt_column1" Text="{x:Static res:LocalResource.CROSS_TXTBX_TOT}"  Height="25" Width="100"  Margin="2,5,5,0"/>
                        <TextBox IsHitTestVisible="False" IsTabStop="False" TextAlignment="Center" Background="White" Style="{StaticResource NormalTextBox_READONLY_WhiteBG}" FontSize="11" Grid.Column="2" Grid.Row="1" IsReadOnly="True" x:Name="txt_column" Text="{x:Static res:LocalResource.CROSS_TXTBX_TOT}" Height="25" Width="100"  Margin="2,5,5,0"/>
                        <TextBox IsHitTestVisible="False" IsTabStop="False" Style="{StaticResource ROTxtBox}" Visibility="Hidden" Grid.Column="2" Grid.Row="1" IsReadOnly="True" Text="" HorizontalContentAlignment="Center" Height="25"  />
                        <TextBox IsHitTestVisible="False" IsTabStop="False" Style="{StaticResource ROTxtBox}"  IsReadOnly="True" x:Name="txt_row1" FontSize="11"  Grid.Row="2"   Height="40" Width="55" Margin="5,5,0,5" Text="{x:Static res:LocalResource.CROSS_AXIS_1}" VerticalContentAlignment="Center" />
                        <TextBox IsHitTestVisible="False" Visibility="Hidden" IsTabStop="False" Style="{StaticResource ROTxtBox}" FontSize="11"  IsReadOnly="True" x:Name="txt_row3"  TextWrapping="Wrap" Grid.Row="2"  VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Height="40" Grid.ColumnSpan="2" Margin="5,5,0,5" Text="{x:Static res:LocalResource.CROSS_TXTBX_TOT}" />
                        <TextBox IsHitTestVisible="False" IsTabStop="False" Style="{StaticResource ROTxtBox}"  IsReadOnly="True" x:Name="txt_row2" Grid.Column="1" Grid.Row="2"  Height="40" Width="55"  FontSize="11" Text="{x:Static res:LocalResource.CROSS_AXIS_2}" VerticalContentAlignment="Center" Margin="2,5,0,5"/>
                        <TextBox IsHitTestVisible="False" IsTabStop="False" Background="White" Style="{StaticResource NormalTextBox_READONLY_WhiteBG}" Grid.Column="2" Grid.Row="2" IsReadOnly="True" TextWrapping="Wrap" VerticalAlignment="Center" AcceptsReturn="True" Height="40" Width="100"  Margin="2,5,5,5"/>

                    </Grid>
                </Border>
                <Grid Grid.Column="2">
                    <Button  Style="{StaticResource NormalButton}" Height="30" x:Name="btn_qstn_sttng" HorizontalAlignment="Right" Width="100" Margin="0,0,0,5" Content="{x:Static res:LocalResource.CROSS_QSTN_DET}" Click="OnClick" VerticalAlignment="Bottom"></Button>
                </Grid>
            </Grid>


            <Grid Grid.Row="1" x:Name="grid_data" Grid.Column="0" Height="310"  VerticalAlignment="Top">

                <DataGrid    SelectionUnit="FullRow"  CurrentCellChanged="List_Source_CurrentCellChanged" 
                          PreviewKeyDown="List_Source_PreviewKeyDown" HorizontalScrollBarVisibility="Hidden" 
                          Style="{StaticResource Datagrid_GT_Font_Style}"  BorderBrush="#FFE1E1E1"   SelectionMode="Extended"  
                          x:Name="List_Source" FontFamily="Arial" FontSize="12" Background="White" HeadersVisibility="None" 
                          Margin="10 0 0 5" ItemsSource="{Binding}" 
                        SelectionChanged="List_Source_SelectionChanged"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" >

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="true" >
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>

                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                    <DataTrigger.Setters>
                                        <Setter Property="Background" Value="#F6F6F6" />
                                        <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                    </DataTrigger.Setters>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#e5f3fb" />
                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="126">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#FF333333" Margin="13 2 0 0" Text="{Binding Variable}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="104">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#FF333333" Margin="0 2 0 0" Text="{Binding AnswerType}" Width="100"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock ToolTip="{Binding Question}" Foreground="#FF333333" Margin="0 2 0 0" Text="{Binding Question}" />

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>


            <Grid Grid.Column="1" Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="0.7*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button   Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" x:Name="Right_Arrow" Width="25" Height="25" Margin="0 0 0 10" Click="Right_Arrow_Click" VerticalAlignment="Top"/>
                    <TextBox   FontFamily="Arial" Padding="2 0 0 0" Height="25" BorderBrush="#FFE1E1E1" TextChanged="Text_Setting_Cross_Hyosoku1_TextChanged" VerticalContentAlignment="Center"  Grid.Column="2" Margin="5 0 5 10"  x:Name="Text_Setting_Cross_Hyosoku1" IsHitTestVisible="False" ></TextBox>

                    <StackPanel Grid.Column="0" Grid.Row="1" VerticalAlignment="Top" Margin="0 5 0 10">
                        <Button   Style="{StaticResource SmallButton}" Margin="0 0 0 0" x:Name="btn_rgt_arrw"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Button_Click"/>
                        <Button   Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow" Click="Lbl_Single_Left_Arrow_Click" Width="25" Height="25" PreviewKeyDown="Lbl_Single_Left_Arrow_PreviewKeyDown"/>
                    </StackPanel>
                    <DataGrid CurrentCellChanged="List_Source_CurrentCellChanged" PreviewKeyDown="List_Setting_Cross_Hyosoku2_PreviewKeyDown" BorderBrush="#FFE1E1E1" SelectionMode="Extended" HorizontalScrollBarVisibility="Hidden"  x:Name="List_Setting_Cross_Hyosoku2" Height="55" FontFamily="Arial"  FontSize="12" Background="White" HeadersVisibility="None" GridLinesVisibility="None" Margin="5 5 5 10" ItemsSource="{Binding}"  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Grid.Column="2" Grid.Row="1">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" >
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="true" >
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                        <DataTrigger.Setters>
                                            <Setter Property="Background" Value="#F6F6F6" />
                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                        </DataTrigger.Setters>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5f3fb" />
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>


                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock  HorizontalAlignment="Left" Foreground="#FF333333" Margin="5 2 0 0" Text="{Binding Variable}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>
                    <ListView  BorderBrush="#FFE1E1E1" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden" Style="{StaticResource ListBoxCommon1}"  x:Name="List_Setting_Cross_Hyosoku21" SelectionChanged="List_Setting_Cross_Hyosoku2_SelectionChanged" SelectionMode="Extended" IsSynchronizedWithCurrentItem="False" ItemTemplate="{StaticResource QuestionVariabl}" ItemsSource="{Binding}" Grid.Column="2" Grid.Row="1" Height="55" Margin="5 5 5 10" MouseDown="List_Source_MouseDown" MouseUp="List_Source_MouseUp" ScrollViewer.ScrollChanged="List_Setting_Cross_Hyosoku2_ScrollChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value=" #FF333333"></Setter>
                                <EventSetter Event="MouseEnter" Handler="ListBoxItem_MouseEnter2"/>





                                <Style.Triggers>
                                    <Trigger Property="IsHitTestVisible" Value="false" >
                                        <Setter Property="Foreground" Value="LightGray" />
                                    </Trigger>
                                </Style.Triggers>

                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <StackPanel Grid.Column="0" Grid.Row="2" VerticalAlignment="Top" Margin="0 5 0 10">
                        <Button  Style="{StaticResource SmallButton}" Margin="0 0 0 0" x:Name="Btn_Right_dbl_arrow" Click="Btn_Right_dbl_arrow_Click" Content="{x:Static res:LocalResource.LABEL_DBL_RIGHT_ARROW}"  Width="25" Height="25"/>
                        <Button  Style="{StaticResource SmallButton}" Margin="0 0 0 0" x:Name="Btn_Right_Single_Arrow" Click="Btn_Right_Single_Arrow_Click" Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25"/>
                        <Button  Style="{StaticResource SmallButton}" Margin="0 0 0 0" x:Name="Btn_left_single_arrow" Click="Btn_left_single_arrow_Click" Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" Width="25" Height="25"/>
                        <Button  Style="{StaticResource SmallButton}" x:Name="Btn_left_dbl_arrow" Click="Btn_left_dbl_arrow_Click" Content="{x:Static res:LocalResource.LABEL_DBL_LEFT_ARROW}" Width="25" Height="25" PreviewKeyDown="Btn_left_dbl_arrow_PreviewKeyDown"></Button>
                    </StackPanel>

                    <TextBlock x:Name="txt_rd1" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.CROSS_AXIS_1}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <TextBlock x:Name="txt_rd2" Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.CROSS_AXIS_2}" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0 5 0 0"/>
                    <TextBlock x:Name="txt_rd3"  Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.CROSS_AGRIGTN_TRGT}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0 5 0 0"  Width="28"/>



                    <DataGrid    
                              PreviewKeyDown="List_Setting_Cross_Hyotou_PreviewKeyDown" 
                              BorderBrush="#FFE1E1E1" Padding="0" SelectionMode="Extended" 
                              HorizontalScrollBarVisibility="Hidden"  
                              x:Name="List_Setting_Cross_Hyotou" Height="160" 
                              FontFamily="Arial" FontSize="12" Background="White" 
                              HeadersVisibility="None" GridLinesVisibility="None" 
                              Margin="5 5 5 10" ItemsSource="{Binding}"  
                              AutoGenerateColumns="False" CanUserAddRows="False" 
                              CanUserDeleteRows="False" Grid.Column="2" Grid.Row="2">

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Left" Foreground="#FF333333" Margin="5 2 0 0" Text="{Binding Variable}" Width="118"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" >
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="true" >
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                        <DataTrigger.Setters>
                                            <Setter Property="Background" Value="#F6F6F6" />
                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                        </DataTrigger.Setters>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5f3fb" />
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>


                    </DataGrid>
                    <!--<ListView  BorderBrush="#FFE1E1E1" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden" Style="{StaticResource ListBoxCommon1}"  x:Name="List_Setting_Cross_Hyotou1" 
                               SelectionChanged="List_Setting_Cross_Hyosoku2_SelectionChanged" SelectionMode="Extended" IsSynchronizedWithCurrentItem="False" ItemTemplate="{StaticResource QuestionVariabl}" ItemsSource="{Binding}" Grid.Column="2" Grid.Row="2" Height="160" Margin="5 5 5 10" MouseDown="List_Source_MouseDown" MouseUp="List_Source_MouseUp" ScrollViewer.ScrollChanged="List_Setting_Cross_Hyosoku2_ScrollChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value=" #FF333333"></Setter>
                                <EventSetter Event="MouseEnter" Handler="ListBoxItem_MouseEnter2"/>





                                <Style.Triggers>
                                    <Trigger Property="IsHitTestVisible" Value="false" >
                                        <Setter Property="Foreground" Value="LightGray" />
                                    </Trigger>
                                </Style.Triggers>

                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>-->


                    <CheckBox Style="{StaticResource CheckBoxCommon}" Grid.Column="2" Grid.Row="3" VerticalAlignment="Bottom" Margin="5" x:Name="Check_Setting_Cross_Group">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>
                            <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.CROSS_OUTPUT_SETTING}" Grid.RowSpan="2"></TextBlock>
                        </Grid>
                    </CheckBox>

                </Grid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
