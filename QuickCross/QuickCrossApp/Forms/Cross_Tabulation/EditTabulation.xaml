<Window x:Class="Qc4Launcher.Forms.Cross_Tabulation.EditTabulation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
        mc:Ignorable="d"
        xmlns:res="clr-namespace:Qc4Launcher"
        BorderBrush="#ADADAD" BorderThickness="1"
         Title="{x:Static res:LocalResource.EDIT_TABULATION_HEADING}"  Height="290" Width="415" ShowInTaskbar="False" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="GridViewColumnHeaderStyle1" TargetType="{x:Type GridViewColumnHeader}">

            <Setter Property="Foreground" Value="#FF333333" />
            
        </Style>
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="TextElement.Foreground" Value="Black"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
    </Window.Resources>

    <Grid Background="#FFF0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="40*"/>
        </Grid.ColumnDefinitions>


        <Grid Grid.ColumnSpan="3" Margin="5 5 5 0" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="40*"/>
        </Grid.ColumnDefinitions>
        
        <Grid>
            <DataGrid FocusVisualStyle="{x:Null}"  TabIndex="1" ColumnHeaderStyle="{StaticResource Datagrid_Header_Style}"  CurrentCellChanged="List_Source_CurrentCellChanged" PreviewKeyDown="List_Source_PreviewKeyDown" BeginningEdit="List_Source_BeginningEdit" PreviewMouseDown="List_Source_PreviewMouseDown" PreviewMouseUp="OnSelectionChanged"  HeadersVisibility="Column"   SelectionMode="Extended" HorizontalScrollBarVisibility="Hidden"  Style="{StaticResource Datagrid_GT_Font_Style}" MouseLeftButtonDown="List_Source_MouseLeftButtonDown"  x:Name="List_Source"  FontFamily="Arial" FontSize="12" Background="White" GridLinesVisibility="None" Margin="5 5 5 5" ItemsSource="{Binding}"  AutoGenerateColumns="False" CanUserAddRows="False" CanUserReorderColumns="False" CanUserDeleteRows="False" Grid.Column="2" Grid.Row="2" CanUserResizeColumns="False" CanUserResizeRows="False">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" >
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="true" >
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                </DataGrid.Resources>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                <DataTrigger.Setters>
                                    <Setter Property="Background" Value="#F6F6F6" />
                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                </DataTrigger.Setters>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e5f3fb" />
                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
               
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="80"  Header="{x:Static res:LocalResource.LABEL_EXECUTE}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock TextAlignment="Center" FontFamily="Batang"  Foreground="#FF333333"  Margin="5 2 0 0" Text="{Binding OnorOff}" Width="65"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="*" Header="{x:Static res:LocalResource.CROS_TABULATION_TAB}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Left" Foreground="#FF333333" Margin="5 2 0 0" Text="{Binding Header}" Width="118"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                
              
            </DataGrid>
           

        </Grid>
        <Grid Grid.Column="1">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <Button TabIndex="2" Style="{StaticResource SmallButton}" Name="UpArrow" Click="UpArrow_Click" Height="25" Width="25" FontFamily="Segoe UI Symbol" FontSize="8" Content="&#xE110;"/>
                <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.CROSS_EDIT_ORDER}" HorizontalAlignment="Center" Margin="0 10 0 10"/>
                <Button TabIndex="3" Style="{StaticResource SmallButton}"  Name="DownArrow" Height="25" Width="25" FontFamily="Segoe UI Symbol" FontSize="8" Content="&#xE1FD;" Click="Button_Click_4"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="110"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Vertical"  HorizontalAlignment="Center" Margin="0 10 0 0">
                <Button TabIndex="4" Style="{StaticResource NormalButton}" Grid.Row="0" Height="25" Width="100" Content="{x:Static res:LocalResource.BTN_DELETE}" x:Name="Btn_Delete" Click="Btn_Delete_Click"/>
                <Button TabIndex="5" Style="{StaticResource NormalButton}" Height="25" Margin="0 10 0 100" Width="100" Content="{x:Static res:LocalResource.BTN_ON_OR_OFF}" x:Name="btn_on_off" Click="Button_Click_2"/>
            </StackPanel>
        </Grid>
        
        
        
    </Grid>
        <Grid Grid.Row="1"  Grid.Column="2" >
            <Button HorizontalAlignment="Right" TabIndex="7" Style="{StaticResource NormalButton}" Grid.Row="1" Margin="10 10 25 10" Height="25" Width="100" Content="{x:Static res:LocalResource.BTN_CLOSE}" Click="Button_Click_1"/>
        </Grid>
    </Grid>
</Window>
