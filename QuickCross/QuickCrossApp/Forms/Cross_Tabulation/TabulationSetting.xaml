<UserControl x:Class="Qc4Launcher.Forms.Cross_Tabulation.TabulationSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Qc4Launcher.Forms.Cross_Tabulation"
             mc:Ignorable="d"
             xmlns:res="clr-namespace:Qc4Launcher"
             d:DesignHeight="450" d:DesignWidth="800" >
    <UserControl.Resources>
        <Style TargetType="CheckBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="Tabulation_options">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Grid.Row="0" Margin="5">
            <GroupBox Header="Output Settings" Foreground="#FF333333" FontFamily="Arial" x:Name="Output_summary">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0 5 5 5">
                        <RadioButton Style="{StaticResource RadibuttonNormal}" Content="{x:Static res:LocalResource.RB_OUTPUT_SHEET_TYPE_ONE}" x:Name="Option_Output_SheetType_One"  Grid.Row="0" Margin="0,0,0,0"  VerticalAlignment="Center" HorizontalAlignment="Left" Height="15"/>
                        <RadioButton Style="{StaticResource RadibuttonNormal}" Content="{x:Static res:LocalResource.RB_OUTPUT_SHEET_TYPE_PLURAL}" x:Name="Option_Output_SheetType_Plural"  Grid.Row="1" Margin="0,5,0,0"  VerticalAlignment="Center" HorizontalAlignment="Left" Height="15"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <CheckBox Style="{StaticResource CheckBoxNormal}" x:Name="Check_Output_Cross_N_Par"  Content="{x:Static res:LocalResource.LABEL_N_PER}" Checked="OnCheck" Unchecked="OnCheck"  IsEnabled="True" Margin="0,4,10,0"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19"  />
                        <CheckBox Style="{StaticResource CheckBoxNormal}" x:Name="Check_Output_Cross_N"  Content="{x:Static res:LocalResource.LABEL_N_}" Checked="OnCheck" Unchecked="OnCheck" IsEnabled="True" Margin="0,4,10,0"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19"  />
                        <CheckBox Style="{StaticResource CheckBoxNormal}" x:Name="Check_Output_Cross_Par"  Content="{x:Static res:LocalResource.LABEL_PER}" Checked="OnCheck" Unchecked="OnCheck" IsEnabled="True" Margin="0,4,0,0"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19"  />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
        <GroupBox Grid.Column="0" Grid.Row="1" Margin="5" x:Name="WeightBack">
            <GroupBox.Header>

                <CheckBox Style="{StaticResource CheckBoxCommon}" x:Name="Check_Summary_WeightBack" Unchecked="OnCheck" Checked="OnCheck" Content="{x:Static res:LocalResource.LABEL_SAMPLE_WEIGHTING}"  Margin="0,0,0,1"/>
            </GroupBox.Header>

            <Grid Grid.Row="0"  Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0"  Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="124*"/>

                    </Grid.ColumnDefinitions>
                    <!--<ComboBox Name="Combo_Summary_WeightBack" IsEnabled="True"  SelectionChanged="Combo_SignificantDifference_Test_SelectionChanged" Margin="10,6,0,6" Visibility="Visible"      Grid.Column="0" Height="20"  HorizontalAlignment="Left" Width="150" >
                     
                    
</ComboBox>-->

                    <ComboBox Style="{StaticResource NormalComboBox}"  ItemsSource="{Binding}"  Height="25" Grid.Column="0" Margin="4,7,0,0" 
                              Loaded="Combo_Classify_Item_Loaded"  
                              PreviewKeyUp="Combo_Summary_WeightBack_PreviewKeyUp" 
                              PreviewKeyDown="Combo_Summary_WeightBack_PreviewKeyDown"
                                  TextSearch.TextPath="QuestionVariable"     
                              IsTextSearchEnabled="True" 
                              IsEditable="True"
                                VerticalAlignment="Top"  
                              Name="Combo_Summary_WeightBack"   
                              SelectionChanged="OnSelectionChanged"                          
                                HorizontalAlignment="Left"  IsEnabled="True"
                              GotKeyboardFocus="Combo_Summary_WeightBack_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="True" 
                              DropDownClosed="Combo_Classify_Item_DropDownClosed"
                                Width="150" ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                                 >
                        <ComboBox.Resources>
                            <Style TargetType="Popup">
                                <Setter Property="Width" Value="auto"/>
                                <Setter Property="MaxWidth" Value="508"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="2" Text="{Binding QuestionVariable}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ComboBoxItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <Grid x:Name="gd" TextElement.Foreground="Black">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="auto"/>
                                                    <ColumnDefinition Width="auto"/>
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Width="100" Margin="5" Grid.Column="0" Text="{Binding QuestionVariable}"/>
                                                <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding QuestionVariableType}"/>
                                                <TextBlock Width="auto"  Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                            </Grid>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                    <Setter TargetName="gd"  Property="Background" Value="Gray"></Setter>
                                                    <Setter TargetName="gd"  Property="TextElement.Foreground" Value="White"></Setter>
                                                </Trigger>
                                               

                                                <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                    <Setter TargetName="gd"  Property="Background" Value="steelblue"></Setter>
                                                    <Setter TargetName="gd"  Property="TextElement.Foreground" Value="White"></Setter>
                                                </Trigger>


                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>


                </Grid>
                <Grid Grid.Column="0" Grid.Row="1">
                    <Button ToolTip="Calculate weight values for sample weighting." Style="{StaticResource NormalButton}" x:Name="BTN_WEIGHT" Margin="4,12,0,06" Content="{x:Static res:LocalResource.BTN_SAMPLE_WEIGHT}" HorizontalAlignment="Left"  Height="25" Width="108" Grid.Column="1" Click="BTN_WEIGHT_Click" />
                </Grid>
                <Grid Grid.Column="1" >
                    <CheckBox VerticalAlignment="Center" Style="{StaticResource CheckBoxNormal}"  Grid.Column="0" x:Name="OutputUnweightbackedTotalCheck"  Unchecked="OutputUnweightbackedTotalCheck_Checked" Checked="OutputUnweightbackedTotalCheck_Checked" Content="{x:Static res:LocalResource.LABEL_OUTPUT_UNWEIGHT_BACKED_TOTAL}"  IsEnabled="True" Margin="10,7,0,0"   HorizontalAlignment="Left"  Height="15" Width="146" />
                </Grid>
                <Grid Grid.Column="1" Grid.Row="1">
                    <CheckBox VerticalAlignment="Center"  Style="{StaticResource CheckBoxNormal}" Grid.Column="0" x:Name="UnweightbackedBaseCheck"   Content="{x:Static res:LocalResource.LABEL_UNWEIGHT_BACKED_BASE}"  IsEnabled="True" Margin="10,0,0,-5"   HorizontalAlignment="Left"   />
                </Grid>
                <Grid Grid.Row="1"  Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                </Grid>
                <Grid Grid.Row="2"  Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="151*"/>
                        <ColumnDefinition Width="15*"/>
                    </Grid.ColumnDefinitions>

                </Grid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Column="0" Grid.Row="2" Margin="5" Foreground="#FF333333" x:Name="Making_group">
            <GroupBox.Header>
                <TextBlock x:Name="Frame_Summary_Mark" Text="{x:Static res:LocalResource.LABEL_MARKING}"  Width="50" Margin="0,0,0,1"/>
            </GroupBox.Header>

            <Grid Grid.Row="0"  Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height=".4*"/>
                    <RowDefinition Height=".25*"/>
                    <RowDefinition Height=".75*"/>
                    <RowDefinition Height=".5*"/>
                    <RowDefinition Height=".5*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*"/>
                        <ColumnDefinition Width="45*"/>
                        <ColumnDefinition Width="244*"/>
                    </Grid.ColumnDefinitions>
                    <!--LostFocus-->
                    <TextBlock x:Name="Label_Summary_Mark_N_Equal" Grid.Column="0" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_N}" Margin="4,5,0,7" HorizontalAlignment="Left" VerticalAlignment="Center" Height="20" Width="16" />
                    <TextBox x:Name="Text_Summary_Mark_N_Equal"  Grid.Column="1" Style="{StaticResource NormalTextBox}" KeyUp="Text_Summary_Mark_N_Equal_KeyUp_1" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox"   Margin="5,3,12,9" Width="35" IsEnabled="True" Height="20"    />
                    <TextBlock x:Name="Label_Summary_Mark_Above" Grid.Column="2" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_EQUALTO_MORETHAN}"  Margin="0,4,0,8" HorizontalAlignment="Left" VerticalAlignment="Center" Height="20" Width="154" />
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="19*"/>
                    </Grid.RowDefinitions>
                    <CheckBox  Style="{StaticResource CheckBoxNormal}" Grid.Column="0" x:Name="Check_Summary_Mark_Ranking" Content="{x:Static res:LocalResource.LABEL_RANKING}"   Margin="4,6,0,1"   HorizontalAlignment="Left" Height="20"  />

                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="142*"/>

                    </Grid.ColumnDefinitions>

                    <CheckBox  Style="{StaticResource CheckBoxNormal}" Grid.Column="0" x:Name="Check_Summary_Mark_Ratio1"   Content="{x:Static res:LocalResource.LABEL_DIFFERENCE_BETWEEN}" Checked="Check_Difference_Marking_Checked"  Unchecked="Check_Difference_Marking_Checked" Margin="4,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center" Height="16" Grid.ColumnSpan="2"/>

                    <Grid Grid.Column="1" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="12*"/>
                                <ColumnDefinition Width="50*"/>
                            </Grid.ColumnDefinitions>
                           
                            <CheckBox   Grid.Column="0" x:Name="Check_Summary_Rate_Difference1" Unchecked="Check_Summary_Rate_Difference1_Checked" Checked="Check_Summary_Rate_Difference1_Checked"       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,6" />
                            <ComboBox Style="{StaticResource NormalComboformat}" FontFamily="Arial" x:Name="Combo_Summary_Rate_Difference1"  IsEnabled="True" Margin="5,0,0,4" Visibility="Visible" Grid.Column="1" Height="22" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="38" >
                                <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.LABEL_ADD_MINUS}"/>
                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_ADD}"/>
                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_HYPHEN}"/>


                            </ComboBox>
                            <StackPanel Orientation="Horizontal" Grid.Column="2" >
                                <TextBox Style="{StaticResource NormalTxtBoxnopad}" x:Name="Text_Summary_Rate_Difference1" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="3,5,0,5" Width="30" Text="0" TextAlignment="Center" />

                                <Grid >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Button x:Name="BTN_SET_1_UP" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" Grid.Row="0" x:FieldModifier="private" Margin="0,5,5,0" Content="˄" Width="20" FontSize="5" FontWeight="UltraBold" />
                                    <Button Grid.Row="1" x:Name="BTN_SET_1_DOWN"  PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,0,5,5"  Content="˅" Width="20" FontSize="5" FontWeight="UltraBold"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1"  >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*"/>
                                <ColumnDefinition Width="12*"/>
                                <ColumnDefinition Width="50*"/>
                            </Grid.ColumnDefinitions>
                           
                            <CheckBox  Grid.Column="0" x:Name="Check_Summary_Rate_Difference2"  Unchecked="Check_Summary_Rate_Difference2_Checked" Checked="Check_Summary_Rate_Difference2_Checked"      IsEnabled="True"    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,6,0,7" />
                            <ComboBox Style="{StaticResource NormalComboformat}" FontFamily="Arial" x:Name="Combo_Summary_Rate_Difference2"   Margin="5,4,0,4" Visibility="Visible" Grid.Column="1" Height="22" VerticalAlignment="Center" HorizontalAlignment="Left" Width="38" Grid.ColumnSpan="2" >

                                <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.LABEL_ADD_MINUS}"/>
                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_ADD}"/>
                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_HYPHEN}"/>


                            </ComboBox>
                            <StackPanel Orientation="Horizontal" Grid.Column="3" RenderTransformOrigin="-1.063,10.167" Grid.ColumnSpan="3">
                                <TextBox Style="{StaticResource NormalTxtBoxnopad}" x:Name="Text_Summary_Rate_Difference2" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="3,5,0,5" Width="30" Text="0" TextAlignment="Center"  />
                                <Grid >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="9*"/>
                                        <ColumnDefinition Width="16*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Button  Grid.Row="0" x:Name="BTN_SET_2_UP" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,5,5,0" Content="˄" Width="20" FontSize="5" FontWeight="UltraBold" />
                                    <Button Grid.Row="1" x:Name="BTN_SET_2_DOWN" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,0,5,5"  Content="˅" Width="20"  FontSize="5" FontWeight="UltraBold" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Row="3" Height="50">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="289*"/>


                    </Grid.ColumnDefinitions>

                  
                    <Grid Grid.Column="0">
                        <StackPanel Margin="0 12 0 0" Orientation="Horizontal">
                            <CheckBox Style="{StaticResource CheckBoxNormal}" x:Name="Check_Summary_SignificantDifferece_Test" Unchecked="Check_Summary_SignificantDifferece_Test_Checked" Checked="Check_Summary_SignificantDifferece_Test_Checked" Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_TEST}"  IsEnabled="True"  Margin="4 0 0 0"   HorizontalAlignment="Left" Width="75" Grid.ColumnSpan="2" />
                            <RadioButton IsChecked="True" Unchecked="Rd_btn_chk_Unchecked" Checked="Rd_btn_chk_Unchecked" Style="{StaticResource RadibuttonNormal}" x:Name="rd_btn_chk" Content="{x:Static res:LocalResource.TEST_OVERALL_DIFFERENCE}"/>
                            <RadioButton   Style="{StaticResource RadibuttonNormal}" x:Name="rd_btn_chk2" Margin="10 0 0 0" Checked="Combo_SignificantDifference_Test_SelectionChanged"  Content="{x:Static res:LocalResource.TEST_FOR_DIFFERENT_BETWEEN_AXIS_ITEMS}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="79"/>
                        <ColumnDefinition Width="49*"/>
                        <ColumnDefinition Width="49*"/>
                        <ColumnDefinition Width="49*"/>
                        <ColumnDefinition Width="133*"/>
                        <!--<ColumnDefinition Width="64*"/>-->
                    </Grid.ColumnDefinitions>
                    <!--Checked="Check_Significance_Level_Checked"-->

                    <TextBlock x:Name="Label_Summary_SignificantDifferece" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL}" Margin="4,8,0,6" HorizontalAlignment="Left" Width="101" Grid.ColumnSpan="2"/>
                    <CheckBox Style="{StaticResource CheckBoxNormal}" Grid.Column="1" Name="Check_Par_99"      Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL1}" Margin="0,10,0,14"   HorizontalAlignment="Left" Width="37" Height="16"/>
                    <CheckBox Style="{StaticResource CheckBoxNormal}"  Grid.Column="2" Name="Check_Par_95"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL5}"   Margin="0,10,0,14"   HorizontalAlignment="Left" RenderTransformOrigin="-0.308,-0.2" Width="37" Height="16"/>
                    <CheckBox Style="{StaticResource CheckBoxNormal}"  Grid.Column="3" Name="Check_Par_90"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL10}" Margin="0,10,0,16"   HorizontalAlignment="Left" RenderTransformOrigin="-2,-0.3" Width="44" Height="14"/>
                    <RadioButton  Visibility="Hidden"  Grid.Column="4" Name="Check_Par_91"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL10}"  IsEnabled="True" Margin="0,9,0,10" IsChecked="True" Checked="Rd_btn_chk2_Checked"  HorizontalAlignment="Left" RenderTransformOrigin="-2,-0.3" Width="44"/>


                </Grid>
            </Grid>

        </GroupBox>
        <GroupBox Grid.Row="1" Grid.Column="1" Margin="5" x:Name="Group_Header" Width="250" HorizontalAlignment="Left">


            <GroupBox.Header>
                <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" VerticalAlignment="Center" Text="{x:Static res:LocalResource.LABEL_CHANGE_HEADING}"  Margin="0,0,0,1"/>
            </GroupBox.Header>

            <Grid Grid.Row="0"  Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.5*"/>
                    <RowDefinition Height="1.5*"/>
                    <RowDefinition Height="1.5*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0"  Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="75*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" x:Name="Label_Summary_Change_Hyoutou" Padding="0" Text="{x:Static res:LocalResource.LABEL_TOTAL_COLUMN}" Grid.Column="0" Margin="4,0,0,0" Height="20" HorizontalAlignment="Left" />
                    <TextBox Style="{StaticResource NormalTextBox}" x:Name="Text_Summary_Change_Hyoutou"  Grid.Column="1" HorizontalAlignment="Left"  Margin="10,0,0,0" Width="110" Height="20"  />
                </Grid>
                <Grid Grid.Row="1"  Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="75*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" x:Name="Label_Summary_Change_Hyosoku" Padding="0" Text="{x:Static res:LocalResource.LABEL_TOTAL_ROW}" Grid.Column="0" Margin="4,0,0,0" Height="20" HorizontalAlignment="Left" />
                    <TextBox Style="{StaticResource NormalTextBox}" x:Name="Text_Summary_Change_Hyosoku"  Grid.Column="1"  HorizontalAlignment="Left" Margin="10,0,0,0" Width="110" Height="20"  />

                </Grid>
                <Grid Grid.Row="2"  Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="75*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" x:Name="Label_Summary_Change_Non" Text="{x:Static res:LocalResource.LABEL_NO_ANSWER}" Grid.Column="0" Margin="4,0,0,0" Height="20" HorizontalAlignment="Left"/>
                    <TextBox Style="{StaticResource NormalTextBox}" x:Name="Text_Summary_Change_Non"  Grid.Column="1"  HorizontalAlignment="Left"  Margin="10,0,0,0" Width="110" Height="20" />

                </Grid>
            </Grid>

        </GroupBox>
        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="4 5 5 5" x:Name="crossanswer">
            <CheckBox x:Name="chk_total_rspnd" Style="{StaticResource CheckBoxNormal}" Checked="OnCheck" Unchecked="OnCheck" HorizontalAlignment="Left" Content='{x:Static res:LocalResource.LABEL_BASED_RESPONDENTS}' Margin="10 0 0 0"/>
            <CheckBox x:Name="chk_display_answer" Style="{StaticResource CheckBoxNormal}" Checked="OnCheck" Unchecked="OnCheck" HorizontalAlignment="Left" Content='{x:Static res:LocalResource.CROSS_DISPLAY_NO_ANSWER}' Margin="10 5 0 0"/>
        </StackPanel>
    </Grid>
</UserControl>
