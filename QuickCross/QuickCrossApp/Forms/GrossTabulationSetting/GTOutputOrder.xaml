<Window x:Class="Qc4Launcher.Forms.GrossTabulationSetting.GTOutputOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.GrossTabulationSetting"
        xmlns:res="clr-namespace:Qc4Launcher"
        mc:Ignorable="d" ResizeMode="NoResize"
        Title="{x:Static res:LocalResource.GT_OUTPUT_ORDER}" PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonDown" PreviewMouseRightButtonDown="Window_PreviewMouseRightButtonDown"
        Background="#FFF0F0F0" Height="700" Width="692" Closed="Window_Closed" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" BorderBrush="#ADADAD" BorderThickness="1">

    <Grid Margin="10,9,10,0" Background="#FFF0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="580"/>
            <RowDefinition Height="73"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,-1,0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="317"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="-7,0,0,0">
                <DataGrid  x:Name="List_Item_Left" Margin="18,16,17,10" CurrentCellChanged="List_Item_Left_CurrentCellChanged" PreviewKeyDown="List_Item_Left_PreviewKeyDown"  
                           BorderThickness="1" SelectionMode="Extended" SelectionUnit="FullRow"  BorderBrush="#FFE1E1E1" Style="{StaticResource Datagrid_GT_Font_Style}" 
                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" Background="#F0F0F0" >
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" >
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="true" >
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                    <DataTrigger.Setters>
                                        <Setter Property="Background" Value="#F6F6F6" />
                                        <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                    </DataTrigger.Setters>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#e5f3fb" />
                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="30" Header="" Binding="{Binding ONOFF}" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="90" Header=""  Binding="{Binding Graph}" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="true" >
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                            </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn> 
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <Setter Property="ToolTip" Value="{Binding QuestionVariable}" />
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding QuestionVariable}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="300"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    <Button Style="{StaticResource SmallButton}" Content="{x:Static res:LocalResource.LABEL_DBL_RIGHT_ARROW}" Grid.Row="0" Margin="5,0,5,0" x:Name="Command_Select_All_Right" HorizontalAlignment="Center" Click="Command_Select_All_Right_Click" VerticalAlignment="Bottom"  />
                    <Button Style="{StaticResource SmallButton}" Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Grid.Row="1" Margin="5,10,5,0" x:Name="Command_Select_Right" HorizontalAlignment="Center" Click="Command_Select_Right_Click" VerticalAlignment="Top"  />
                </Grid>
                <Grid Grid.Row="1" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="130"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>
                    <Button Style="{StaticResource SmallButton}" Content="{x:Static res:LocalResource.LABEL_DBL_LEFT_ARROW}" Grid.Row="0" Margin="5,0,5,0" x:Name="Command_Select_All_Left" HorizontalAlignment="Center" Click="Command_Select_All_Left_Click" VerticalAlignment="Bottom"   RenderTransformOrigin="0.789,-0.44"/>
                    <Button Style="{StaticResource SmallButton}" Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" Grid.Row="1" Margin="5,10,5,0" x:Name="Command_Select_Left" HorizontalAlignment="Center" Click="Command_Select_Left_Click" VerticalAlignment="Top"  />
                </Grid>
            </Grid>
            <Grid Grid.Column="2" Margin="0,0,4,0">
                <DataGrid  x:Name="List_Item_Right" Margin="0,16,37,10" CurrentCellChanged="List_Item_Right_CurrentCellChanged" PreviewKeyDown="List_Item_Left_PreviewKeyDown"
                           BorderThickness="1" SelectionMode="Extended" SelectionUnit="FullRow"  BorderBrush="#FFE1E1E1" Style="{StaticResource Datagrid_GT_Font_Style}" 
                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" HorizontalGridLinesBrush="White" VerticalGridLinesBrush="White" Background="#F0F0F0"
                           AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" 
                           HorizontalScrollBarVisibility="Hidden" HorizontalAlignment="Right" Width="279">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" >
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="true" >
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                    <DataTrigger.Setters>
                                        <Setter Property="Background" Value="#F6F6F6" />
                                        <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                    </DataTrigger.Setters>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#e5f3fb" />
                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="30" Header="" Binding="{Binding ONOFF}" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="100" Header=""  Binding="{Binding Graph}" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <Setter Property="ToolTip" Value="{Binding QuestionVariable}" />
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding QuestionVariable}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Margin="0,8,0,0" Background="#FFF0F0F0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="122"/>
                <ColumnDefinition Width="234"/>
            </Grid.ColumnDefinitions>
            <Button Style="{StaticResource NormalButton}" Name="Command_Entry" IsEnabled="False" Grid.Column="1" Content="{x:Static res:LocalResource.BTN_DECISION}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,10,5,0" Click="Command_Entry_Click" />
            <Button Style="{StaticResource NormalButton}" Name="Command_Cancel" Content="{x:Static res:LocalResource.BTN_CLOSE}" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,10,0,0" Click="Command_Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
