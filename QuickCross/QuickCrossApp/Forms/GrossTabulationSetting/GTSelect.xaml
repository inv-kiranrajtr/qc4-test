<Window x:Class="Qc4Launcher.Forms.GrossTabulationSetting.GTSelect"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.GrossTabulationSetting"
        mc:Ignorable="d"
        xmlns:res="clr-namespace:Qc4Launcher" ResizeMode="NoResize"
        Title="{x:Static res:LocalResource.GT_SELECT_TABULATION_TITLE}" PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonDown" 
        PreviewMouseRightButtonDown="Window_PreviewMouseRightButtonDown" Background="#FFF0F0F0" ShowInTaskbar="False" Loaded="Window_Loaded" Height="170" Width="254"
        WindowStartupLocation="CenterScreen" BorderBrush="#ADADAD" BorderThickness="1">
    <Grid Background="White" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.GT_SELECT_TABLE_TYPE}" Grid.Row="0" Name="Label_Summary_Variety" Margin="5,15,50,0" />
        <ComboBox Style="{StaticResource NormalComboBox}" Height="25" Grid.Row="1" Text="" Name="Combo_Summary_Variety" Margin="5,0,11,5" SelectionChanged="Combo_Summary_Variety_SelectionChanged">
            <ComboBox.Resources>
                <Style TargetType="Popup">
                    <Setter Property="MaxWidth" Value="608"/>
                </Style>
            </ComboBox.Resources>
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="2" Text="{Binding QSType}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
            <ComboBox.ItemContainerStyle >
                <Style TargetType="{x:Type ComboBoxItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Grid x:Name="gd" TextElement.Foreground="Black">
                                    <Grid.ColumnDefinitions >
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Width="160" Margin="0,0,10,0" Grid.Column="0" Text="{Binding QSType}"/>
                                    <TextBlock Width="70" Margin="0,0,10,0" Grid.Column="1" Text="{Binding QSTypeShort}"/>
                                </Grid>

                                <ControlTemplate.Triggers >
                                    <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                        <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                        <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                    </Trigger>
                                    <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                        <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                        <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>

                            </ControlTemplate>

                        </Setter.Value>
                    </Setter>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>
        <Grid Grid.Row="2" Background="#FFF0F0F0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Button Style="{StaticResource NormalButton}" Name="Command_Entry" Content="{x:Static res:LocalResource.BTN_OK}" HorizontalAlignment="Right" IsEnabled="False" VerticalAlignment="Center" Margin="0,0,5,0"  Click="Command_Entry_Click" />
            <Button Style="{StaticResource NormalButton}" Name="Command_Cancel" Content="{x:Static res:LocalResource.BTN_CANCEL}" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Click="Command_Cancel_Click"  />
        </Grid>
    </Grid>
</Window>
