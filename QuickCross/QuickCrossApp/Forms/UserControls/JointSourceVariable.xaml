<UserControl x:Class="Qc4Launcher.Forms.UserControls.JointSourceVariable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Qc4Launcher.Forms.UserControls"
              xmlns:res="clr-namespace:Qc4Launcher" 
             mc:Ignorable="d" 
             d:DesignHeight="115" d:DesignWidth="675">

    <Grid Grid.Row="0" Margin="8,2,8,2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>
                <TextBlock  Name="Label_OriginItem_Item" Grid.Column="0" Margin="0,2,0,2" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_SOURCE_VARIABLE}"></TextBlock>


                <ComboBox Name="Combo_OriginItem_Item" ItemsSource="{Binding }" Grid.Column="1"  Height="25"
                                VerticalAlignment="Top" IsEditable="True" IsTextSearchEnabled="True"  Margin="0,2,0,2" 
                                HorizontalAlignment="Left" IsEnabled="True" TextSearch.TextPath="Variable"           
                                IsSynchronizedWithCurrentItem="False"   
                        Width="150" Style="{StaticResource NormalComboBox_Editable}" TabIndex="1" >
                    <!--DragEnter="Combo_sourceVariable_DragEnter" SelectionChanged="Combo_sourceVariable_SelectionChanged"  LostFocus="Combo_OriginItem_Item_DropDownClosed"   LostFocus=""-->
                    <ComboBox.Resources>
                        <Style TargetType="Popup">
                            <Setter Property="MaxWidth" Value="508"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="2"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.ItemContainerStyle >
                        <Style TargetType="{x:Type ComboBoxItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Grid x:Name="gd" TextElement.Foreground="Black">
                                            <Grid.ColumnDefinitions >
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Width="150" Margin="5" Grid.Column="0" Text="{Binding Variable}"/>
                                            <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding AnswerTypeWithNoOfChoices}" />
                                            <TextBlock Width="auto" Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                        </Grid>

                                        <ControlTemplate.Triggers >
                                            <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                            </Trigger>
                                            <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

            </Grid>
            <Grid Grid.Row="1" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Name="Label_OriginItem_AnswerType" Grid.Column="0" Margin="0,2,0,2" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.ANS_TYPE_NO_OF_CHOICES_QUESTION}"></TextBlock>
                <TextBlock Name="Text_OriginItem_AnswerType_SelectCount" Grid.Column="1" Margin="0,2,0,2" TextWrapping="Wrap"   Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"  Margin="0,2,0,2"  Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                <!--<TextBox Grid.Column="1"   x:Name="Text_OriginItem_Question"  Height="25" Margin="0,2,10,2" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>-->
                <TextBox x:Name="Text_OriginItem_Question" Grid.Column="1"  ScrollViewer.VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Height="25"  Margin="0,2,10,2" Style="{StaticResource NormalTextBoxMultiLine_READONLY}"  IsTabStop="False"  ></TextBox>

            </Grid>

        </Grid>

        <ListView x:Name="List_OriginItem_ChoiceList"   Style="{StaticResource ListViewCommon}" Grid.Column="1" Margin="0,2,0,2" Background="#F0F0F0"  IsTabStop="False" KeyboardNavigation.TabNavigation="None"></ListView>
        <Grid Grid.Column="2" >
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="1" Name="Label_OriginItem_Choice" Margin="45,2,0,2" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.TARGET_CHOICES}"></TextBlock>

            <Grid Grid.Row="2" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width=".5*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="Combo_OriginItem_Min" IsEditable="False" Style="{StaticResource NormalComboBox_Editable}"  Width="60" Height="25" IsEnabled="False" ></ComboBox>
                <TextBlock Grid.Column="1" Name="Label_OriginItem_Between" Margin="0,2,0,2" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LBL_SEPERATOR_FOR_DISPLAY}" HorizontalAlignment="Center"></TextBlock>
                <ComboBox Grid.Column="2" x:Name="Combo_OriginItem_Max" IsEditable="False" Style="{StaticResource NormalComboBox_Editable}"  Width="60" Height="25" IsEnabled="False" ></ComboBox>
            </Grid>

        </Grid>

    </Grid>

</UserControl>
