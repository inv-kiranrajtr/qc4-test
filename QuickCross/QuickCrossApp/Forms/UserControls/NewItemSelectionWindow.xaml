<Window x:Class="Qc4Launcher.Forms.UserControls.NewItemSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.UserControls"
        xmlns:res="clr-namespace:Qc4Launcher"
        mc:Ignorable="d" PreviewMouseRightButtonDown="Window_PreviewMouseRightButtonDown" PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonDown"
        Title="{x:Static res:LocalResource.LBL_NEW_ITEM_SELECTION}" Height="500" Width="590" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Closed="Window_Closed" Background="#FFF0F0F0" BorderBrush="#ADADAD" BorderThickness="1" ShowInTaskbar="False">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height=".9*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="White"></Border>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txt_newVariable_search" Grid.Column="0" Style="{StaticResource NormalTextBox}" TextChanged="Txt_newVariable_search_TextChanged" Height="25" Margin="8,8,8,0"></TextBox>
            <TextBox x:Name="txt_question_search" Grid.Column="2" Style="{StaticResource NormalTextBox}" TextChanged="Txt_question_search_TextChanged" Width="245" Height="25"  Margin="22,8,8,0" HorizontalAlignment="Left"></TextBox>
        </Grid>
        <ListView x:Name="List_Reuse" Grid.Row="1" Margin="8" Style="{StaticResource ListViewCommon}" MouseDoubleClick="List_Reuse_MouseDoubleClick" SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{Binding Path=ExistingVariableListView}" SelectionChanged="List_Reuse_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <WrapPanel>
                        <TextBlock Text="{Binding Variable}" Width="180"></TextBlock>
                        <TextBlock Text="{Binding AnswerTypeWithNoOfChoices}" Width="100"></TextBlock>
                        <TextBlock Text="{Binding Question}" Width="auto"></TextBlock>
                    </WrapPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Resources>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Border x:Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
                                                    Background="{TemplateBinding Background}"  Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="Selector.IsSelectionActive" Value="False" />
                                            <Condition Property="IsSelected"  Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background"  TargetName="Bd" Value="#F6F6F6" />
                                    </MultiTrigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="Selector.IsSelectionActive" Value="True" />
                                            <Condition Property="IsSelected"  Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" TargetName="Bd"  Value="#CBE8F6" />
                                    </MultiTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5f3fb" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.Resources>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="Select" Content="{x:Static res:LocalResource.BTN_SELECT}"  Style="{StaticResource NormalButton}" HorizontalAlignment="Right" Width="100" Height="25" Margin="6,0,0,0" Click="Select_Click"/>
            <Button Name="CloseBtn" Style="{StaticResource NormalButton}" Content="{x:Static res:LocalResource.BTN_CANCEL}" HorizontalAlignment="Right" Width="100" Height="25" Click="CloseBtn_Click" Margin="6,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
