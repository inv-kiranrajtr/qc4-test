<Window x:Class="Qc4Launcher.Forms.QuestionSetting.QuestionSettingCopy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.QuestionSetting"
        mc:Ignorable="d"
         xmlns:res="clr-namespace:Qc4Launcher"
        Title="{x:Static res:LocalResource.QUESTION_SETTING_FORM_TITLE}" Height="675" Width="620" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Closed="Window_Closed" Loaded="Windowloaded" PreviewMouseRightButtonDown="DisableRightMenu" PreviewMouseRightButtonUp="DisableRightMenu">
    <Window.Resources>
    </Window.Resources>
    <Grid Background="#FFF0F0F0">
        <Grid>
            <Grid.RowDefinitions >
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="50"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#FFFFFFFF" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.8*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Label Name="Label_Item" Style="{StaticResource Labelformat_white}" Content="{x:Static res:LocalResource.ADDQS_VARIABLE_NAME}" Padding="16,0,0,3" VerticalContentAlignment="Bottom"></Label>
                        </Grid>
                        <Grid Grid.Row="1">
                            <TextBox Name="Text_Item_Name" MaxLength="25" Width="200" Height="25" Style="{StaticResource NormalTextBox}" HorizontalAlignment="Left" Margin="16,0,0,15" PreviewKeyUp="Handle_save_btn" ></TextBox>
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Label Name="Label_Answer" Content="{x:Static res:LocalResource.QS_COMBO_LABEL_ANSWERTYPE}" Style="{StaticResource Labelformat_white}"  Padding="16,0,0,0" Width="100" Height="25" Margin="0,5,0,15"/>
                            </Grid>
                            <Grid Grid.Column="1">
                                <ComboBox Name="Combo_Answer_Type" IsEditable="False" Width="75" Height="20" Style="{StaticResource NormalComboBox_qs}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="1,0,0,19" SelectionChanged="AnswertypeChanged">
                                    <ComboBoxItem Name="saType">SA</ComboBoxItem>
                                    <ComboBoxItem Name="maType">MA</ComboBoxItem>
                                    <ComboBoxItem Name="faType">FA</ComboBoxItem>
                                    <ComboBoxItem Name="nType">N</ComboBoxItem>
                                    <ComboBoxItem Name="dType" Visibility="Hidden">D</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Label Name="Label_Category" Content="{x:Static res:LocalResource.QS_COMBO_LABEL_NO_OF_CHOICE}" Style="{StaticResource Labelformat_white}" Width="100" Height="25" Margin="0,0,0,15" Padding="16,5,0,0"></Label>
                            </Grid>
                            <Grid Grid.Column="1">
                                <ComboBox Name="Combo_Category"  Width="75" Height="20" Style="{StaticResource NormalComboBox_Editable_qs}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="1,1,0,19" SelectionChanged="Combo_Category_Validation" PreviewKeyUp="Combo_Category_PreviewKeyUp">
                                    <ComboBoxItem ></ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"></ColumnDefinition>
                                <ColumnDefinition Width="95"></ColumnDefinition>
                                <ColumnDefinition Width="60"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <CheckBox Name="Check_Sort"  Style="{StaticResource CheckBoxNormal}" Width="66" Height="25" HorizontalAlignment="Left" Margin="16,0,0,14" Checked="Check_SortStateChange" Unchecked="Check_SortStateChange">
                                    <TextBlock Name="Label_checksort"   Margin="1,0,0,0" ><Run Text="{x:Static res:LocalResource.QS_CHECK_SORT_LABEL}"></Run></TextBlock>
                                </CheckBox>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Label Name="Label_Sort2" Content="{x:Static res:LocalResource.QS_COMBO_CHOICE_ONE_TO}" Style="{StaticResource Labelformat_white}" Width="92" Height="25" HorizontalContentAlignment="Right"  Padding="0,5,0,0" Margin="0,0,0,15"></Label>
                            </Grid>
                            <Grid Grid.Column="2">
                                <ComboBox Name="Combo_Sort"  HorizontalAlignment="Left" Width="58" Height="20"  Style="{StaticResource NormalComboBox_Editable_qs}" VerticalAlignment="Center" Margin="2,1,0,19" SelectionChanged="Combo_sort_Validation" PreviewKeyUp="Combo_sort_PreviewKeyUp"  ></ComboBox>
                            </Grid>
                            <Grid Grid.Column="3">
                                <Label Name="Label_Sort3" Content="{x:Static res:LocalResource.ADDQS_LABEL_CHOICE1TO_JP}" Style="{StaticResource Labelformat_white}"  HorizontalAlignment="Left" Width="auto" Height="25"  Padding="0,5,0,0" Margin="2,0,1,15"></Label>
                            </Grid>
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=".35*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Label Name="Label_Title" Content="{x:Static res:LocalResource.QS_TXT_LABEL_TABLEHEADING}" Style="{StaticResource Labelformat_white}" Height="25" Width="82" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Padding="0 0 0 0" Margin="0,57,0,18"></Label>
                            </Grid>
                            <Grid Grid.Column="1">
                                <TextBox Name="Text_QuestionA" Style="{StaticResource NormalTextBoxMultiLine}" Height="55" Margin="0,40,16,0" TextWrapping="Wrap"
AcceptsReturn="True"
HorizontalScrollBarVisibility="Disabled"
VerticalScrollBarVisibility="Auto" MaxLength="32767" ></TextBox>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=".35*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Label Content="{x:Static res:LocalResource.QS_TXT_LABEL_QUESTION}" Style="{StaticResource Labelformat_white}" Width="80" Height="25" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Padding="0 0 0 0" Margin="0,28,0,50"></Label>
                            </Grid>
                            <Grid Grid.Column="1">
                                <TextBox  Name="Text_QuestionB" MaxLength="32767" Style="{StaticResource NormalTextBoxMultiLine}" Height="55" Margin="0,0,16,20" TextWrapping="Wrap"
AcceptsReturn="True"
HorizontalScrollBarVisibility="Disabled"
VerticalScrollBarVisibility="Auto"></TextBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="300"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"></ColumnDefinition>
                            <ColumnDefinition Width="150"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <CheckBox Name="Check_SubTotal" Style="{StaticResource CheckBoxNormal}"  Width="130" Height="25" HorizontalAlignment="Left"  Margin="16,-2,0,10"  Checked="Check_SubTotalChange" Unchecked="Check_SubTotalChange"></CheckBox>
                        </Grid>
                        <Grid Grid.Column="1">
                            <Button Name="Command_Subtotal" Content="{x:Static res:LocalResource.QS_BUTTON_SUBTOTAL_SETTING}" Style="{StaticResource NormalButton}"  Click="Subtotalsetting_btn_Click" HorizontalAlignment="Left" Margin="12,0,0,5" ></Button>
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <CheckBox Name="CheckMACN" Style="{StaticResource CheckBoxNormal}" Margin="10,0,0,12">
                            </CheckBox>
                            <TextBlock Name="Label_MACN" TextWrapping="Wrap" Text="{x:Static res:LocalResource.ADDQS_COUNT_LONG_LABEL}" Height="50" Margin="28,0,0,0" ></TextBlock>
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Row="2" Margin="16,6,16,6">
                    <DataGrid  RowHeight="18.25" RowHeaderWidth="0"  PreparingCellForEdit="begincelledit" CellEditEnding="cellend"  CanUserReorderColumns="False" ColumnHeaderHeight="50"  ItemsSource="{Binding}"  CanUserResizeColumns="False" HorizontalScrollBarVisibility="Hidden" HorizontalAlignment="Stretch" CanUserResizeRows="False" ClipboardCopyMode="ExcludeHeader" ColumnHeaderStyle="{StaticResource Datagrid_Header_Style}" Style="{StaticResource Datagrid_normal_qs}" Padding="0" AutoGenerateColumns="False" CanUserSortColumns="False"  Name="data_grid" CanUserAddRows="False" CanUserDeleteRows="False"   SelectedCellsChanged="Datagrid_SelectedCellsChanged" PreviewKeyDown="HandleCopyPaste" PreviewKeyUp="data_grid_PreviewKeyUp" CopyingRowClipboardContent="data_grid_CopyingRowClipboardContent"  >
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                        <DataTrigger.Setters>
                                            <Setter Property="Background" Value="LightGray" />
                                        </DataTrigger.Setters>
                                    </DataTrigger>

                                    <Trigger Property="IsMouseOver"
                           Value="True">
                                        <Setter Property="Background"
                               Value="#e5f3fb" />
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">

                                        <Setter Property="Background" Value="#CBE8F6"/>
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                </Style.Triggers>

                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Resources>
                            <!--<SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" 
                   Color="#FFd9f3fe"/>-->
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                        </DataGrid.Resources>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                <Setter Property="IsTabStop" Value="False" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="50" IsReadOnly="True" Binding="{Binding No}"  x:Name="Choice">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                        <Setter Property="Background" Value="#FFF0F0F0"/>
                                        <Setter Property="KeyboardNavigation.IsTabStop"
                Value="False" />
                                        <Style.Triggers>
                                            <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="Transparent"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground"
                            Value="{DynamicResource
                                   {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FFF0F0F0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="#FF333333" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="*" Header="{x:Static res:LocalResource.QS_DATAGRID_CHOICE}" Binding="{Binding Choice}" x:Name="No">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,0,0,0" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="#FF333333" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="IsTabStop" Value="True" />
                                        <Setter Property="Focusable" Value="True" />
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Width="95"  Header="{x:Static res:LocalResource.QS_DATAGRID_SCOREOFMEAN}" Binding="{Binding SMean}" x:Name="Mean" >
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox" >
                                        <EventSetter Event="TextChanged" Handler="TextBox_scoreofmean_TextChanged"/>
                                        <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown"
                                                     ></EventSetter>
                                        <Setter Property="AcceptsReturn" Value="true" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Setter Property="KeyboardNavigation.IsTabStop"
                Value="True" />
                                        <Style.Triggers>
                                            <Trigger Property="IsReadOnly" Value="True">
                                                <Setter Property="Background" Value="#FFF0F0F0"/>
                                                <Setter Property="KeyboardNavigation.IsTabStop"
                Value="False" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,0,0,0" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="#FF333333" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Width="102">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate >
                                        <StackPanel HorizontalAlignment="Center" Margin="0,0,4,0" >
                                            <Label Content="{x:Static res:LocalResource.QS_DATAGRID_COUNTFORMEAN}"  Loaded="label_countmean" Foreground="#FF333333" />
                                            <CheckBox x:Name="checkAllbox"  Loaded="Checkbox_all_load" HorizontalAlignment="Center"   Checked="Listallchecked" Unchecked="Listallunchecked" ></CheckBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox  Name="checkMean" HorizontalAlignment="Center" IsChecked="{Binding cMean ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Unchecked="fail" Checked="getevnt"  />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>
            </Grid>
            <Border BorderBrush="#FFADADAD" BorderThickness="1" Margin="10"></Border>
            <Grid Grid.Row="1">
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width=".3*"></ColumnDefinition>
                        <ColumnDefinition Width=".35*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Button Name="demoBtn" Content="" Height="0" Width="0" HorizontalAlignment="Left"></Button>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Button Name="addqs_btn_save" Content="{x:Static res:LocalResource.COPY_EDIT__SAVE}"  Style="{StaticResource NormalButton}"  HorizontalAlignment="Right" Margin="0"  ToolTip="{x:Static res:LocalResource.QS_TOOLTIP_SAVE}" Click="Add_New_question_Save_btn"></Button>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Button x:Name="Close_btn" Content="{x:Static res:LocalResource.QSUI_CLOSE}" Style="{StaticResource NormalButton}" Margin="0" Click="Close_btn_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</Window>
