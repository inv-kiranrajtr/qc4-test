<Window x:Class="Qc4Launcher.Forms.ConfirmationBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher"
        mc:Ignorable="d"
        Title="{x:Static local:LocalResource.CONFIRMATION_BOX_TITLE}" Height="Auto" Width="600" Background="WhiteSmoke" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="Arial"
        BorderThickness="1"
        BorderBrush="LightGray"
        AllowsTransparency="True"
        WindowStyle="None"
        SizeToContent="Height" ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button" x:Key="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="0" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="true">
                    <Setter Property="Background" Value="#aeaeae"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <DockPanel Name="dpTitleBar">
            <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="#3467b0" Foreground="WhiteSmoke" FontFamily="Arial" FontWeight="DemiBold" Height="24" Padding="5" Text="{x:Static local:LocalResource.CONFIRMATION_BOX_TITLE}"></TextBlock>
            <StackPanel Name="stkpnlMessageBody" DockPanel.Dock="Bottom" Background="WhiteSmoke" Height="Auto">
                <Grid Background="WhiteSmoke" Height="Auto">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="499*"></ColumnDefinition>
                        <ColumnDefinition Width="99*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="txtbMessage" Text="{x:Static local:LocalResource.CONFIRMATION_BOX_CONTENT_TEXT}" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="WhiteSmoke" Foreground="DarkSlateBlue" FontFamily="Arial" FontWeight="Normal" Height="Auto" Padding="5" Margin="0,30,0,0" TextWrapping="Wrap">
                    </TextBlock>
                    <TextBlock Name="txtDialogStatus" Visibility="Hidden" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="WhiteSmoke" Foreground="DarkSlateBlue" FontFamily="Arial" FontWeight="Normal" Height="Auto" Padding="5" Margin="0,30,0,0" TextWrapping="Wrap">
                    </TextBlock>
                </Grid>

                <Grid Background="WhiteSmoke" VerticalAlignment="Bottom" Margin="5,5,5,5" Height="Auto">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35*"/>
                        <ColumnDefinition Width="92*"/>
                        <ColumnDefinition Width="207"/>
                    </Grid.ColumnDefinitions>
                    <Button Name="btnSaveAs" Click="BtnSaveAs_Click" Style="{StaticResource Button}" Content="{x:Static local:LocalResource.CONFIRMATION_BOX_BUTTON_SAVEAS}" VerticalAlignment="Bottom"  Height="24" Width="100" Margin="0,0,107,0" Grid.Column="2"/>
                    <Button Name="btnSave" Click="BtnSave_Click" Style="{StaticResource Button}" Content="{x:Static local:LocalResource.CONFIRMATION_BOX_BUTTON_SAVE}" HorizontalAlignment="Right"  VerticalAlignment="Top" Height="24" Width="100" Grid.Column="2" Margin="0,0,107,0" />
                    <Button Name="btnCancel" Click="BtnCancel_Click" Visibility="Visible" Style="{StaticResource Button}" Content="{x:Static local:LocalResource.CONFIRMATION_BOX_BUTTON_CANCEL}" VerticalAlignment="Bottom" Height="24" Grid.Column="2" Margin="118,0,10,0"/>

                </Grid>

            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
