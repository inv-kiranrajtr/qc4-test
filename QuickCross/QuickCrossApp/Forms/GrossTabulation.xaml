<Window x:Class="Qc4Launcher.Forms.GrossTabulation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms"
         xmlns:res="clr-namespace:Qc4Launcher"
        mc:Ignorable="d" ResizeMode="NoResize" Closing="Window_Closing" Closed="Window_Closed" Title="{x:Static res:LocalResource.TITLE_GROSS_TAB}" Height="700" Width="700" 
        Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" BorderBrush="#ADADAD" BorderThickness="1">

    <Window.Resources>
        <Style x:Key="txtStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="TextAlignment" Value="Left"></Setter>
        </Style>
        <Style TargetType="ComboBox" x:Key="Combo">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="QuestionVariabl">
            <Grid Height="15" Width="180" ShowGridLines="false">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"></ColumnDefinition>
                    <ColumnDefinition Width="120"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="{Binding QuestionVariable}"
                    Style="{StaticResource txtStyle}"></TextBlock>
                <TextBlock Grid.Column="1"  Text="{Binding QuestionVariableType}"
                    Style="{StaticResource txtStyle}"></TextBlock>
            </Grid>
        </DataTemplate>

        <TextBlock x:Key="header1" Text="QuestionVariable"></TextBlock>
        <TextBlock x:Key="header2" Text="QuestionVariableType"></TextBlock>
        <TextBlock x:Key="header3" Text="Question"></TextBlock>

        <!--Toggle Button Template-->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid x:Name="gd">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" SnapsToDevicePixels="True" Grid.ColumnSpan="2" Background="White" BorderBrush="LightGray" BorderThickness="1"/>
                <Border x:Name="Boredr1" SnapsToDevicePixels="True" Grid.Column="0"  Margin="1" Background="White" BorderBrush="LightGray" BorderThickness="0,0,1,0" />
                <Path x:Name="Arrow" SnapsToDevicePixels="True" Grid.Column="1" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 6 6 L 12 0 Z"/>
                <ContentPresenter Grid.Column="0" TextElement.Foreground="Orange"></ContentPresenter>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="ToggleButton.IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="Black"/>
                    <Setter TargetName="Boredr1" Property="BorderBrush" Value="Black"/>
                </Trigger>
                <Trigger Property="ToggleButton.IsChecked" Value="True">
                    <Setter TargetName="Arrow" Property="Data" Value="M 0 0 L 5 5 L 10 0"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="Black"/>
                    <Setter TargetName="Arrow" Property="StrokeThickness" Value="1.5"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="gd" Property="Visibility" Value="Visible"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!--TextBox Template-->
        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" />
        </ControlTemplate>



        <!--combobox item style-->
        <Style x:Key="Column_CmbItem" TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Grid x:Name="Border" Grid.ColumnSpan="2" Margin="1,0,1,1" Background="White">
                            <ContentPresenter></ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="Gray"></Setter>
                            </Trigger>
                            <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="LightBlue"></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF0F0F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="287*"/>
            <ColumnDefinition Width="100*"/>
            <ColumnDefinition Width="306*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TabControl Margin="10,5,10,50" Grid.ColumnSpan="3">


            <TabItem Name="Page_Refine">
                <TabItem.Header>
                    <StackPanel Name="Container_panel" Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:LocalResource.LABEL_FILTER_SETTING}" Foreground="Black" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Name="GridContainer" ></Grid>
            </TabItem>

            <TabItem Name="Page_Output">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:LocalResource.LABEL_OUTPUT_OPTIONS}" Foreground="Black" />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="191"/>
                        <RowDefinition Height="135"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="130"/>
                        <RowDefinition Height="72"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="186*"/>
                            <RowDefinition Height="5*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60*"/>
                            <ColumnDefinition Width="40*"/>
                        </Grid.ColumnDefinitions>
                        <Border Margin="7,16,11,6" Grid.Column="0" 
                            BorderThickness="1" CornerRadius="0"    BorderBrush="#FFE1E1E1">
                            <Grid Margin="-4,0,0,-1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="60"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="74"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="139"/>
                                        <ColumnDefinition Width="199"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Name="Check_Summary_WeightBack" Unchecked="Check_Summary_WeightBack_Checked" Checked="Check_Summary_WeightBack_Checked" Grid.Column="0" Content="{x:Static res:LocalResource.LABEL_SAMPLE_WEIGHTING}" Margin="15,28,0,15" RenderTransformOrigin="0.5,1"/>
                                    <ComboBox  ItemsSource="{Binding}" VerticalContentAlignment="Center" Height="25" Grid.Column="1" Margin="16,24,0,11" Loaded="Combo_Summary_WeightBack_Loaded"  
                                  PreviewKeyUp="Combo_Summary_WeightBack_PreviewKeyUp"  PreviewKeyDown="Combo_Summary_WeightBack_PreviewKeyDown"
                                  TextSearch.TextPath="QuestionVariable" IsTextSearchEnabled="True" IsEditable="True"
                                VerticalAlignment="Top"  Name="Combo_Summary_WeightBack"                          
                                HorizontalAlignment="Left"  IsEnabled="True" GotKeyboardFocus="Combo_Summary_WeightBack_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="True" DropDownClosed="Combo_Summary_WeightBack_DropDownClosed" FontFamily="Arial" FontSize="12" Foreground="#FF333333"
                                Width="180" ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                                 >
                                        <ComboBox.Resources>
                                            <Style TargetType="Popup">
                                                <Setter Property="MaxWidth" Value="508"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="2" Text="{Binding QuestionVariable}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ComboBoxItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <Grid x:Name="gd" TextElement.Foreground="Black">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Width="150" Margin="5" Grid.Column="0" Text="{Binding QuestionVariable}"/>
                                                                <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding QuestionVariableType}"/>
                                                                <TextBlock Width="Auto" Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                                            </Grid>

                                                            <ControlTemplate.Triggers >
                                                                <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                                    <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                                    <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                                </Trigger>
                                                                <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                                    <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                                    <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>

                                                        </ControlTemplate>

                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                </Grid>
                                <Button Name="BTN_WEIGHT"  Content="{x:Static res:LocalResource.BTN_SAMPLE_WEIGHT}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="25" Width="108" Margin="15,0,0,5" Grid.Row="1" Click="BTN_WEIGHT_Click"/>
                                <CheckBox Name="OutputUnweightbackedTotalCheck" Unchecked="OutputUnweightbackedTotalCheck_Checked" Checked="OutputUnweightbackedTotalCheck_Checked" Content="{x:Static res:LocalResource.LABEL_OUTPUT_UNWEIGHT_BACKED_TOTAL}" Margin="15,9,99,48" RenderTransformOrigin="0.5,1" Grid.Row="2"/>
                            </Grid>
                        </Border>
                        <CheckBox Name="Check_All_Base"  Grid.Column="1" IsEnabled="True" Content="{x:Static res:LocalResource.GT_TABULATION_OUTPUT_RESPONDANTS}" Margin="49,39,10,130"/>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,1,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60*"/>
                            <ColumnDefinition Width="40*"/>
                        </Grid.ColumnDefinitions>
                        <Border Margin="7,6,11,9" Grid.Column="0" 
                            BorderThickness="1" CornerRadius="0" BorderBrush="#FFE1E1E1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="16*"/>
                                    <RowDefinition Height="37*"/>
                                </Grid.RowDefinitions>
                                <CheckBox Name="Check_Output_Graphs" IsChecked="True" Grid.Row="0" Content="{x:Static res:LocalResource.LABEL_GT_CHECK_OUTPUT_GRAPHS}" Margin="15,12,138,7"/>
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20*"/>
                                        <RowDefinition Height="23*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="231*"/>
                                        <ColumnDefinition Width="56*"/>
                                        <ColumnDefinition Width="94*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Name="Check_Output_Hide_ChoiceFor_PieChart" Grid.Column="0" Content="{x:Static res:LocalResource.LABEL_GT_CHECK_OUTPUT_HIDE_CHOICE_PIECHART}" Click="Check_Output_Hide_ChoiceFor_PieChart_Click" Margin="15,12,3,3"/>
                                    <TextBox Name="Text_Outputs_Ratios_EqualToLessThan" Text="0" HorizontalAlignment="Left" x:FieldModifier="private" VerticalContentAlignment="Center" 
                                             TextAlignment="Center" 
                                             LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" 
                                             TextChanged="Text_Outputs_Ratios_EqualToLessThan_TextChanged"
                                             Width="32" Margin="1,1,0,0" RenderTransformOrigin="1.275,0.419" 
                                             Grid.Column="1"  Height="32" VerticalAlignment="Top"/>
                                    <Button Name="BTN_SET_1_UP" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown"  Grid.Column="1" x:FieldModifier="private" Content="˄" FontSize="10" FontWeight="UltraBold" Margin="33,1,2,21" RenderTransformOrigin="0.8,0.647" />
                                    <Button x:Name="BTN_SET_1_DOWN" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private"  Content="˅" FontSize="10" FontWeight="UltraBold" Height="16" VerticalAlignment="Bottom" Margin="33,0,2,5" Grid.Column="1"/>
                                    <Label Content="{x:Static res:LocalResource.LABEL_RATIOS_EQUALTO_LESSTHAN1}"  Name="Label_Rate" Grid.Column="2" HorizontalAlignment="Left" Width="82" Margin="0,5,0,10" RenderTransformOrigin="0.243,0.36"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="2" Margin="28,0,0,0" Text="{x:Static res:LocalResource.LABEL_CHANGE_HEADING}" Height="17" Width="Auto"/>
                    <Grid Grid.Row="3" Margin="0,1,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60*"/>
                            <ColumnDefinition Width="40*"/>
                        </Grid.ColumnDefinitions>
                        <Border Margin="7,0,11,9" Grid.Column="0" 
                            BorderThickness="1" CornerRadius="0" BorderBrush="#FFE1E1E1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="42"/>
                                        <RowDefinition Height="68"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{x:Static res:LocalResource.LABEL_OPTION_TOTAL}"  Name="Label_Option_Total" Grid.Row="0" HorizontalAlignment="Left" Width="76" Margin="15,13,0,4" RenderTransformOrigin="0.724,0.536"/>
                                    <Label Content="{x:Static res:LocalResource.LABEL_NO_ANSWER}"  Name="Label_No_Answer" Grid.Row="1" HorizontalAlignment="Left" Margin="15,5,0,38"/>
                                </Grid>
                                <Grid Grid.Column="1" Margin="0,0,-90,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="45"/>
                                        <RowDefinition Height="68"/>
                                    </Grid.RowDefinitions>
                                    <TextBox Grid.Row="0" Text="{x:Static res:LocalResource.LABEL_OPTION_TOTAL}" Name="Text_Summary_Change_Hyoutou" Width="110" Height="20" Margin="25,15,194,8"/>
                                    <TextBox Grid.Row="1" Text="{x:Static res:LocalResource.LABEL_NO_ANSWER}" Name="Text_Summary_Change_Non" Width="110" Height="20" Margin="25,10,194,35"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
 
            </TabItem>
           
        </TabControl>
        <Button Name="BTN_CREATEREPORT" Margin="21,0,0,10" Visibility="Hidden" Content="{x:Static res:LocalResource.LABEL_CREATEREPORT}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="25" Width="92" Grid.Column="2" Click="BTN_CREATEREPORT_Click" />
        <Button Name="BTN_GROSSTABULATE" Margin="128,0,0,10" Content="{x:Static res:LocalResource.LABEL_EXECUTE_GT}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="25" Width="92" Grid.Column="2" Click="BTN_GROSSTABULATE_Click" />
        <Button Name="BTN_CLOSE" Content="{x:Static res:LocalResource.LABEL_CLOSE}" Margin="231,0,0,10"  HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="25" Width="60" Grid.Column="2" Click="BTN_CLOSE_Click"/>

    </Grid>
</Window>
