<Window x:Class="Qc4Launcher.Forms.SummaryTableForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms"
         xmlns:res="clr-namespace:Qc4Launcher"
         xmlns:userctrl="clr-namespace:FilterSettingsView;assembly=FilterSettingsView"
        mc:Ignorable="d" ResizeMode="NoResize" Title="{x:Static res:LocalResource.TITLE_SUMMARY_FORM}"
        Height="700" Closing="Window_Closing" Closed="Window_Closed" Width="700" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        BorderBrush="#ADADAD" BorderThickness="1" >

    <Window.Resources>
        <Image x:Key="fileopen" Source="/QuickCross4;component/images/file open.PNG"/>
        <Image x:Key="fileopen2" Source="/QuickCross4;component/images/file open.PNG"/>

        <Style x:Key="txtStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="TextAlignment" Value="Left"></Setter>
        </Style>
        <Style TargetType="ComboBox" x:Key="Combo">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="QuestionVariabl">
            <Grid Height="15" Width="180" ShowGridLines="false">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"></ColumnDefinition>
                    <ColumnDefinition Width="120"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="{Binding QuestionVariable}"
                    Style="{StaticResource txtStyle}"></TextBlock>
                <TextBlock Grid.Column="1"  Text="{Binding QuestionVariableType}"
                    Style="{StaticResource txtStyle}"></TextBlock>
            </Grid>
        </DataTemplate>

        <TextBlock x:Key="header1" Text="QuestionVariable"></TextBlock>
        <TextBlock x:Key="header2" Text="QuestionVariableType"></TextBlock>
        <TextBlock x:Key="header3" Text="Question"></TextBlock>

        <!--Toggle Button Template-->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid x:Name="gd">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" SnapsToDevicePixels="True" Grid.ColumnSpan="2" Background="White" BorderBrush="LightGray" BorderThickness="1"/>
                <Border x:Name="Boredr1" SnapsToDevicePixels="True" Grid.Column="0"  Margin="1" Background="White" BorderBrush="LightGray" BorderThickness="0,0,1,0" />
                <Path x:Name="Arrow" SnapsToDevicePixels="True" Grid.Column="1" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 6 6 L 12 0 Z"/>
                <ContentPresenter Grid.Column="0" TextElement.Foreground="Orange"></ContentPresenter>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="ToggleButton.IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="Black"/>
                    <Setter TargetName="Boredr1" Property="BorderBrush" Value="Black"/>
                </Trigger>
                <Trigger Property="ToggleButton.IsChecked" Value="True">
                    <Setter TargetName="Arrow" Property="Data" Value="M 0 0 L 5 5 L 10 0"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="Black"/>
                    <Setter TargetName="Arrow" Property="StrokeThickness" Value="1.5"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="gd" Property="Visibility" Value="Visible"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!--TextBox Template-->
        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" />
        </ControlTemplate>



        <!--combobox item style-->
        <Style x:Key="Column_CmbItem" TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Grid x:Name="Border" Grid.ColumnSpan="2" Margin="1,0,1,1" Background="White">
                            <ContentPresenter></ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="Gray"></Setter>
                            </Trigger>
                            <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="LightBlue"></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56*"/>
            <ColumnDefinition Width="231*"/>
            <ColumnDefinition Width="100*"/>
            <ColumnDefinition Width="306*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TabControl Margin="10,5,10,50" Grid.ColumnSpan="4">


            <TabItem Name="Page_Refine">
                <TabItem.Header>
                    <StackPanel Name="Container_panel" Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:LocalResource.LABEL_FILTER_SETTING}" Foreground="Black" />
                    </StackPanel>
                </TabItem.Header>
                <Grid Name="GridContainer"></Grid>
            </TabItem>
            <TabItem Name="Page_Summary">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:LocalResource.LABEL_TABULATION_OPTION}" Foreground="Black" />
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="260"></RowDefinition>
                        <RowDefinition Height="220"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60*"/>
                            <ColumnDefinition Width="50*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height=".5*"/>
                                <RowDefinition Height="1.2*"/>
                                <RowDefinition Height=".4*"/>
                                <RowDefinition Height="1.5*"/>
                                <RowDefinition Height=".4*"/>
                                <!--<RowDefinition Height=".7*"/>-->
                                <!--<RowDefinition Height="2.3*"/>-->
                            </Grid.RowDefinitions>

                            <TextBlock Text="{x:Static res:LocalResource.LABEL_ST_TABULATE}" Grid.Row="0" Height="22" HorizontalAlignment="Left" Width="90" Margin="30,11,0,1"/>
                            <Border Margin="20,0,0,0" Grid.Row="1" 
                            BorderThickness="1" CornerRadius="0"  VerticalAlignment="Top"  BorderBrush="#FFE1E1E1">
                                <Grid Margin="0,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="50"/>
                                    </Grid.RowDefinitions>
                                    <RadioButton Content="{x:Static res:LocalResource.RB_OUTPUT_SHEET_TYPE_ONE}" Name="Option_Output_SheetType_One"  Grid.Row="0" Margin="10,5,0,0"  VerticalAlignment="Center" HorizontalAlignment="Left" Height="15" ></RadioButton>
                                    <Grid Grid.Row="1"  Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="101*"/>
                                            <ColumnDefinition Width="100*"/>
                                            <ColumnDefinition Width="26*"/>
                                            <ColumnDefinition Width="75*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Name="Check_Output_Cross_N" Checked="Check_Output_Settings_Unchecked" Unchecked="Check_Output_Settings_Unchecked" Content="{x:Static res:LocalResource.LABEL_N_}"  IsEnabled="True" Margin="49,4,0,5"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19" Width="70" Grid.ColumnSpan="2" />
                                        <CheckBox  Grid.Column="1" Name="Check_Output_Cross_Par" Checked="Check_Output_Settings_Unchecked" Unchecked="Check_Output_Settings_Unchecked" Content="{x:Static res:LocalResource.LABEL_PER}"  IsEnabled="True" Margin="48,4,0,5"   HorizontalAlignment="Left" VerticalAlignment="Center" Height="19" Width="71" Grid.ColumnSpan="3" />
                                    </Grid>
                                </Grid>
                            </Border>
                            <CheckBox Grid.Row="2" HorizontalAlignment="Left" Name="Check_Summary_WeightBack" Unchecked="Check_Summary_WeightBack_Checked" Checked="Check_Summary_WeightBack_Checked" Content="{x:Static res:LocalResource.LABEL_SAMPLE_WEIGHTING}" Height="15" Width="120" Margin="30,8,0,0"/>
                            <Border Margin="20,3,0,0" Grid.Row="3" 
                            BorderThickness="1" CornerRadius="0"    BorderBrush="#FFE1E1E1">
                                <Grid Margin="0,0,0,0">

                                    <Grid  Margin="0,0,0,10" Grid.RowSpan="3">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <ComboBox Grid.Row="0"  ItemsSource="{Binding}"  Height="25" Grid.Column="0" Margin="10,7,0,0" Loaded="Combo_Summary_WeightBack_Loaded"  
                                  PreviewKeyUp="Combo_Summary_WeightBack_PreviewKeyUp" PreviewKeyDown="Combo_Summary_WeightBack_PreviewKeyDown"
                                  TextSearch.TextPath="QuestionVariable"     IsTextSearchEnabled="True" IsEditable="True"
                                VerticalAlignment="Top"  Name="Combo_Summary_WeightBack"                             
                                HorizontalAlignment="Left"  IsEnabled="True" GotKeyboardFocus="Combo_Summary_WeightBack_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="True" DropDownClosed="Combo_Summary_WeightBack_DropDownClosed" FontFamily="Arial" FontSize="12" Foreground="#FF333333"
                                Width="150" ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                                 >
                                            <ComboBox.Resources>
                                                <Style TargetType="Popup">
                                                    <Setter Property="MaxWidth" Value="508"/>
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="2" Text="{Binding QuestionVariable}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ComboBoxItem}">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Grid x:Name="gd" TextElement.Foreground="Black">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="150"/>
                                                                        <ColumnDefinition Width="80"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Width="150" Margin="5" Grid.Column="0" Text="{Binding QuestionVariable}"/>
                                                                    <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding QuestionVariableType}"/>
                                                                    <TextBlock Width="Auto" Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                                                </Grid>

                                                                <ControlTemplate.Triggers >
                                                                    <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                                        <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                                        <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                                    </Trigger>
                                                                    <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                                        <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                                        <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>

                                                            </ControlTemplate>

                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                        </ComboBox>
                                        <Button Name="BTN_WEIGHT" Width="108" Margin="10,7,0,0" Content="{x:Static res:LocalResource.BTN_SAMPLE_WEIGHT}" VerticalAlignment="Top" HorizontalAlignment="Left"  Height="25"  Grid.Row="1" Click="BTN_WEIGHT_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                            <TextBlock HorizontalAlignment="Left" Grid.Row="4" Name="Frame_Summary_Mark" Text="{x:Static res:LocalResource.LABEL_MARKING}" Height="22" Width="50" Margin="30,7,0,0"/>

                        </Grid>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height=".7*"/>
                                <RowDefinition Height="2.6*"/>
                                <!--<RowDefinition Height=".4*"/>-->
                                <!--<RowDefinition Height="1.5*"/>-->
                                <RowDefinition Height="3.1*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{x:Static res:LocalResource.LABEL_CHANGE_HEADING}" Height="22" Width="90" HorizontalAlignment="Left" Margin="20,10,0,1"/>
                            <Border Margin="10,3,10,0" Grid.Row="1" 
                            BorderThickness="1" CornerRadius="0"    BorderBrush="#FFE1E1E1">

                                <Grid Margin="0,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*"/>
                                        <RowDefinition Height="1*"/>
                                        <RowDefinition Height="1*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0"  Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Name="Label_Summary_Change_Hyoutou" Text="{x:Static res:LocalResource.LABEL_TOTAL_COLUMN}" Grid.Column="0" Margin="10,0,0,0" Height="20" HorizontalAlignment="Left" />
                                        <TextBox Name="Text_Summary_Change_Hyoutou" Text="{x:Static res:LocalResource.LABEL_OPTION_TOTAL}" Grid.Column="1" HorizontalAlignment="Left"  Margin="0,0,0,0" Width="110" Height="20"  />
                                    </Grid>
                                    <Grid Grid.Row="1"  Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Name="Label_Summary_Change_Hyosoku" Text="{x:Static res:LocalResource.LABEL_TOTAL_ROW}" Grid.Column="0" Margin="10,0,0,0" Height="20" HorizontalAlignment="Left" />
                                        <TextBox Name="Text_Summary_Change_Hyosoku" Text="{x:Static res:LocalResource.LABEL_OPTION_TOTAL}"  Grid.Column="1"  HorizontalAlignment="Left" Margin="0,0,0,0" Width="110" Height="20"  />

                                    </Grid>
                                    <Grid Grid.Row="2"  Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Name="Label_Summary_Change_Non" Text="{x:Static res:LocalResource.LABEL_NO_ANSWER}" Grid.Column="0" Margin="10,0,0,0" Height="20" HorizontalAlignment="Left"/>
                                        <TextBox Name="Text_Summary_Change_Non" Text="{x:Static res:LocalResource.LABEL_NO_ANSWER}"  Grid.Column="1"  HorizontalAlignment="Left"  Margin="0,0,0,0" Width="110" Height="20" />

                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="85*"/>
                            <ColumnDefinition Width="15*"/>
                        </Grid.ColumnDefinitions>
                        <Border Margin="20,0,0,0" Grid.Row="5" 
                            BorderThickness="1" CornerRadius="0"    BorderBrush="#FFE1E1E1">
                            <Grid Grid.Row="0"  Margin="0,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height=".6*"/>
                                    <RowDefinition Height=".25*"/>
                                    <RowDefinition Height=".75*"/>
                                    <RowDefinition Height=".5*"/>
                                    <RowDefinition Height=".5*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="11.5*"/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition Width="78.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Name="Label_Summary_Mark_N_Equal" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_N}" Margin="10,11,0,6" HorizontalAlignment="Left" VerticalAlignment="Center" Height="20" Width="16" />
                                    <TextBox Name="Text_Summary_Mark_N_Equal"  Grid.Column="1" MaxLength="4" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox"   Margin="0,9,12,8" Width="35" Height="20"    />
                                    <TextBlock Name="Label_Summary_Mark_Above" Grid.Column="2" Text="{x:Static res:LocalResource.LABEL_EQUALTO_MORETHAN}"  Margin="9,10,0,7" HorizontalAlignment="Left" VerticalAlignment="Center" Height="20" Width="154" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,10,0,13" Grid.RowSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26*"/>
                                        <ColumnDefinition Width="32*"/>
                                        <ColumnDefinition Width="46*"/>

                                    </Grid.ColumnDefinitions>

                                    <CheckBox  Grid.Column="0" Name="Check_Summary_Mark_Ratio1" Unchecked="Check_Difference_Marking_Checked" Checked="Check_Difference_Marking_Checked"  Content="{x:Static res:LocalResource.LABEL_DIFFERENCE_BETWEEN}"  IsEnabled="True"  Margin="10,19,0,19"  HorizontalAlignment="Left" VerticalAlignment="Center" Height="15" Width="116" Grid.ColumnSpan="2"/>

                                    <Grid Grid.Column="1" >
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" >
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20*"/>
                                                <ColumnDefinition Width="30*"/>
                                                <ColumnDefinition Width="50*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox  Grid.Column="0" Name="Check_Summary_Rate_Difference1" Unchecked="Check_Summary_Rate_Difference1_Checked" Checked="Check_Summary_Rate_Difference1_Checked"    IsEnabled="True"   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,6" />
                                            <ComboBox Name="Combo_Summary_Rate_Difference1"  IsEnabled="True" Margin="0,0,0,6" Visibility="Visible" Grid.Column="1" Height="20" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="38" >
                                                <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.LABEL_ADD_MINUS}"/>
                                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_ADD}"/>
                                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_HYPHEN}"/>
                                            </ComboBox>
                                            <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="4 0 0 0" >
                                                <TextBox x:Name="Text_Summary_Rate_Difference1" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="0,5,0,5" Width="30" Text="0" TextAlignment="Center" />
                                                <Grid >
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Button Name="BTN_SET_1_UP"  PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" Grid.Row="0" x:FieldModifier="private" Margin="0,5,5,0" Content="˄" Width="20" FontSize="5" FontWeight="UltraBold" />
                                                    <Button Grid.Row="1" x:Name="BTN_SET_1_DOWN" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown"   x:FieldModifier="private" Margin="0,0,5,5"  Content="˅" Width="20" FontSize="5" FontWeight="UltraBold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Grid.Row="1" >
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20*"/>
                                                <ColumnDefinition Width="30*"/>
                                                <ColumnDefinition Width="50*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox  Grid.Column="0" Name="Check_Summary_Rate_Difference2"  Unchecked="Check_Summary_Rate_Difference2_Checked" Checked="Check_Summary_Rate_Difference2_Checked"      IsEnabled="True"    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,6,0,7" />
                                            <ComboBox Name="Combo_Summary_Rate_Difference2"  IsEnabled="True" Margin="0,4,0,4" Visibility="Visible" Grid.Column="1" Height="20" VerticalAlignment="Center" HorizontalAlignment="Left" Width="38" Grid.ColumnSpan="2" >
                                                <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.LABEL_ADD_MINUS}"/>
                                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_ADD}"/>
                                                <ComboBoxItem Content="{x:Static res:LocalResource.LABEL_HYPHEN}"/>
                                            </ComboBox>
                                            <StackPanel Orientation="Horizontal" Grid.Column="3" Margin="4 0 0 0">
                                                <TextBox x:Name="Text_Summary_Rate_Difference2" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="0,5,0,5" Width="30" Text="0" TextAlignment="Center"  />
                                                <Grid >
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="9*"/>
                                                        <ColumnDefinition Width="16*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Button Grid.Row="0" x:Name="BTN_SET_2_UP" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,5,5,0" Content="˄" Width="20" FontSize="5" FontWeight="UltraBold" />
                                                    <Button Grid.Row="1" x:Name="BTN_SET_2_DOWN" PreviewMouseUp="BTN_SET_1_UP_PreviewMouseUp" PreviewMouseDown="BTN_SET_1_UP_PreviewMouseDown" x:FieldModifier="private" Margin="0,0,5,5"  Content="˅" Width="20"  FontSize="5" FontWeight="UltraBold" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0 0 5 0">
                                        <TextBlock x:Name="Frame_Color_Settings" Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_COLOR_SETTINGS}" Margin="0 0 10 0" VerticalAlignment="Center" HorizontalAlignment="Left"  />
                                        <ComboBox
                                            x:Name="Combo_Color_Settings_P" 
                                            Height="25"
                                            FontFamily="Arial" 
                                            Width="140" 
                                            VerticalContentAlignment="Center"
                                            IsEditable="False"
                                            SelectedValuePath="Name"
                                        >
                                            <ComboBox.Resources>
                                                <Style TargetType="Popup">
                                                    <Setter Property="Width" Value="auto"/>
                                                    <Setter Property="MaxWidth" Value="508"/>
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="2" Text="{Binding DisplayName}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>

                                        </ComboBox>

                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="3" Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="25.5*"/>
                                        <ColumnDefinition Width="74.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Name="Check_Summary_SignificantDifferece_Test" Unchecked="Check_Summary_SignificantDifferece_Test_Checked" Checked="Check_Summary_SignificantDifferece_Test_Checked" Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_TEST}"  IsEnabled="True" Margin="10,12,0,16"   HorizontalAlignment="Left"  Height="20" Width="107" />
                                    <ComboBox IsEnabled="True"  SelectionChanged="Combo_SignificantDifference_Test_SelectionChanged" Margin="0,10,1,15" Visibility="Visible" Name="Combo_SignificantDifference_Test" HorizontalAlignment="Left"  Width="262" Grid.Column="1"  >
                                        <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.TEST_OVERALL_DIFFERENCE}"/>
                                        <ComboBoxItem Content="{x:Static res:LocalResource.TEST_FOR_DIFFERENT_BETWEEN_AXIS_ITEMS}"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="113"/>
                                        <ColumnDefinition Width="66*"/>
                                        <ColumnDefinition Width="66*"/>
                                        <ColumnDefinition Width="97*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Name="Label_Summary_SignificantDifferece" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL}" Margin="10,8,0,6" HorizontalAlignment="Left"  Height="25" Width="100"/>
                                    <CheckBox  Grid.Column="1" Name="Check_Par_99"      Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL1}"  IsEnabled="True" Margin="24,10,0,9"   HorizontalAlignment="Left" Height="20"/>
                                    <CheckBox  Grid.Column="2" Name="Check_Par_95"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL5}"  IsEnabled="True" Margin="24,10,0,9"   HorizontalAlignment="Left"  Height="20" RenderTransformOrigin="-0.308,-0.2"/>
                                    <CheckBox  Grid.Column="3" Name="Check_Par_90"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL10}"  IsEnabled="True" Margin="24,9,0,10"   HorizontalAlignment="Left" Height="20" RenderTransformOrigin="-2,-0.3"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
