<UserControl x:Class="Qc4Launcher.Forms.Multivariate_Analysis.Usercontrols.crosstabulate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis.Usercontrols"
             mc:Ignorable="d" 
             xmlns:res="clr-namespace:Qc4Launcher"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Grid.Row="1" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10" >

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.18*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="1">


                    <DataGrid  x:Name="Multi_Process_Grid" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="0 0 5 0" BorderThickness="1" 
                                               ColumnHeaderHeight="40"
                                               FocusVisualStyle="{x:Null}"
                                               VerticalScrollBarVisibility="Auto" RowHeight="20" VirtualizingPanel.ScrollUnit="Pixel"
                                           SelectionMode="Single" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="#F0F0F0"
                                           HeadersVisibility="Column"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForMV}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" >
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="true" >
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                        <DataTrigger.Setters>
                                            <Setter Property="Background" Value="#F6F6F6" />
                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                        </DataTrigger.Setters>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5f3fb" />
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.QUSI_VARIABLE}" Width="0.5*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>

                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="5 0 0 0" Text="{Binding Variable}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.CROSS_ANSTYPE_NO_OF_CHOICE}" Width="0.5*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                      
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="5 0 0 0" Text="{Binding AnswerTypeCount}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.LABEL_QUESTION}" Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <Setter Property="ToolTip" Value="{Binding Question}" />
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="5 0 0 0" Text="{Binding Question}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>



                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        
                        <RowDefinition/>

                    </Grid.RowDefinitions>
                    
                </Grid>
                <Grid Grid.Row="1" Grid.Column="2">


                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1" Grid.RowSpan="2" VerticalAlignment="Center">
                        <Button  TabIndex="4" Margin="0 2 0 0" Style="{StaticResource SmallButton}"  x:Name="btn_rgt_arrw"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw_Click" />
                        <Button  TabIndex="6" Margin="0 5 0 0"  Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow" Width="25" Height="25" Click="Lbl_Single_Left_Arrow_Click" HorizontalAlignment="Left" />

                    </StackPanel>
                    <TextBlock Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="3" Margin="10 5 5 3" Text="{x:Static res:LocalResource.MULTI_CORRES_ROW_VARIABLE_SIDE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                    <TextBox IsTabStop="True" TabIndex="5" x:Name="txt_Expensive_variable" Style="{StaticResource NormalTextBox}" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"  Height="22" Margin="10 2 5 5" />
                    <TextBlock x:Name="choicetxt1" Grid.Column="1"  Grid.Row="2" Margin="10 2 5 5" Text="{x:Static res:LocalResource.MULTI_CORRES_CHOICE_ONE_TO}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                    <ComboBox TabIndex="7" Grid.Row="3" Grid.Column="1"  Height="25"  Margin="10,5,0,0"  SelectedIndex="0"  Style="{StaticResource NormalComboBox}" x:Name="combobox_choices" VerticalAlignment="Top"></ComboBox>
                    <TextBlock  x:Name="choicetxt2" Grid.Column="2"  Grid.Row="3" Margin="10 5 5 5" Text="{x:Static res:LocalResource.MULTI_CORRES_UPTO}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Left"></TextBlock>

                    
                    
                    <StackPanel Grid.Row="6" Grid.RowSpan="2" VerticalAlignment="Center">
                        <Button  TabIndex="8" Margin="0 2 0 0" Style="{StaticResource SmallButton}"  x:Name="btn_rgt_arrw1"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw1_Click" />
                        <Button  TabIndex="10" Margin="0 5 0 0"  Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow1" Width="25" Height="25" Click="Lbl_Single_Left_Arrow1_Click"  />
                    </StackPanel>

                    <TextBlock Grid.Column="1" Grid.Row="5" Margin="10 5 5 3" Text="{x:Static res:LocalResource.MULTI_CORRES_COLUMN_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                    <TextBox TabIndex="9" x:Name="txt_variable_exp" Style="{StaticResource NormalTextBox}" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"  Height="22" Margin="10 2 5 5" />
                    <TextBlock x:Name="choicetxt3" Grid.Column="1"  Grid.Row="7" Margin="10 5 5 5" Text="{x:Static res:LocalResource.MULTI_CORRES_CHOICE_ONE_TO}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                    <ComboBox  x:Name="choicelist" TabIndex="11" Grid.Row="8" Grid.Column="1"  Height="25"  Margin="10,5,0,0" SelectedIndex="0"  Style="{StaticResource NormalComboBox}"  VerticalAlignment="Top"></ComboBox>
                    <TextBlock x:Name="choicetxt4" Grid.Column="2"  Grid.Row="8" Margin="10 5 5 5" Text="{x:Static res:LocalResource.MULTI_CORRES_UPTO}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Left"></TextBlock>

                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
