<UserControl x:Class="Qc4Launcher.Forms.Multivariate_Analysis.Usercontrols.ClusterUsd"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis.Usercontrols"
             mc:Ignorable="d" 
             xmlns:res="clr-namespace:Qc4Launcher"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10" >

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="1">

                    <DataGrid  x:Name="Multi_Process_Grid" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="0 0 5 0" BorderThickness="1" 
                                               ColumnHeaderHeight="40"
                                               FocusVisualStyle="{x:Null}"
                                               VerticalScrollBarVisibility="Auto" RowHeight="20" VirtualizingPanel.ScrollUnit="Pixel"
                                           SelectionMode="Single" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="#F0F0F0"
                                           HeadersVisibility="Column"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForMV}"
                                            PreviewKeyDown="Multi_Process_Grid_PreviewKeyDown">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" >
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="true" >
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                        <DataTrigger.Setters>
                                            <Setter Property="Background" Value="#F6F6F6" />
                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                        </DataTrigger.Setters>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5f3fb" />
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.QUSI_VARIABLE}" Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>

                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="5 0 0 0" Text="{Binding Variable}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.CROSS_ANSTYPE_NO_OF_CHOICE}" Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <Setter Property="ToolTip" Value="{Binding Question}" />
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="5 0 0 0" Text="{Binding AnswerTypeCount}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.LABEL_QUESTION}" Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>

                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Padding="5 0 0 0" Text="{Binding Question}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>



                </Grid>

                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>

                    </Grid.RowDefinitions>
                    <Button Grid.Row="2"  Style="{StaticResource SmallButton}"  x:Name="btn_rgt_arrw"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw_Click"/>
                    <Button Grid.Row="4"   Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow" Width="25" Height="25"  Click="Lbl_Single_Left_Arrow_Click"/>

                </Grid>
                <Grid Grid.Row="1" Grid.Column="2">


                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Margin="10 5 5 5" Text="Matrix Variable" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>


                    <DataGrid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"  IsSynchronizedWithCurrentItem="True" 
                                              KeyboardNavigation.TabNavigation="Once" VirtualizingPanel.ScrollUnit="Pixel"
                               CanUserDeleteRows="False" GridLinesVisibility="None" AutoGenerateColumns="False"
                              x:Name="Selected_grid" ItemsSource="{Binding}" Background="#F0F0F0" FontFamily="Arial" 
                             SelectionMode="Extended" Style="{StaticResource Datagrid_GT_Font_Style}" FocusVisualStyle="{x:Null}" SelectionUnit="FullRow"
                              ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForGT}" RowHeight="20" Padding="0"
                              CanUserAddRows="False" CanUserReorderColumns="False" CanUserResizeRows="False" HeadersVisibility="None" Margin="5 0 0 0"
                               >

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" >

                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="true" >
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>

                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                        </DataGrid.Resources>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                        <DataTrigger.Setters>
                                            <Setter Property="Background" Value="#F6F6F6" />
                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                        </DataTrigger.Setters>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e5f3fb" />
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*" Header="Variable">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Foreground="#FF333333" Margin="13 2 0 0" Text="{Binding Variable}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="*" Header="Answer Type">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
                                        <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>

                                            </Trigger>

                                        </Style.Triggers>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>
                                        <TextBlock Foreground="#FF333333" Margin="0 2 0 0" Text="{Binding AnswerTypeCount}" Width="100"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Question" Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
                                        <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>

                                            </Trigger>

                                        </Style.Triggers>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock  ToolTip="{Binding Question}" Foreground="#FF333333" Margin="0 2 0 0" Text="{Binding Question}" />

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                   
                    <ComboBox  Grid.Row="4" Grid.Column="0"  Height="25" Width="150" HorizontalAlignment="Left" Margin="5,5,0,0" SelectedIndex="0"  Style="{StaticResource NormalComboBox}" x:Name="combobox_choices" VerticalAlignment="Top"></ComboBox>
                    
                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
