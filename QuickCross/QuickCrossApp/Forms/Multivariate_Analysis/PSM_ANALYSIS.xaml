                                <TextBox Style="{StaticResource NormalTextBox}"  Grid.Row="1"  Grid.Column="1" Height="20" Margin="5 0 5 2" x:Name="txt_Cheap_variable1"/>
                                <TextBox   Style="{StaticResource NormalTextBox}"  Grid.Row="2"  Grid.Column="1" Height="20" Margin="5 0 5 2" x:Name="txt_tooExpensve_variable1"/>
                                <TextBox  Style="{StaticResource NormalTextBox}"  Grid.Row="3"  Grid.Column="1" Height="20" Margin="5 0 5 2" x:Name="txt_toocheap_variable1"/>


                                <TextBlock x:Name="txt17"  Grid.Row="0" Grid.Column="2" Text="-" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                <TextBlock x:Name="txt18" Grid.Row="1" Grid.Column="2" Text="-" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                <TextBlock x:Name="txt19" Grid.Row="2" Grid.Column="2" Text="-" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
