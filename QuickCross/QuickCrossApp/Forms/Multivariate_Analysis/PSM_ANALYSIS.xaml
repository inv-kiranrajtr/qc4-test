<Window xmlns:Usercontrols="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis.Usercontrols"  xmlns:UserControls="clr-namespace:Qc4Launcher.Forms.UserControls"  x:Class="Qc4Launcher.Forms.Multivariate_Analysis.PSM_ANALYSIS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis"
         xmlns:res="clr-namespace:Qc4Launcher"
        xmlns:FilterSettingsView="clr-namespace:FilterSettingsView;assembly=FilterSettingsView"
        mc:Ignorable="d"
        Title="{x:Static res:LocalResource.MULTI_PSM_HEADING}" Closing="Window_Closing" PreviewMouseRightButtonDown="DisableRightMenu" ResizeMode="NoResize" PreviewMouseRightButtonUp="DisableRightMenu" Height="700" Width="600" Background="#FFF0F0F0" PreviewKeyDown="Window_PreviewKeyDown" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" ContentRendered="Window_ContentRendered" Closed="Window_Closed">
    <Window.Resources>

        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                          BorderThickness="1" BorderBrush="White"
                          CornerRadius="0,0,0,0">
                                <ContentPresenter 
                          ContentSource="Header"
                          RecognizesAccessKey="True" />
                            </Border>
                            <Border Grid.Row="1" BorderBrush="#D5DFE5"
                                    BorderThickness="1"
                                    CornerRadius="0,0,0,0">
                                <ContentPresenter Margin="4" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <TabControl Margin="10" SelectionChanged="TabControl_SelectionChanged_1">
            <TabItem x:Name="Page_GT_Summary">
                <TabItem.Header>
                    <TextBlock Grid.Column="0" Text="{x:Static res:LocalResource.MULTI_ANALYSIS_SETTINGS}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Margin="5" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                    <ComboBox SelectionChanged="Combo_Answer_type_SelectionChanged"  Grid.Column="1" Height="25" Width="60" HorizontalAlignment="Left" Margin="5" SelectedIndex="0"  Style="{StaticResource NormalComboBox}" x:Name="combo_Answer_type"></ComboBox>
                    <Grid Grid.Row="2" Grid.ColumnSpan="3">

                        <DataGrid  x:Name="Multi_Process_Grid" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="5 5 5 2" BorderThickness="1" 
                                               ColumnHeaderHeight="40"
                                               FocusVisualStyle="{x:Null}"
                                               VerticalScrollBarVisibility="Auto" RowHeight="20" VirtualizingPanel.ScrollUnit="Pixel"
                                           SelectionMode="Single" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="#F0F0F0"
                                           HeadersVisibility="Column"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForMV}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" >
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                            <DataTrigger.Setters>
                                                <Setter Property="Background" Value="#F6F6F6" />
                                                <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                            </DataTrigger.Setters>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5f3fb" />
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.QUSI_VARIABLE}" Width="*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>

                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding Variable}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.CROSS_ANSTYPE_NO_OF_CHOICE}" Width="*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>

                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding AnswerTypeCount}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.LABEL_QUESTION}" Width="*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                            <Setter Property="ToolTip" Value="{Binding Question}" />
                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding Question}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>


                    </Grid>

                   

                    <Grid Grid.Row="1" Grid.Column="3" Grid.RowSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <Button   Style="{StaticResource SmallButton}" Margin="0 5 0 0" x:Name="btn_rgt_arrw"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw_Click"/>

                            <Button   Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow" Width="25" Height="25" HorizontalAlignment="Left" Margin="7,0,0,0" Click="Lbl_Single_Left_Arrow_Click"/>

                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Grid.Column="0" Margin="5" Text="{x:Static res:LocalResource.MULTI_PSM_EXPENSIVE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
