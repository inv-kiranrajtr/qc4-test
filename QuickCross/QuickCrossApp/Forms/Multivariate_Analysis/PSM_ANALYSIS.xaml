                            <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Margin="5 0 5 5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="2" Text="{x:Static res:LocalResource.MULTI_PSM_MIN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="1"  Text="{x:Static res:LocalResource.MULTI_PSM_MAX}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="2"  Text="{x:Static res:LocalResource.MULTI_PSM_MEAN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBox Margin="2 2 2 2" Grid.Column="1" Grid.Row="0" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_min_val1"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="1" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False"  Height="20" IsReadOnly="True"  x:Name="txt_max_val1"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="2" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_mean_val1"/>

                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <Button  Style="{StaticResource SmallButton}" Margin="0 5 0 0" x:Name="btn_rgt_arrw2"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Click="Btn_rgt_arrw2_Click" Width="25" Height="25"/>
                            <Button  Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow2" Width="25" Height="25" Click="Lbl_Single_Left_Arrow2_Click" HorizontalAlignment="Left" Margin="7,0,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1">
                            <TextBlock Grid.Column="0" Margin="5" Text="{x:Static res:LocalResource.MULTI_PSM_CHEAP}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                            <TextBox TextChanged="Txt_Cheap_variable_TextChanged"  Style="{StaticResource NormalTextBox}" IsReadOnly="True" Grid.Column="1"  Height="20" Margin="5 0 5 2" x:Name="txt_Cheap_variable"/>
                            <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Margin="5 0 5 5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="2" Text="{x:Static res:LocalResource.MULTI_PSM_MIN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="1"  Text="{x:Static res:LocalResource.MULTI_PSM_MAX}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="2"  Text="{x:Static res:LocalResource.MULTI_PSM_MEAN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBox Margin="2 2 2 2" Grid.Column="1" Grid.Row="0" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_min_val2"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="1" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False"  Height="20" IsReadOnly="True"  x:Name="txt_max_val2"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="2" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_mean_val2"/>

                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="2">
                            <Button   Style="{StaticResource SmallButton}" Margin="0 5 0 0" x:Name="btn_rgt_arrw3"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw3_Click"/>
                            <Button    Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow3" Width="25" Height="25" Click="Lbl_Single_Left_Arrow3_Click" />

                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock Grid.Column="0" Margin="5" Text="{x:Static res:LocalResource.MULTI_PSM_TOO_EXPENSIVE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                            <TextBox TextChanged="Txt_TooExpensive_variable_TextChanged"  Style="{StaticResource NormalTextBox}" IsReadOnly="True" Grid.Column="1"  Height="20" Margin="5 0 5 2" x:Name="txt_TooExpensive_variable"/>
                            <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Margin="5 0 5 5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="2" Text="{x:Static res:LocalResource.MULTI_PSM_MIN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="1"  Text="{x:Static res:LocalResource.MULTI_PSM_MAX}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="2"  Text="{x:Static res:LocalResource.MULTI_PSM_MEAN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBox Margin="2 2 2 2" Grid.Column="1" Grid.Row="0" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_min_val3"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="1" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False"  Height="20" IsReadOnly="True"  x:Name="txt_max_val3"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="2" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_mean_val3"/>

                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="3">
                            <Button    Style="{StaticResource SmallButton}" Margin="0 5 0 0" x:Name="btn_rgt_arrw4"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw4_Click"/>
                            <Button    Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow4" Width="25" Height="25" Click="Lbl_Single_Left_Arrow4_Click" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="3">
                            <TextBlock Grid.Column="0" Margin="5" Text="{x:Static res:LocalResource.MULTI_PSM_TOO_CHEAP}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                            <TextBox TextChanged="Txt_Tocheap_variable_TextChanged"  Style="{StaticResource NormalTextBox}" IsReadOnly="True" Grid.Column="1"  Height="20" Margin="5 0 5 2" x:Name="txt_Tocheap_variable"/>
                            <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Margin="5 0 5 5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="2" Text="{x:Static res:LocalResource.MULTI_PSM_MIN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="1"  Text="{x:Static res:LocalResource.MULTI_PSM_MAX}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="0" Margin="2" Grid.Row="2"  Text="{x:Static res:LocalResource.MULTI_PSM_MEAN}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBox Margin="2 2 2 2" Grid.Column="1" Grid.Row="0" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_min_val4"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="1" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False"  Height="20" IsReadOnly="True"  x:Name="txt_max_val4"/>
                                    <TextBox Margin="2 0 2 2" Grid.Column="1" Grid.Row="2" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False" Height="20" IsReadOnly="True"  x:Name="txt_mean_val4"/>

                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="3" Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Column="0" Margin="5,0,5,8" Text="{x:Static res:LocalResource.PSM_GRAPHDISPLAY_RANGE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" VerticalAlignment="Bottom" ></TextBlock>
                        <TextBox  Style="{StaticResource NormalTextBox}" Grid.Column="1" Width="90" Height="20" Margin="5" x:Name="txt_graph_displayrng"/>
                        <TextBlock Grid.Column="2" Margin="5" Text="-" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                        <TextBox  Style="{StaticResource NormalTextBox}" Grid.Column="3" Width="90" Height="20" Margin="5 5 0 5" x:Name="txt_grah_range"/>
                        <TextBlock Grid.Column="0" Grid.Row="1" Margin="5" Text="{x:Static res:LocalResource.MULTI_PSM_SCALE_INTERVAL}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                        <TextBox  Grid.Column="1" Grid.Row="1" Style="{StaticResource NormalTextBox}" Width="90" Height="20" Margin="5" x:Name="txt_scale_interval"/>
                    </Grid>

                    <CheckBox  Style="{StaticResource CheckBoxCommon}" VerticalAlignment="Top" Grid.Column="3" Grid.Row="3" Margin="5 5 5 5" x:Name="Check_Setting_Cross_Group">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_PSM_INVERT_FOR_OUTPUT}" Grid.RowSpan="2"></TextBlock>
                        </Grid>
                    </CheckBox>
                </Grid>
            </TabItem>
            <TabItem x:Name="Page_Refine">
