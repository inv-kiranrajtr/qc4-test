                            </Grid>
                            <StackPanel VerticalAlignment="Center" Grid.Row="8" Grid.Column="2" Margin="0 0 0 0">
                                <Button Click="Btn_rgt_arrw_choice3_Click"  Style="{StaticResource SmallButton}"  x:Name="btn_rgt_arrw_choice3"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25"  />
                                <Button Click="Lbl_Single_Left_Arrow_choice3_Click"  Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow_choice3" Width="25" Height="25" Margin="0 10 0 0"   />

                            </StackPanel>
                            <Grid Grid.Column="3" Grid.Row="8"  >


                                <DataGrid  x:Name="Selected_grid4" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="0 0 10 10" BorderThickness="1" 
                                           VirtualizingPanel.ScrollUnit="Pixel"  
                                           FocusVisualStyle="{x:Null}"
                                           VerticalScrollBarVisibility="Auto" RowHeight="17" 
                                           SelectionMode="Extended" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="#F0F0F0"
                                           HeadersVisibility="None"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForGT}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" >
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                    </DataGrid.Resources>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                    <DataTrigger.Setters>
                                                        <Setter Property="Background" Value="#F6F6F6" />
                                                        <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                    </DataTrigger.Setters>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#e5f3fb" />
                                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                      
                                     
                                        <DataGridTemplateColumn Header="Question" Width="*">
                                            <DataGridTemplateColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                    <Setter Property="ToolTip" Value="{Binding Question}" />
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                </Style>
                                            </DataGridTemplateColumn.CellStyle>
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding choice}" TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>


                            </Grid>

                        </Grid>
                    </Grid>
                </Border>
            </TabItem>
            <TabItem x:Name="Page_Refine">
                <TabItem.Header>
                    <TextBlock Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_FILTER_SETTING}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <CheckBox Checked="OnCheck" HorizontalAlignment="Left" Unchecked="OnCheck" x:Name="Check_Refine_Condition" Style="{StaticResource CheckBoxCommon}" Content="{x:Static res:LocalResource.LABEL_FILTERING_CRITERIA}" Margin="10 20 10 0"/>
                    <Grid Grid.Row="1" x:Name="filterGrid">
                        <Border BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10"  >
                            <FilterSettingsView:FilterControlMulti x:Name="fdesign" Margin="10"/>
                            <!--<Usercontrols:CriteriaControl x:Name="Criteria_Control" Margin="10"/>-->
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Visibility="Hidden">
                <TabItem.Header>
                    <TextBlock Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_GRAPH_OPTIONS}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <GroupBox   Foreground="#FF333333" Margin="10" FontFamily="Arial" x:Name="Output_summary">
                        <GroupBox.Header>
                            <TextBlock Style="{StaticResource TextBlockNormal}" Text="Graph Pattern Setting"   />

                        </GroupBox.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                               
                            </StackPanel>
                           

                                <Grid  Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource TextBlockNormal}" Margin="10 0 0 0" Text="Background"/>
                                <TextBox Grid.Column="1" IsReadOnly="True" x:Name="backgroud_color_txtbx" Margin="10" Width="20" Height="20" MouseDoubleClick="Backgroud_color_txtbx_MouseDoubleClick" Cursor="Arrow"></TextBox>
                                <ComboBox  Grid.Column="2" Height="25" Width="100" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="5" SelectedIndex="0" Style="{StaticResource NormalComboBox}" x:Name="background_combo"></ComboBox>
                                    
                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Style="{StaticResource TextBlockNormal}" Margin="10 0 0 0" Text="Marker Foreground"/>
                                <TextBox Grid.Row="1" Grid.Column="1" IsReadOnly="True" x:Name="Expensive_color_txtbx" Margin="10" Width="20" Height="20" MouseDoubleClick="Backgroud_color_txtbx_MouseDoubleClick" Cursor="Arrow"></TextBox>

                                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Style="{StaticResource TextBlockNormal}" Margin="10 0 0 0" Text="Character"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" IsReadOnly="True" x:Name="TooExpensive_color_txtbx" Margin="10" Width="20" Height="20" MouseDoubleClick="Backgroud_color_txtbx_MouseDoubleClick" Cursor="Arrow"></TextBox>

                                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource TextBlockNormal}" Margin="10 0 0 0" Text="Marker Background"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" IsReadOnly="True" x:Name="Cheep_color_txtbx" Margin="10" Width="20" Height="20" MouseDoubleClick="Backgroud_color_txtbx_MouseDoubleClick" Cursor="Arrow"></TextBox>

                                    
                                </Grid>
                           
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Button TabIndex="20" HorizontalAlignment="Left"  Style="{StaticResource NormalButton}" Margin="10 10 10 10"  Content="Initialize"  Width="100" Height="25" />
                                <Button TabIndex="20" Grid.Column="1" HorizontalAlignment="Right"  Style="{StaticResource NormalButton}" Margin="10 10 10 10"  Content="Restore Default"  Width="100" Height="25" Click="Button_Click" />
                                <Button TabIndex="20" Grid.Column="2" HorizontalAlignment="Right"  Style="{StaticResource NormalButton}" Margin="10 10 10 10"  Content="Save as Default"  Width="100" Height="25" />

                            </Grid>
                        </Grid>


                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
        
        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button IsEnabled="False"   Style="{StaticResource NormalButton}" Margin="0 10 10 10" x:Name="btn_Execute"  Content="{x:Static res:LocalResource.LABEL_EXECUTE}" Width="100" Height="25" Click="Btn_Execute_Click" />
                <Button    Style="{StaticResource NormalButton}" Margin="0 10 10 10"  Content="{x:Static res:LocalResource.LABEL_CLOSE}" x:Name="Btn_close" Width="100" Height="25" Click="Btn_close_Click"   />

            </StackPanel>
        </Grid>
    </Grid>
</Window>
