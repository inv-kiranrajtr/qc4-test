<Window xmlns:FilterSettingsView="clr-namespace:FilterSettingsView;assembly=FilterSettingsView"  xmlns:Usercontrols="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis.Usercontrols"  x:Class="Qc4Launcher.Forms.Multivariate_Analysis.Cluster_Analysis"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis"
        mc:Ignorable="d"
          xmlns:res="clr-namespace:Qc4Launcher" PreviewMouseRightButtonDown="DisableRightMenu" PreviewMouseRightButtonUp="DisableRightMenu"
        Title="{x:Static res:LocalResource.MULTI_CLUSTOR_HEADING}" Height="700" Width="810" Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown" Background="#FFF0F0F0" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                          BorderThickness="1" BorderBrush="White"
                          CornerRadius="0,0,0,0">
                                <ContentPresenter 
                          ContentSource="Header"
                          RecognizesAccessKey="True" />
                            </Border>
                            <Border Grid.Row="1" BorderBrush="#D5DFE5"
                                    BorderThickness="1"
                                    CornerRadius="0,0,0,0">
                                <ContentPresenter Margin="4" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <TabControl Margin="10" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Name="Page_GT_Summary">
                <TabItem.Header>
                    <TextBlock Grid.Column="0"  Text="{x:Static res:LocalResource.MULTI_ANALYSIS_SETTINGS}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                </TabItem.Header>
                <Grid>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Grid.ColumnSpan="3" Grid.Row="0" Margin="10 5 5 5" Text="{x:Static res:LocalResource.MULTI_FACTOR_ANALYSIS_FOR_ANSWER_HEADING}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>


                        <Border Grid.Row="1" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10"  >

                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Margin="5 0 15 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Visibility="Collapsed" Grid.Row="0" Margin="0 5 5 5" Text="{x:Static res:LocalResource.QUSI_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="1"  Visibility="Collapsed"  Grid.Row="0" Margin="0 5 5 5" Text="{x:Static res:LocalResource.CROSS_ANSTYPE_NO_OF_CHOICE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                    <TextBlock Grid.Column="2"  Visibility="Collapsed"  Grid.Row="0" Margin="0 5 5 5" Text="{x:Static res:LocalResource.LABEL_QUESTION}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>

                                </Grid>
                                <Grid Grid.Row="0" Grid.RowSpan="2">

                                    <DataGrid  x:Name="Multi_Process_Grid" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="0 0 5 0" BorderThickness="1" 
                                               ColumnHeaderHeight="40"
                                               FocusVisualStyle="{x:Null}"
                                               VerticalScrollBarVisibility="Visible" RowHeight="22.3" VirtualizingPanel.ScrollUnit="Item"
                                           SelectionMode="Extended" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="#F0F0F0"
                                           HeadersVisibility="Column"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForMV}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell" >
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                        </DataGrid.Resources>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                        <DataTrigger.Setters>
                                                            <Setter Property="Background" Value="#F6F6F6" />
                                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                        </DataTrigger.Setters>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#e5f3fb" />
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.QUSI_VARIABLE}" Width="0.50*">
                                                <DataGridTemplateColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="true" >
                                                                <Setter Property="Foreground" Value="Black" />
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                            </Trigger>
                                                        </Style.Triggers>

                                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                    </Style>
                                                </DataGridTemplateColumn.CellStyle>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Padding="5 0 0 0" Text="{Binding Variable}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                           
                                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.CROSS_ANSTYPE_NO_OF_CHOICE}" Width="0.5*">
                                                <DataGridTemplateColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="true" >
                                                                <Setter Property="Foreground" Value="Black" />
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                        <Setter Property="ToolTip" Value="{Binding Question}" />
                                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                    </Style>
                                                </DataGridTemplateColumn.CellStyle>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Padding="5 0 0 0" Text="{Binding AnswerTypeCount}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.LABEL_QUESTION}" Width="*">
                                                <DataGridTemplateColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="true" >
                                                                <Setter Property="Foreground" Value="Black" />
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                        <Setter Property="ToolTip" Value="{Binding Question}" />
                                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                    </Style>
                                                </DataGridTemplateColumn.CellStyle>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Padding="5 0 0 0" Text="{Binding Question}" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                      
                                        </DataGrid.Columns>
                                    </DataGrid>

                                   
                                </Grid>

                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>

                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="2"   Style="{StaticResource SmallButton}"  x:Name="btn_rgt_arrw"  Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Width="25" Height="25" Click="Btn_rgt_arrw_Click"/>
                                    <Button Grid.Row="4"   Style="{StaticResource SmallButton}"  Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" x:Name="Lbl_Single_Left_Arrow" Width="25" Height="25"  Click="Lbl_Single_Left_Arrow_Click"/>

                                </Grid>
                                <Grid Grid.Column="2">
                                    <TextBlock Grid.Column="0" Grid.ColumnSpan="3"  Grid.Row="0" Margin="10 15 5 5" Text="{x:Static res:LocalResource.MULTI_CLUSTOR_ANALYSIS_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>

                                </Grid>
                                <Grid Grid.Row="1" Grid.Column="2">


                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2">
                                    </Grid>
                                    <Grid Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2">
                                        <DataGrid  x:Name="Selected_grid" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="5 7 0 0" BorderThickness="1" 
                                               VerticalScrollBarVisibility="Auto"
                                                   RowHeight="22.3"
                                           SelectionMode="Extended" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="#F0F0F0"
                                           HeadersVisibility="None"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" 
                                                   ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForGT}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell" >
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                </Style>
                                            </DataGrid.CellStyle>
                                            <DataGrid.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                            </DataGrid.Resources>

                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                            <DataTrigger.Setters>
                                                                <Setter Property="Background" Value="#F6F6F6" />
                                                                <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                            </DataTrigger.Setters>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#e5f3fb" />
                                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="1.5*" Header="Variable" Binding="{Binding Variable}" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                                                    <DataGridTextColumn.CellStyle>
                                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="true" >
                                                                    <Setter Property="Foreground" Value="Black" />
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                        </Style>
                                                    </DataGridTextColumn.CellStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Width="*" Header="AnswerType/ No. of Choices"  Binding="{Binding AnswerTypeCount}" CanUserResize="False" CanUserSort="False" IsReadOnly="True">
                                                    <DataGridTextColumn.CellStyle>
                                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="true" >
                                                                    <Setter Property="Foreground" Value="Black" />
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                        </Style>
                                                    </DataGridTextColumn.CellStyle>
                                                </DataGridTextColumn>
                                                <!--<DataGridTemplateColumn Header="Question" Width="*">
                                                    <DataGridTemplateColumn.CellStyle>
                                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="true" >
                                                                    <Setter Property="Foreground" Value="Black" />
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                            <Setter Property="ToolTip" Value="{Binding Question}" />
                                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                        </Style>
                                                    </DataGridTemplateColumn.CellStyle>
                                                    --><!--<DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Question}" TextTrimming="CharacterEllipsis"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>--><!--
                                                </DataGridTemplateColumn>-->
                                            </DataGrid.Columns>
                                        </DataGrid>

                                    </Grid>
                              
                                </Grid>

                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.9*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                           
                        </Grid>
                        <Grid Grid.Row="2" Margin="5 0 0 0" Grid.Column="2" Grid.ColumnSpan="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>

                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="5 5 0 5" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" VerticalAlignment="Center" Text="{x:Static res:LocalResource.MULTI_CLUSTOR_NO_OF_CLUSTOR}"></TextBlock>
                                <Usercontrols:NumericUpDown VerticalAlignment="Center" x:Name="numericUpDown" Width="50"  Grid.Column="1" Margin="15 5 5 5"/>
                            </StackPanel>
                            <CheckBox x:Name="checkbox_check_result" VerticalAlignment="Bottom" Style="{StaticResource CheckBoxCommon}" IsChecked="True" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="1" Margin="5 5 5 5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition Height="3*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_FACTOR_SAVE_RESULT}"  Grid.RowSpan="2"></TextBlock>
                                </Grid>
                            </CheckBox>
                            <TextBlock Grid.Row="2" Margin="5 0 0 10" Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" VerticalAlignment="Top"  Text="{x:Static res:LocalResource.MULTI_CLUSTOR_EXCLUDE_CASES}"></TextBlock>

                        </Grid>

                    </Grid>
                </Grid>
            </TabItem>
            <TabItem x:Name="Page_Refine">
                <TabItem.Header>
                    <TextBlock Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_FILTER_SETTING}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <CheckBox Checked="OnCheck" HorizontalAlignment="Left" Unchecked="OnCheck" x:Name="Check_Refine_Condition" Style="{StaticResource CheckBoxCommon}" Content="{x:Static res:LocalResource.LABEL_FILTERING_CRITERIA}" Margin="10 20 10 0"/>
                    <Grid Grid.Row="1" x:Name="filterGrid">
                        <Border BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10"  >
                            <FilterSettingsView:FilterControlMulti x:Name="fdesign" Margin="10"/>
                            <!--<Usercontrols:CriteriaControl x:Name="Criteria_Control" Margin="10"/>-->
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button IsEnabled="False"  Style="{StaticResource NormalButton}" Margin="0 10 10 10" x:Name="btn_Execute" Click="Btn_Execute_Click"  Content="{x:Static res:LocalResource.LABEL_EXECUTE}" Width="100" Height="25"/>
                <Button     Style="{StaticResource NormalButton}" Margin="0 10 10 10"  Content="{x:Static res:LocalResource.LABEL_CLOSE}" x:Name="Btn_close" Width="100" Height="25" Click="Btn_close_Click"  />

            </StackPanel>
        </Grid>
    </Grid>
</Window>
