                                            </Grid>
                                        </Border>
                              

                                    <GroupBox Visibility="Collapsed" Grid.Row="1" x:Name="groupbox_rotation_method"  Foreground="#FF333333" Margin="10 0 10 10" FontFamily="Arial" >
                                        <GroupBox.Header>
                                            <TextBlock Style="{StaticResource TextBlockNormal}" TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_FACTOR_ROTATION_METHOD}"  x:Name="grp_header" />
                                        </GroupBox.Header>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="txt_ortho_rotation" Grid.Column="0" Grid.Row="0" Margin="5" Text="{x:Static res:LocalResource.MULTI_FACTOR_ORTHOGONAL_ROTATION}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                                            <TextBlock x:Name="txt_orgue_rotation" Grid.Column="1" Grid.Row="0" Margin="5" Text="{x:Static res:LocalResource.MULTI_FACTOR_OBLIQUE_ROTATION}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>

                                        </Grid>
                                    </GroupBox>
                                </Grid>



                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2" Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Border BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>

                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <RadioButton Grid.Row="0" x:Name="Num_factor_extracted_radiobtn" Checked="RadioButton_Checked" Unchecked="RadioButton_Checked" Margin="5" Style="{StaticResource RadibuttonNormal}" >
                                        <!--<TextBlock TextWrapping="Wrap">No. of Factors to be extracted</TextBlock>-->
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition Height="3*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_FACTOR_FACTOR_TO_EXTRACTED}" Grid.RowSpan="2"></TextBlock>
                                        </Grid>
                                    </RadioButton>
                                    <Usercontrols:NumericUpDown x:Name="numericUpDown" HorizontalAlignment="Left" Width="50"  Grid.Column="1" Margin="5"/>
                                    <RadioButton Grid.ColumnSpan="3" x:Name="rdo_adopt_factor" Grid.Row="1" Style="{StaticResource RadibuttonNormal}" Margin="5" >
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition Height="3*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_FACTOR_WITH_EIGN}" Grid.RowSpan="2"></TextBlock>
                                        </Grid>
                                    </RadioButton>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="Checkbox_Score_reverse_order" Style="{StaticResource CheckBoxCommon}" Grid.Column="2" Grid.Row="0" Margin="17 5 5 5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition Height="3*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_FACTOR_ASSIGN_SCORES_REVERSE_ORDER}" Grid.RowSpan="2"></TextBlock>
                                    </Grid>
                                </CheckBox>

                                <CheckBox x:Name="checkbox_check_result" Style="{StaticResource CheckBoxCommon}" HorizontalAlignment="Left" Grid.Column="2" Grid.Row="1" Margin="17 5 5 5">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="7"/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock TextWrapping="Wrap" Text="{x:Static res:LocalResource.MULTI_FACTOR_SAVE_RESULT}"   Grid.RowSpan="2"></TextBlock>
                                    </Grid>
                                </CheckBox>
                            </Grid>
                        </Grid>

                    </Grid>
                </Grid>
            </TabItem>
            <TabItem x:Name="Page_Refine">
                <TabItem.Header>
                    <TextBlock Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_FILTER_SETTING}" Style="{StaticResource TextBlockNormalWithCenterAligned}" ></TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <CheckBox Checked="OnCheck" HorizontalAlignment="Left" Unchecked="OnCheck" x:Name="Check_Refine_Condition" Style="{StaticResource CheckBoxCommon}" Content="{x:Static res:LocalResource.LABEL_FILTERING_CRITERIA}" Margin="10 20 10 0"/>
                    <Grid Grid.Row="1" x:Name="filterGrid">
                        <Border BorderThickness="1" BorderBrush="#FFE1E1E1" Margin="10"  >
                            <FilterSettingsView:FilterControlMulti x:Name="fdesign" Margin="10"/>
                            <!--<Usercontrols:CriteriaControl x:Name="Criteria_Control" Margin="10"/>-->
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button IsEnabled="False"   Style="{StaticResource NormalButton}" Margin="0 10 10 10" x:Name="btn_Execute"  Content="{x:Static res:LocalResource.LABEL_EXECUTE}" Width="100" Height="25" Click="Btn_Execute_Click"/>
                <Button    Style="{StaticResource NormalButton}" Margin="0 10 10 10"  Content="{x:Static res:LocalResource.LABEL_CLOSE}" x:Name="Btn_close" Width="100" Height="25" Click="Btn_close_Click"  />

            </StackPanel>
        </Grid>
    </Grid>
</Window>
