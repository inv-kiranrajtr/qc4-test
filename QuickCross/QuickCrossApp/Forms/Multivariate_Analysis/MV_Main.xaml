<Window x:Class="Qc4Launcher.Forms.Multivariate_Analysis.MV_Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:Qc4Launcher"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.Multivariate_Analysis"
        mc:Ignorable="d"
        Title="{x:Static res:LocalResource.MULTIVARIATE_MAIN_HEADER}" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Height="700" 
        Width="1040" PreviewKeyDown="Window_PreviewKeyDown" Background="#FFF0F0F0" Loaded="Window_Loaded"  Closed="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid Margin="10" Background="White" >
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1.5*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Border Margin="10" BorderBrush="#FFE1E1E1" BorderThickness="1" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static res:LocalResource.MULTI_VARIATE_ANALYSIS_PROCESS}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Margin="15 10 0 0"></TextBlock>
                        <Grid Grid.Column="1">
                        <StackPanel  Orientation="Horizontal">
                            <Image Source="/img/warning.png" Width="25" Height="25" VerticalAlignment="Center" Margin="5 5 0 0"/>
                            <TextBlock  Text="{x:Static res:LocalResource.MULTI_VARIATE_PROCESS_TYPE}" Margin="10 5 0 0" Style="{StaticResource TextBlockNormalWithCenterAligned}" VerticalAlignment="Center" ></TextBlock>

                        </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Visibility="Hidden" Click="Button_Help_Click" x:Name="Button_Help" Grid.Column="2" IsTabStop="True" TabIndex="0" HorizontalAlignment="Right" Style="{StaticResource Button_Hlep}"  Width="50" Height="25" Margin="0,5,10,0" Content="{x:Static res:LocalResource.BTN_HELP}" ToolTip="{x:Static res:LocalResource.TOOLTIP_HELP}" />

                            </StackPanel>
                        </Grid>
                        <DataGrid Grid.Row="1" TabIndex="0" x:Name="Multi_Process_Grid" Grid.ColumnSpan="2"  CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="10 10 10 10" BorderThickness="1" 
                                                SelectedIndex="0"
                                               FocusVisualStyle="{x:Null}"  FontFamily="Arial"
                                               VerticalScrollBarVisibility="Auto" RowHeight="20" VirtualizingPanel.ScrollUnit="Pixel"
                                           SelectionMode="Single" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="White"
                                           HeadersVisibility="None"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForMV}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" >
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                            </DataGrid.Resources>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <EventSetter Event="MouseDoubleClick" Handler="Row_DoubleClick"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                            <DataTrigger.Setters>
                                                <Setter Property="Background" Value="#F6F6F6" />
                                                <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                            </DataTrigger.Setters>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5f3fb" />
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>

                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.MULTI_MAIN_ANALYSIS_NAME}" Width="*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>

                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding JType}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                           
                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Width="3*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>

                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding Type}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Style="{StaticResource NormalButton}"  x:Name="Btn_Setting_process" Width="100" Height="25" Content="{x:Static res:LocalResource.MULTI_MAIN_SETTING}" Grid.Row="2" Grid.Column="3" Margin="10 0 10 10" HorizontalAlignment="Right" Click="Btn_Setting_process_Click" ></Button>

                    </Grid>
                </Border>
            </Grid>
            <Border Grid.Row="1" BorderBrush="#FFE1E1E1" BorderThickness="1" Margin="10">
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.24*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="0" Visibility="Collapsed" Text="{x:Static res:LocalResource.MULTI_MAIN_ANALYSIS_NAME}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Margin="15 10 0 0"></TextBlock>
                    <TextBlock Grid.Column="1" Visibility="Collapsed" Text="{x:Static res:LocalResource.MULTI_MAIN_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Margin="8 10 0 0"></TextBlock>
                    <TextBlock Grid.Column="2" Visibility="Collapsed" Text="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Margin="8 10 0 0"></TextBlock>
                    <Grid Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Grid.RowSpan="4">

                        <DataGrid  x:Name="data_grid" CurrentCellChanged="List_GT_Summary_CurrentCellChanged"  Margin="10 10 5 10" BorderThickness="1" 
                                              
                                               FocusVisualStyle="{x:Null}" 
                                               VerticalScrollBarVisibility="Auto" RowHeight="20" VirtualizingPanel.ScrollUnit="Pixel"  FontFamily="Arial"
                                           SelectionMode="Single" SelectionUnit="FullRow" Style="{StaticResource Datagrid_GT_Font_Style}" ItemsSource="{Binding}" Background="White"
                                           HeadersVisibility="Column"  IsEnabled="True" AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" 
                                           CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Hidden" ColumnHeaderStyle="{StaticResource Datagrid_Header_StyleForMV}"
                                            PreviewKeyDown="List_GT_Summary_PreviewKeyDown">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" >
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="true" >
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                            <DataTrigger.Setters>
                                                <Setter Property="Background" Value="#F6F6F6" />
                                                <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                            </DataTrigger.Setters>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5f3fb" />
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.MULTI_MAIN_ANALYSIS_NAME}" Width="0.5*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>

                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding ProcessName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.MULTI_MAIN_NEW_VARIABLE}" Width="0.5*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                            <Setter Property="ToolTip" Value="{Binding Question}" />
                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding NumberofVariable}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Width="*">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="true" >
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>

                                            <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Padding="5 0 0 0" Text="{Binding VariableName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Visibility="{Binding Items.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}, ElementName=data_grid}" Text="{x:Static res:LocalResource.MULTI_MAIN_EXECUTED_ANALYSIS_RESULT}" HorizontalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" x:Name="txt_Nodata" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="3" Grid.RowSpan="3">
                        <StackPanel>
                            <Button Style="{StaticResource NormalButton}"  x:Name="Btn_Delete" Width="100" Height="25" Content="{x:Static res:LocalResource.BTN_DELETE}" Grid.Row="1" Grid.Column="3" Margin="5 10 10 10" HorizontalAlignment="Right" IsEnabled="{Binding ElementName=data_grid, Path=SelectedItems.Count}" Click="Btn_Delete_Click" ></Button>
                            <Button Style="{StaticResource NormalButton}"  x:Name="Btn_Edit" Width="100" Height="25" Content="{x:Static res:LocalResource.BTN_EDIT}" Grid.Row="2" Grid.Column="3" Margin="5 0 10 10" HorizontalAlignment="Right" IsEnabled="{Binding ElementName=data_grid, Path=SelectedItems.Count}" Click="Btn_Edit_Click"  ></Button>
                            <Button Style="{StaticResource NormalButton}"  x:Name="Btn_Reset" Width="100" Height="25" Content="{x:Static res:LocalResource.MULTI_MAIN_RESET}" Grid.Row="3" Grid.Column="3" Margin="5 0 10 10" HorizontalAlignment="Right" IsEnabled="False" Click="Btn_Reset_Click"></Button>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

        </Grid>
        <Grid Grid.Row="2"  Height="50">
            <Button Style="{StaticResource NormalButton}"  x:Name="Btn_Close" Width="100" Height="25" Content="{x:Static res:LocalResource.BTN_CLOSE}" Grid.Row="3" Grid.Column="3" Margin="0 0 10 0" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Btn_Close_Click" ></Button>

        </Grid>
    </Grid>
</Window>
