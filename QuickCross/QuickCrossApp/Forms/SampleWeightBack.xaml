<Window x:Class="Qc4Launcher.Forms.SampleWeightBack"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher"
          xmlns:res="clr-namespace:Qc4Launcher"
        mc:Ignorable="d" ResizeMode="NoResize" Height="500"   Width="550"
        Loaded="Window_Loaded" WindowStartupLocation="CenterScreen"
        Title="{x:Static res:LocalResource.TITLE_SAMPLE_WEIGH}" MouseRightButtonUp="DisableRightMenu" MouseRightButtonDown="DisableRightMenu" ShowInTaskbar="False" BorderBrush="#ADADAD" BorderThickness="1" Background="#FFF0F0F0" Closing="Window_Closing">
    <Window.Resources>


    </Window.Resources>

    <Grid Margin="5"  Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="410"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Column="0" 
                            BorderThickness="1" CornerRadius="0"    BorderBrush="LightGray">
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100*"/>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="175*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0 5 0 0">
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_WEIGHTING_VARIABLE}" Grid.Column="0" Margin="10,10,0,0" HorizontalAlignment="Left" Width="120"/>
                        <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_ANSWERTYPE}" Grid.Column="1" VerticalAlignment="Center" Margin="10,10,0,0" HorizontalAlignment="Left" />
                        <TextBox Foreground="#999999" Style="{StaticResource NormalTextBox_READONLY}" Name="Text_OriginItem_AnswerType" IsReadOnly="True" Grid.Column="2"     Margin="10,10,0,0"  Height="25"  />
                        <TextBlock Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_CHOICE_COUNT}" Grid.Column="3" VerticalAlignment="Center" Margin="10,10,10,0" HorizontalAlignment="Right"  />
                        <TextBox Foreground="#999999" Style="{StaticResource NormalTextBox_READONLY}"  Name="Text_OriginItem_SelectCount" IsReadOnly="True" Height="25" Grid.Column="4"   Margin="0,10,10,0"  />
                        <Grid Grid.Row="1">
                            <ComboBox VerticalContentAlignment="Center"  ItemsSource="{Binding}"  Height="25" Grid.Column="0" Margin="10,10,0,0" Loaded="Combo_OriginItem_Item_Loaded"  
                                  PreviewKeyUp="Combo_OriginItem_Item_PreviewKeyUp" PreviewKeyDown="Combo_OriginItem_Item_PreviewKeyDown"
                                  TextSearch.TextPath="QuestionVariable"     IsTextSearchEnabled="True" IsEditable="True"
                                VerticalAlignment="Top"  Name="Combo_OriginItem_Item"   SelectionChanged="Combo_OriginItem_Item_SelectionChanged"                          
                                HorizontalAlignment="Left"  IsEnabled="True" GotKeyboardFocus="Combo_OriginItem_Item_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="True" DropDownClosed="Combo_OriginItem_Item_DropDownClosed" FontFamily="Arial" FontSize="12" Foreground="#FF333333"
                                Width="145" ScrollViewer.HorizontalScrollBarVisibility="Visible" 
                                 >
                                <ComboBox.Resources>
                                    <Style TargetType="Popup">
                                        <Setter Property="MaxWidth" Value="508"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="2" Text="{Binding QuestionVariable}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ComboBoxItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <Grid x:Name="gd" TextElement.Foreground="Black">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Width="150" Margin="5" Grid.Column="0" Text="{Binding QuestionVariable}"/>
                                                        <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding QuestionVariableType}"/>
                                                        <TextBlock Width="Auto" Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                                    </Grid>

                                                    <ControlTemplate.Triggers >
                                                        <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                            <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                            <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                        </Trigger>
                                                        <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                            <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                            <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>

                                                </ControlTemplate>

                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                        </Grid>
                        <TextBlock  Style="{StaticResource TxtblockformatWithoutBg}" Text="{x:Static res:LocalResource.LABEL_QUESTION}" Grid.Column="1" Grid.Row="1" Margin="10,10,0,0"  HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Grid Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="4">
                            <TextBox Padding="6 2 2 2" VerticalAlignment="Top" Foreground="#999999" Margin="10" Style="{StaticResource NormalTextBoxMultiLine_READONLY}" Grid.Column="5" Name="Text_OriginItem_Question" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"   Height="55" Grid.ColumnSpan="2"/>
                        </Grid>
                    </Grid>
                    <!--</Border>-->

                </Grid>
                <Grid Grid.Row="1">
                    <!--<Border Background="White" BorderBrush="LightGray" BorderThickness="1"  Grid.Row="0" Margin="0,0,0,10" Width="500">-->
                    <Grid  Width="500">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"  Width="500">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="22*"/>
                                <ColumnDefinition Width="20*"/>
                                <ColumnDefinition Width="20*"/>
                                <ColumnDefinition Width="20*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Style="{StaticResource CheckBoxCommon}" Name="Check_Vertical" Unchecked="Check_Vertical_Checked" Checked="Check_Vertical_Checked" Grid.Column="1" Content="{x:Static res:LocalResource.CB_WB_ASSIST}"  Visibility="Visible" Margin="0,0,0,0"  Height="15" HorizontalAlignment="Left"/>
                            <RadioButton Style="{StaticResource Radibuttoncommon}" Name="Option_WB_N" Checked="Option_WB_N_Checked" Content="{x:Static res:LocalResource.LABEL_WB_N}" GroupName="Option_WB" Grid.Column="2"  IsEnabled="False"  Margin="0,0,0,0" Width="60" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <RadioButton Style="{StaticResource Radibuttoncommon}" Name="Option_WB_Proportion" Checked="Option_WB_Proportion_Checked" Content="{x:Static res:LocalResource.LABEL_WB_PER}" GroupName="Option_WB" Grid.Column="3"   IsEnabled="False"  Width="50"   Margin="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <Button Style="{StaticResource NormalButton}" Name="Command_WB_Calculate"  Grid.Column="4" Content="{x:Static res:LocalResource.BTN_CALCULATE}" Margin="0,0,0,0" HorizontalAlignment="Right"  IsEnabled="False"  Height="25" Width="62" Click="Command_WB_Calculate_Click"/>

                        </Grid>

                    </Grid>
                    <!--</Border>-->

                </Grid>
                <Grid Grid.Row="2" Margin="0" >
                    <Border BorderBrush="LightGray" BorderThickness="1"    Margin="0,0,0,10" Width="500" Name="WB_DYNAMIC_GROUPBOX">
                        <Grid   Name="WB_DYNAMIC_GRID" Background="#F0F0F0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50*"/>

                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*"/>
                                    <ColumnDefinition Width="20*"/>
                                    <ColumnDefinition Width="20*"/>
                                    <ColumnDefinition Width="20*"/>
                                </Grid.ColumnDefinitions>
                                <DataGrid 
                                    Padding="0" 
                                    ColumnHeaderHeight="40" 
                                    Style="{StaticResource Datagrid_normal_NoPadding}"   
                                    Name="gridweightback" 
                                    PreviewKeyUp="Gridweightback_PreviewKeyUp"
                                    PreviewKeyDown="Gridweightback_PreviewKeyDown" 
                                    HeadersVisibility="Column"  
                                   CanUserSortColumns="False" 
                                    Margin="0,0,0,10" 
                                    CanUserDeleteRows="False"  
                               CanUserResizeRows="False"
                                  CanUserResizeColumns="False"
                                          Grid.ColumnSpan="5"
                                  HorizontalScrollBarVisibility="Auto"
                                   CanUserAddRows="False" ItemsSource="{Binding}" AutoGenerateColumns="False" 
                                   VerticalAlignment="Top">
                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                    </DataGrid.Resources>

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                    <DataTrigger.Setters>
                                                        <Setter Property="Background" Value="#F6F6F6" />
                                                        <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                    </DataTrigger.Setters>
                                                </DataTrigger>

                                                <Trigger Property="IsMouseOver"
                           Value="True">
                                                    <Setter Property="Background"
                               Value="#e5f3fb" />
                                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">

                                                    <Setter Property="Background" Value="#CBE8F6"/>
                                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                </Trigger>
                                            </Style.Triggers>

                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>

                                        <DataGridTextColumn Width="40"  x:Name="sl" HeaderStyle="{StaticResource Datagrid_Header_StyleWB}" Header="{x:Static res:LocalResource.GV_SL}" CanUserReorder="False" CanUserResize="False" CanUserSort="False"  IsReadOnly="True" Binding="{Binding Sl}" >
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#FFF0F0F0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                            <Setter Property="BorderBrush">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="Transparent"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground"
                            Value="{DynamicResource
                                   {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#FFF0F0F0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>

                                            </DataGridTextColumn.CellStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn x:Name="choice" HeaderStyle="{StaticResource Datagrid_Header_StyleWB}" Width="*" IsReadOnly="True" CanUserReorder="False" CanUserResize="False" CanUserSort="False"
                                                            Header="{x:Static res:LocalResource.GV_CHOICE}" Binding="{Binding Choice}">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#FFF0F0F0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                            <Setter Property="BorderBrush">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="Transparent"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground"
                            Value="{DynamicResource
                                   {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#FFF0F0F0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>

                                            </DataGridTextColumn.CellStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn  Width="*" x:Name="gvN" HeaderStyle="{StaticResource Datagrid_Header_StyleWB}" IsReadOnly="True" CanUserReorder="False" CanUserResize="False" CanUserSort="False" Header="{x:Static res:LocalResource.GV_N}" Binding="{Binding N}">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#FFF0F0F0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                            <Setter Property="BorderBrush">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="Transparent"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground"
                            Value="{DynamicResource
                                   {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#FFF0F0F0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>

                                            </DataGridTextColumn.CellStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                    <Setter Property="TextWrapping" Value="Wrap"></Setter>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn HeaderStyle="{StaticResource Datagrid_Header_StyleWB1}" Width="*" x:Name="populationSize" CanUserReorder="False" CanUserResize="False" CanUserSort="False" Header="{x:Static res:LocalResource.GV_BASED_ON_POPULATION_SIZE}" 
                                                     Binding="{Binding Based_On_Population_Size}" >
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox" >
                                                    <EventSetter Event="TextChanged" Handler="AllowOnlyNumbers"/>
                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                    <Setter Property="AcceptsReturn" Value="true" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn  HeaderStyle="{StaticResource Datagrid_Header_StyleWB}" Width="*" IsReadOnly="True" CanUserReorder="False" CanUserResize="False" CanUserSort="False" x:Name="gvPer" Header="{x:Static res:LocalResource.GV_PER}" Binding="{Binding per}">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#FFF0F0F0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                            <Setter Property="BorderBrush">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="Transparent"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground"
                            Value="{DynamicResource
                                   {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="#FFF0F0F0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>

                                            </DataGridTextColumn.CellStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                    <Setter Property="TextWrapping" Value="Wrap"></Setter>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn HeaderStyle="{StaticResource Datagrid_Header_StyleWB1}" Width="*" x:Name="populationPortion" CanUserReorder="False" CanUserResize="False" CanUserSort="False" Header="{x:Static res:LocalResource.GV_POPULATION_PROPORTION}"   Binding="{Binding Population_Proportion}">
                                            <DataGridTextColumn.EditingElementStyle >
                                                <Style TargetType="TextBox" >
                                                    <EventSetter Event="TextChanged" Handler="TextBox_TextChanged" />
                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                    <Setter Property="AcceptsReturn" Value="true" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn HeaderStyle="{StaticResource Datagrid_Header_StyleWB}" x:Name="weight" CanUserReorder="False" CanUserResize="False" CanUserSort="False" Header="{x:Static res:LocalResource.GV_WEIGHT}"  Binding="{Binding Weight}">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox" >
                                                    <EventSetter Event="TextChanged" Handler="TextBox_TextChanged" />
                                                    <Setter Property="Width" Value="auto"/>
                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Setter Property="AcceptsReturn" Value="true" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>

                                    </DataGrid.Columns>

                                </DataGrid>


                            </Grid>

                        </Grid>
                    </Border>



                </Grid>

            </Grid>
        </Border>

        <Grid Grid.Row="1" Background="#FFF0F0F0" Margin="0">



            <Grid Grid.Row="0"  Width="500" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="20*"/>
                </Grid.ColumnDefinitions>

                <Button Style="{StaticResource NormalButton}" Name="Export" Grid.Column="2" Margin="0,10,70,0" Content="{x:Static res:LocalResource.BTN_SAVE}" HorizontalAlignment="Right" VerticalAlignment="Top"  Height="25" Width="60" Click="Export_Click"/>
                <Button Style="{StaticResource NormalButton}" Name="CloseBtn" Click="BTN_CLOSE_Click"  Grid.Column="2" Content="{x:Static res:LocalResource.LABEL_CLOSE}" Margin="0,10,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Height="25" Width="60"/>

            </Grid>

        </Grid>
    </Grid>
</Window>
