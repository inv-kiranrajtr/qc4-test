<Window x:Class="Qc4Launcher.Forms.GenerateKey"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms"
         xmlns:res="clr-namespace:Qc4Launcher"
        mc:Ignorable="d"
        Title="Authentication Screen" ResizeMode="NoResize" Height="450" Width="800" WindowStyle="None" 
			WindowStartupLocation="CenterScreen" BorderBrush="#ADADAD" BorderThickness="1" >
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="Header" TargetType="{x:Type Grid}">
                <Setter Property="Background" Value="#0051A3"/>
            </Style>
            <Style x:Key="HeaderText" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Text" Value="QuickCross"/>
                <Setter Property="Padding" Value="24,10"/>
                <Setter Property="FontSize" Value="30"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style x:Key="Versiontext" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Text" Value="v0.1 β"/>
                <Setter Property="Padding" Value="180,30"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style TargetType="Button" x:Key="Button">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="0" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#aeaeae"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>


            <Style TargetType="Button" x:Key="ButtonBlue">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="0" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#3467b0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ButtonCircle">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="Button" x:Key="ButtonEnd">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Height" Value="25"/>
                <Setter Property="Width" Value="80"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#f15a24"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="13*"/>
            <RowDefinition Height="27*"/>
            <RowDefinition Height="23*"/>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"  MouseDown="DragableGridMouseDown" Style="{StaticResource Header}">
            <Image Source="/QuickCross4;component/img/textlogo.png" Height="25" HorizontalAlignment="left" Margin="50,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Style="{StaticResource Versiontext}" Name="txt_version" Margin="25,5,0,0" VerticalAlignment="Center"/>
            <Image Source="../img/logo.png" Height="25" HorizontalAlignment="Right" Margin="24,0"/>
        </Grid>
        <Grid Grid.Row="1" Margin="24,0">
            <GroupBox>
                <GroupBox.Header>
                    <Label Content="{x:Static res:LocalResource.GK_TITLE_SYSTEM_INFORMATION}"></Label>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="65*"/>
                        <RowDefinition Height="35*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="24,0">
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="20*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="{x:Static res:LocalResource.GK_LABEL_IDENTIFICATION_KEY}" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtEncryptedCode" Grid.Column="1" HorizontalAlignment="Left" Height="50"  TextWrapping="Wrap" Text="" 
                         VerticalAlignment="Center" Width="350"/>
                        <Button  Style="{StaticResource Button}" Grid.Column="2" Height="30" Width="90" HorizontalAlignment="Center" Click="BtnGenerate_Click" Content="{x:Static res:LocalResource.GK_BTN_GENERATE}"></Button>
                    </Grid>
                    <Grid Grid.Row="1" Margin="24,0">
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="80*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{x:Static res:LocalResource.GK_DESCRIPTION}" 
                               Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
        <Grid Grid.Row="2" Margin="24,0">
            <GroupBox>
                <GroupBox.Header>
                    <Label Content="{x:Static res:LocalResource.GK_TITLE_AUTH_INFORMATION}"></Label>
                </GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="23*"/>
                        <ColumnDefinition Width="347*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="24,0" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="20*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="{x:Static res:LocalResource.GK_LABEL_AUTH_KEY}" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtKey" Grid.Column="1" HorizontalAlignment="Left" Height="50"  TextWrapping="Wrap" Text="" 
                         VerticalAlignment="Center" Width="350"/>
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="100*"/>
                                <RowDefinition Height="100*"/>
                            </Grid.RowDefinitions>
                            <Button  Style="{StaticResource Button}" Grid.Row="0"  Height="30" Width="90" HorizontalAlignment="Center" Click="BtnGenerateKey_Click" VerticalAlignment="Center" Content="{x:Static res:LocalResource.GK_BTN_AUTHENTICATION}"></Button>
                            <Button  Style="{StaticResource Button}" Grid.Row="1"  Height="30" Width="90" Foreground="Red" HorizontalAlignment="Center" Click="BtnDeleteKey_Click" VerticalAlignment="Center" Content="{x:Static res:LocalResource.BTN_DELETE}"></Button>
                        </Grid>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
        <Grid Grid.Row="3" Margin="24,0">
            <GroupBox>
                <GroupBox.Header>
                    <Label Content="{x:Static res:LocalResource.GK_TITLE_AUTHORITY}"></Label>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="24,0">
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition Width="10*"/>
                            <ColumnDefinition Width="60*"/>
                            <ColumnDefinition Width="20*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="rdPro"  Grid.Column="0" Content="Pro" GroupName="Group1" VerticalAlignment="Center"/>
                        <RadioButton x:Name="rdSTD"  Grid.Column="1" Content="Std" GroupName="Group1" VerticalAlignment="Center"/>
                        <Button x:Name="btnVerChange" Style="{StaticResource Button}" Grid.Column="2"  Height="30" Width="90"  HorizontalAlignment="Center" Click="BtnChangeVersion_Click" VerticalAlignment="Center" Content="{x:Static res:LocalResource.GK_BTN_SWITCHING}"></Button>
                    </Grid>
                    <Grid Grid.Row="1" Margin="24,0">
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="50*"/>
                            <ColumnDefinition Width="20*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
        <Grid Grid.Row="4" Margin="24,0">
            <Button  Style="{StaticResource Button}" Height="30" Width="90"  HorizontalAlignment="Center" Margin="540,0,0,0" Click="BtnClose_Click" VerticalAlignment="Center" Content="{x:Static res:LocalResource.BTN_CLOSE}"></Button>
        </Grid>
    </Grid>
</Window>
