<Window x:Class="Qc4Launcher.Forms.DP_Main.Group"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.DP_Main"
        xmlns:res="clr-namespace:Qc4Launcher"
        xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        mc:Ignorable="d" Name="Group_DP_UI"
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen" 
        Title="{x:Static res:LocalResource.DATAPROCESS_FORM_NAME}" Loaded="Window_Loaded" Closed="Window_Closed" Height="680" Width="805" Background="#FFF0F0F0"
            PreviewMouseRightButtonDown="DisableRightMenu" PreviewMouseRightButtonUp="DisableRightMenu" BorderBrush="#ADADAD" BorderThickness="1">
    <Window.Resources>
        <DataTemplate x:Key="QuestionVariable">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="{Binding Question}"></TextBlock>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="#FFFFFFFF" Margin="6">
        <Grid.RowDefinitions>
            <!-- Divide whole window into three rows-->
            <RowDefinition Height="6*"/>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <!--<Border BorderBrush="#FFADADAD" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2"/> -->
        <!--<Border Grid.Row="0"  Margin="10,5,10,5" BorderThickness="1" CornerRadius="4" BorderBrush="LightGray" Grid.ColumnSpan="2"> -->
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1,1,1,0" >
            <Grid Grid.Row="0" Margin="10,5,10,5">

                <!-- 1st row with processing method and command-->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25*"/>
                    <ColumnDefinition Width="100*"/>
                    <ColumnDefinition Width="100*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,10,0" Text="{x:Static res:LocalResource.LBL_GROUP_PROCESSING_METHOD}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" Background="#FFFFFFFF" />
                    <TextBlock Grid.Row="1" Margin="0,0,10,0" Text="{x:Static res:LocalResource.LBL_GROUP_COMMAND}" Style="{StaticResource TextBlockNormalWithCenterAligned}"  HorizontalAlignment="Left"  />

                </Grid>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!--<Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>-->

                    <TextBox Name="Textbox_ProcessMethod" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Left" Text="{x:Static res:LocalResource.LBL_COMMAND_MAX_METHOD}" Style="{StaticResource NormalTextBox}"
                             Margin="5" Width="320" Height="30" TextWrapping="Wrap" Background="#FFFFFFFF" Padding="0" IsReadOnly="True" IsTabStop="False"/>
                    <ComboBox ItemsSource="{Binding}" Grid.Row="1" Margin="5"                                
                              Name="Combo_Commands" Style="{StaticResource NonEditableComboformat}"  Width="320" Height="25"  IsTabStop="False"                           
                              HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" IsEnabled="True"
                              IsSynchronizedWithCurrentItem="True" SelectionChanged="Combo_Commands_SelectionChanged" />

                </Grid>
                <Grid Grid.Column="2">
                    <TextBlock Name="Text_Command_Desc"  Text="{x:Static res:LocalResource.LBL_COMMAND_MAX_DESC}" Style="{StaticResource TextBlockNormal}" Background="#FFFFFFFF" Margin="0,5,0,0" Width="320" TextWrapping="Wrap" />
                </Grid>

            </Grid>
        </Border>



        <!--2nd row with source variable and new variable details-->
        <Border Grid.Row="1" BorderBrush="#FFE1E1E1" BorderThickness="1,0,1,1"  >
            <Grid Grid.Row="1"  Grid.ColumnSpan="2" Margin="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*"/>
                    <ColumnDefinition Width="50*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"  Margin="2,10,0,10" Width="380" BorderThickness="1" BorderBrush="#FFE1E1E1">
                    <!-- Grid for source variable-->
                    
                    <Grid Grid.Column="0" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50*"/>
                            <RowDefinition Height="70*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="188*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6*"/>
                                <ColumnDefinition Width="80*"/>
                                <ColumnDefinition Width="260*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="1" Margin="0,5,0,0" Height="180" Width="100" VerticalAlignment="Top" Grid.RowSpan="2" >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Margin="0,10,0,0" Text="{x:Static res:LocalResource.LABEL_SOURCE_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Height="27"  />
                                <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="{x:Static res:LocalResource.LBL_GROUP_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25"  />
                                <TextBlock Grid.Row="2" Margin="0,-12,0,10" Text="{x:Static res:LocalResource.LBL_GROUP_QUESTION}" Style="{StaticResource TextBlockNormal}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3"  Margin="0,10,0,0" Text="{x:Static res:LocalResource.LBL_GROUP_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25"  />
                            </Grid>
                            <Grid Grid.Column="2" Margin="0,5,5,0" Height="180" VerticalAlignment="Top" Grid.RowSpan="2" >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <TextBox Name="Text_OriginItem_Item"  Grid.Row="0"  IsTabStop="False" HorizontalAlignment="Left" VerticalAlignment="Center" Width="215" Height="25"  Style="{StaticResource NormalTextBox_READONLY}" />

                                <Grid Grid.Row="1" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30*"/>
                                        <ColumnDefinition Width="50*"/>
                                        <ColumnDefinition Width="50*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="Text_OriginItem_AnswerType"  Grid.Column="0"  IsTabStop="False" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Width="50"  Style="{StaticResource NormalTextBox_READONLY}" />
                                    <TextBlock Name="Lbl_No_of_Choices" Grid.Column="1" Text="{x:Static res:LocalResource.LBL_GROUP_N0_OF_CHOICES}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                                    <TextBox Name="Text_OriginItem_SelectCount"  Style="{StaticResource NormalTextBox_READONLY}"  IsTabStop="False" Grid.Column="2" HorizontalAlignment="Left" Height="25" Width="42" />
                                </Grid>

                                <TextBox Name="Text_OriginItem_Question"  Style="{StaticResource NormalTextBoxMultiLine_READONLY}" Grid.Row="2"  IsTabStop="False" HorizontalAlignment="Left" HorizontalContentAlignment="Left"  Margin="0,10,0,10" Width="215" TextWrapping="Wrap"
                                         HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                                <ComboBox ItemsSource="{Binding}" Grid.Row="3" Style="{StaticResource NonEditableComboformat}"                
                                        Name="Combo_OriginItem_ListFilter" Margin="0,5,0,5"  TabIndex="1"   PreviewKeyDown="Combo_OriginItem_ListFilter_PreviewKeyDown"                  
                                        HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" IsEnabled="True"           
                                        IsSynchronizedWithCurrentItem="True" SelectionChanged="Combo_OriginItem_ListFilter_SelectionChanged" Width="50" Height="25" />
                            </Grid>

                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40*"/>
                                <ColumnDefinition Width="10*"/>
                                <ColumnDefinition Width="40*"/>
                            </Grid.ColumnDefinitions>


                            <DataGrid  Name="Grid_OriginItem_ChoiceList1" Grid.Column="0" Margin="9" Width="148" Height="248" Style="{StaticResource Datagrid_GT_Font_Style}" TabIndex="2" 
                                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" CurrentCellChanged="Grid_CurrentCellChanged" RowHeight="17.5"
                                           AutoGenerateColumns="False" CanUserReorderColumns="False" FontFamily="Arial" SelectionChanged="Grid_OriginItem_ChoiceList1_SelectionChanged"
                                           CanUserDeleteRows="False"  CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Disabled" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" SelectionUnit="FullRow" SelectionMode="Extended"  PreviewKeyDown="Grid_OriginItem_ChoiceList1_PreviewKeyDown" GotMouseCapture="Grid_OriginItem_ChoiceList1_GotMouseCapture" >
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" >
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Background" Value="#F6F6F6" />
                                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5f3fb" />
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn  Width="*" Binding="{Binding Variable}" CanUserResize="False" CanUserSort="False"  IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Grid.Column="1" Height="250">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="25"/>
                                    <RowDefinition Height="25"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="2" Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Style="{StaticResource SmallButton}" TabIndex="3" x:Name="Command_OriginItem_Add"  Click="Command_OriginItem_Add_Click" PreviewKeyDown="Command_OriginItem_Add_PreviewKeyDown" />
                                <Button Grid.Row="5" Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" Style="{StaticResource SmallButton}" TabIndex="5" x:Name="Command_OriginItem_Remove" Click="Command_OriginItem_Remove_Click" />
                            </Grid>

                            <DataGrid  Name="Grid_OriginItem_ChoiceList2" Grid.Column="2" Margin="9" Width="148" Height="248" Style="{StaticResource Datagrid_GT_Font_Style}" TabIndex="4"
                                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" CurrentCellChanged="Grid_CurrentCellChanged" RowHeight="17.5"
                                           AutoGenerateColumns="False" CanUserReorderColumns="False" FontFamily="Arial" SelectionChanged="Grid_OriginItem_ChoiceList2_SelectionChanged"
                                           CanUserDeleteRows="False"  CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Disabled" DataContextChanged="Grid_OriginItem_ChoiceList2_DataContextChanged"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" SelectionUnit="FullRow" SelectionMode="Extended"  PreviewKeyDown="Grid_OriginItem_ChoiceList2_PreviewKeyDown"  GotMouseCapture="Command_OriginItem_Remove_GotMouseCapture" >
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" >
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Background" Value="#F6F6F6" />
                                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5f3fb" />
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn  Width="*" Binding="{Binding Variable}" CanUserResize="False" CanUserSort="False"  IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>


                <Border Grid.Column="1"  Margin="0,10,2,10" Width="380" BorderThickness="1" BorderBrush="#FFE1E1E1">
                    <!--Grid for new variable-->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50*"/>
                            <RowDefinition Height="70*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30*"/>
                                <ColumnDefinition Width="70*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="5" Height="180" Width="100" VerticalAlignment="Top" >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{x:Static res:LocalResource.LBL_GROUP_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" />
                                <TextBlock Grid.Row="1" Text="{x:Static res:LocalResource.LBL_GROUP_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"  />
                                <TextBlock Grid.Row="2" Margin="0,-12,0,10" Text="{x:Static res:LocalResource.LBL_GROUP_QUESTION}" Style="{StaticResource TextBlockNormal}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Column="1" Margin="5" Height="180" VerticalAlignment="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="Combo_NewItem_Item" SelectionChanged="Combo_NewItem_Item_SelectionChanged" Style="{StaticResource NormalTextBox}" Grid.Column="0" MaxLength="25" TabIndex="6" HorizontalAlignment="Left" VerticalAlignment="Center" Width="200" Height="25" />
                                    <Button x:Name="Button_Search" Style="{StaticResource SmallButton}" BorderThickness="0" Click="Search_Click" TabIndex="7" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" >
                                        <uc:MagnifyingGlassButton x:Name="MagnifyingGlassButton" Title="GROUP" ></uc:MagnifyingGlassButton>
                                    </Button>
                                </Grid>
                                <Grid Grid.Row="1" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30*"/>
                                        <ColumnDefinition Width="50*"/>
                                        <ColumnDefinition Width="50*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="Text_NewItem_AnswerType"  Grid.Column="0" HorizontalAlignment="Left" Height="25" Width="50" Style="{StaticResource NormalTextBox_READONLY}"  IsTabStop="False" />
                                    <TextBlock Grid.Column="1" Margin="5,0,5,0" Text="{x:Static res:LocalResource.LBL_GROUP_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Width="80" Grid.ColumnSpan="2" Visibility="Hidden" />
                                    <ComboBox ItemsSource="{Binding}" Grid.Column="2" Style="{StaticResource NormalComboformat}"                          
                                  Name="Combo_NewItem_SelectCount"  Height="25" Width="42"                   
                                HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Hidden"          
                                IsSynchronizedWithCurrentItem="True"  />
                                </Grid>
                                <TextBox Name="Text_NewItem_Question" Style="{StaticResource NormalTextBoxMultiLine}" Grid.Row="2" TabIndex="8" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Margin="0,10,0,10" Width="200" 
                                         TextWrapping="Wrap" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                            </Grid>

                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 3rd row with Save and close button-->
        <Grid Grid.Row="2" Background="#FFF0F0F0" Margin="0,1,0,0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="30*"/>
            </Grid.ColumnDefinitions>
            <Button Name="Command_Entry" Grid.Column="2" Margin="12,0,0,0" TabIndex="9" Content="{x:Static res:LocalResource.BTN_SAVE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center"  Height="25" Width="100" IsEnabled="False" Click="Command_Entry_Click"/>
            <Button Name="Command_Cancel" Grid.Column="3" Margin="12,0,0,0" TabIndex="10" Content="{x:Static res:LocalResource.LABEL_CLOSE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" Width="100" Click="Command_Close_Click" PreviewKeyDown="Command_Cancel_PreviewKeyDown"/>
        </Grid>
    </Grid>
</Window>
