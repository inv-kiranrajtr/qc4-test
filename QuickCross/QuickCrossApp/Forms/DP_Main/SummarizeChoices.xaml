<Window x:Class="Qc4Launcher.Forms.DP_Main.SummarizeChoices"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.DP_Main"
        xmlns:res="clr-namespace:Qc4Launcher" ShowInTaskbar="False"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        mc:Ignorable="d" PreviewMouseRightButtonDown="Window_PreviewMouseRightButtonDown" PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonDown"
        Title="{x:Static res:LocalResource.TITLE_SUMMARIZE_CHOICES}" Height="214" Width="274" Background="#FFF0F0F0" BorderBrush="#ADADAD" BorderThickness="1" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Closed="Window_Closed" >
    <Grid x:Name="data_grid_summarizeChoices" Margin="6,6,6,8" DataContext="{Binding SummarizedChoice}" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height=".5*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height=".7*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
        <CheckBox Grid.Row="0" x:Name="checkbox_include_source_choices" Margin="6,6,0,0" Content="{x:Static res:LocalResource.LBL_INCLUDE_SOURCE_CHOICES}" Style="{StaticResource CheckBoxNormal}" IsChecked="{Binding Path=IsIncludeSourceChoices}"></CheckBox>
        <Grid x:Name="data_grid_summarizeChoicesDetails" Grid.Row="1" DataContext="{Binding RelativeSource={RelativeSource Self}}" Margin="6,0,10,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.35*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1.2*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="49*"/>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="83*"/>
                <ColumnDefinition Width="83*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="3" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LBL_CHOICES_TO_BE_SUMMARIZED}" Style="{StaticResource TextBlockNormalWithCenterAlignedMultiline}" HorizontalAlignment="Center" Margin="0,5,0,4"></TextBlock>
            <TextBlock Grid.Row="0" Grid.Column="4" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LBL_POSITION}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Center" Margin="0,12,0,11"/>

            <CheckBox Grid.Row="1" Grid.Column="0"  Content="{x:Static res:LocalResource.LBL_TOP}" Margin="0,2,4,4" Style="{StaticResource CheckBoxNormal}" IsChecked="{Binding Path=IsTop}" Grid.ColumnSpan="3"></CheckBox>
            <ComboBox x:Name="Combo_Top" Grid.Row="1" Grid.Column="3" IsEditable="True" Margin="2,2,4,4" Style="{StaticResource NormalComboBox_Editable}"
                  DisplayMemberPath="Id" SelectedIndex="1"></ComboBox>
            <ComboBox x:Name="Combo_top_position" Grid.Row="1" ItemsSource="{Binding positions}" Grid.Column="4" IsEditable="True" SelectedIndex="1" Margin="2,2,0,4" Style="{StaticResource NormalComboBox_Editable}">
            </ComboBox>

            <CheckBox Grid.Row="2" Grid.Column="0"  Content="{x:Static res:LocalResource.LBL_BOTTOM}" Style="{StaticResource CheckBoxNormal}"  Margin="0,7,4,5" Grid.ColumnSpan="3" IsChecked="{Binding Path=IsBottom}"></CheckBox>
            <ComboBox x:Name="Combo_Bottom" Grid.Row="2" Grid.Column="3" IsEditable="True" Margin="2,8,4,2" Style="{StaticResource NormalComboBox_Editable}" DisplayMemberPath="Id" SelectedIndex="1"></ComboBox>
            <ComboBox x:Name="Combo_bottom_position" Grid.Row="2" Grid.Column="4" ItemsSource="{Binding positions}" IsEditable="True" SelectedIndex="1" Margin="2,8,0,2" Style="{StaticResource NormalComboBox_Editable}">
            </ComboBox>
        </Grid>
        <Border Grid.Row="2"  Background="#FFF0F0F0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"  HorizontalAlignment="Right">
            <Button Name="btn_Ok"  Style="{StaticResource NormalButton}"  Content="{x:Static res:LocalResource.BTN_OK}" Click="Btn_Ok_Click" HorizontalAlignment="Right" Width="100" Height="25" />
            <Button Name="btn_closeBtn"  Style="{StaticResource NormalButton}" Content="{x:Static res:LocalResource.BTN_CANCEL}" Click="Btn_closeBtn_Click" HorizontalAlignment="Right" Width="100" Height="25"  Margin="6,0,0,0"/>
        </StackPanel>
        </Border>
    </Grid>
</Window>
