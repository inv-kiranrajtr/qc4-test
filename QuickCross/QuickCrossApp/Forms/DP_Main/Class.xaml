<Window x:Class="Qc4Launcher.Forms.DP_Main.Class"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        xmlns:res="clr-namespace:Qc4Launcher"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        
        mc:Ignorable="d" PreviewMouseRightButtonDown="Window_PreviewMouseRightButtonDown" PreviewMouseRightButtonUp="Window_PreviewMouseRightButtonDown"
        Title="{x:Static res:LocalResource.TITLE_CREATE_NEW_VARIABLE}" Height="700" Width="810" ResizeMode="NoResize" 
			WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Background="#FFF0F0F0" BorderBrush="#ADADAD" BorderThickness="1" Closed="Window_Closed">
    <Grid Background="#FFFFFFFF" Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="27*"/>
            <ColumnDefinition Width="241*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="6.5*"/>
            <RowDefinition Height=".7*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
        <Grid Grid.Row="0" Margin="10" Grid.ColumnSpan="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="5.2*"/>
                <ColumnDefinition Width=".9*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="6.5*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_PROCESSING_METHOD}" Style="{StaticResource TextBlockNormalWithCenterAligned}" TextWrapping="Wrap"></TextBlock>
                <TextBox Name="lb_class" Grid.Row="0" Grid.Column="1" Height="25" Margin="2,0,0,2" IsReadOnly="True" Style="{StaticResource NormalTextBox}" IsTabStop="False"></TextBox>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_COMMAND}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                <TextBox Name="lb_command" Grid.Row="1" Grid.Column="1" Height="25" Margin="2,2,0,0" Style="{StaticResource NormalTextBox_READONLY_Command}" IsTabStop="False"></TextBox>
            </Grid>
            <TextBlock Grid.Column="1" TextWrapping="Wrap" Margin="16,5,0,0" Style="{StaticResource TextBlockNormal}" Text="{x:Static res:LocalResource.LABEL_ClASS}"></TextBlock>
            <Button x:Name="Button_Help" Grid.Column="2" HorizontalAlignment="Right" Width="50" Style="{StaticResource Button_Hlep}" VerticalAlignment="Top" Height="25" Margin="0,5,0,0" Content="{x:Static res:LocalResource.BTN_HELP}" ToolTip="{x:Static res:LocalResource.TOOLTIP_HELP}" Click="Button_Help_Click_1">
            </Button>

        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Grid.Column="1" Margin="10,8,10,8"/>

            <Grid Grid.Column="0" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.8*" />
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Grid.RowSpan="2" Margin="10,8,10,8"/>
                <Grid Grid.Row="0" Margin="12,8,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.4*"/>
                        <RowDefinition Height="1.8*"/>
                        <RowDefinition Height="2.5*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="6,10,6,2" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_SOURCE_VARIABLE}"></TextBlock>

                    <ComboBox Name="Combo_sourceVariableNType" ItemsSource="{Binding Path=SourceVariableListView}"  Grid.Column="1" Grid.Row="0" Margin="6,12,6,2" Height="25"
                                VerticalAlignment="Top" IsTextSearchEnabled="True" TextSearch.TextPath="Variable" 
                                HorizontalAlignment="Left" IsEnabled="True" GotKeyboardFocus="Combo_sourceVariableNType_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="True" DropDownClosed="Combo_sourceVariableNType_DropDownClosed" PreviewKeyUp="Combo_sourceVariableNType_PreviewKeyUp" PreviewKeyDown="Combo_sourceVariableNType_PreviewKeyDown"
                                Width="150" Style="{StaticResource NormalComboBox_Editable}" SelectionChanged="Combo_sourceVariableNType_SelectionChanged" >
                        <ComboBox.Resources>
                            <Style TargetType="Popup">
                                <Setter Property="MaxWidth" Value="508"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="2" Text="{Binding Variable}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle >
                            <Style TargetType="{x:Type ComboBoxItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <Grid x:Name="gd" TextElement.Foreground="Black">
                                                <Grid.ColumnDefinitions >
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Width="150" Margin="5" Grid.Column="0" Text="{Binding Variable}"/>
                                                <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding AnswerType}"/>
                                                <TextBlock Width="auto" Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                            </Grid>

                                            <ControlTemplate.Triggers >
                                                <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                    <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                    <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                </Trigger>
                                                <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                    <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                    <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>



                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6,10,6,6" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}"></TextBlock>
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1" Margin="6">
                        <TextBox x:Name="txt_answerType" Width="85" Height="25" Margin="0,0,4,0" IsEnabled="False" Style="{StaticResource NormalTextBox_READONLY}" IsTabStop="False"></TextBox>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="6,6,6,6" Style="{StaticResource TextBlockNormal}" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}"></TextBlock>
                    <TextBox x:Name="txt_source_Question" Grid.Column="1" TextWrapping="Wrap" Grid.Row="2" Margin="6" Style="{StaticResource NormalTextBoxMultiLine_READONLY}" Width="229" HorizontalAlignment="Left" IsTabStop="False" IsEnabled="False" VerticalScrollBarVisibility="Auto"></TextBox>
                    
                </Grid>

                <Grid Grid.Row="1" Margin="12,8,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="10*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{x:Static res:LocalResource.LBL_REFERENCE_VALUE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Margin="6,0,6,0"></TextBlock>
                    <Border Grid.Row="1" BorderBrush="#FFE1E1E1" BorderThickness="1" Margin="6,4,8,24">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=".8*"/>
                                <ColumnDefinition Width="3.6*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Text="{x:Static res:LocalResource.LABEL_MAX_INTEGRATE}" VerticalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Grid.Column="0" Height="20"></TextBlock>
                            <TextBox Name="txt_max" Grid.Row="0" Grid.Column="1" Height="20" Margin="0,0,35,0" IsTabStop="False" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>
                            <TextBlock Grid.Row="1" Text="{x:Static res:LocalResource.LABEL_MIN_INTEGRATE}" VerticalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Grid.Column="0" Height="20"></TextBlock>
                            <TextBox Name="txt_min" Grid.Row="1"  Grid.Column="1" Height="20" Margin="0,0,35,0" IsTabStop="False" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>
                            
                            <TextBlock Grid.Row="2" Text="{x:Static res:LocalResource.LABEL_MEAN_INTEGRATE}" VerticalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Grid.Column="0" Height="20"></TextBlock>
                            <TextBox Name="txt_mean" Grid.Row="2" Grid.Column="1" IsTabStop="False" Height="20" Margin="0,0,35,0" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>
                        </Grid>
                    </Border>
                </Grid>
                <Grid Grid.Row="2" Margin="12,8,10,0">
                    <CheckBox Name="chk_noAnswer" Content ="{x:Static res:LocalResource.LABEL_REGARD_NO_ANSWER}" Style="{StaticResource CheckBoxNormal}" Margin="6,0,0,20"></CheckBox>
                    
                </Grid>
            </Grid>

            <Grid Grid.Column="1" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.7*" />
                    <RowDefinition Height="3.5*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="8,8,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.4*"/>
                        <RowDefinition Height="1.8*"/>
                        <RowDefinition Height="2.5*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="6,2,6,2" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                        <TextBox Name="txt_new_variable" Margin="6,2,6,2" MaxLength="25" TextChanged="Txt_new_variable_TextChanged" Background="#FFF0F0F0" Height="25" Width="150" IsEnabled="False" Style="{StaticResource NormalTextBox_Disabled}"></TextBox>

                        <Button Name="NewItemSearchbutton" Click="NewItemSearchbutton_Click" IsTabStop="False" BorderThickness="0" Padding="0" Style="{StaticResource SmallButton}">
                            <uc:MagnifyingGlassButton x:Name="MagnifyingGlassButton" Title= "CLASS" Loaded="MagnifyingGlassButton_Loaded" ></uc:MagnifyingGlassButton>
                        </Button>
                    </StackPanel>


                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6,10,6,6" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                    <Grid Grid.Column="1" Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3.6*"/>
                            <ColumnDefinition Width="2.4*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="answerType" Grid.Column="0" Height="25" Width="85" Margin="6,2,6,2" Text="{x:Static res:LocalResource.TEXT_SA}" IsTabStop="False" IsEnabled="False" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>
                        <TextBlock TextWrapping="Wrap" Grid.Column="1" Margin="6,2,0,2" VerticalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_NO_OF_CHOICES}"></TextBlock>
                        <ComboBox x:Name="choicesCount" Grid.Column="2" HorizontalAlignment="Left" IsEditable="True" Style="{StaticResource NormalComboBox_Editable}" PreviewKeyUp="ChoicesCount_PreviewKeyUp" SelectionChanged="ChoicesCount_SelectionChanged" Width="88" Height="25" SelectedIndex="0" ></ComboBox>
                    </Grid>
                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="6,6,6,6" Padding="0,6,0,0" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}" Style="{StaticResource TextBlockNormal}"></TextBlock>
                    <TextBox Name="Text_NewItem_Question" Background="#FFF0F0F0" Style="{StaticResource NormalTextBoxMultiLine}" VerticalScrollBarVisibility="Auto" Grid.Column="1" Grid.Row="2"  Margin="6" Width="244" HorizontalAlignment="Left" IsEnabled="False" AcceptsReturn="True" />

                </Grid>
                <Grid Grid.Row="1" Margin="8,0,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="14.2*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3.1*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <RadioButton Name="checkbox_greater_or_equal" Content="{x:Static res:LocalResource.GTT_FS_CB_ITEM_VALUE_GREATER_THAN_OR_EQUAL_TO}"  Style="{StaticResource RadibuttonNormal}" IsChecked="True"></RadioButton>
                            <RadioButton Name="checkbox_greater"  Content="{x:Static res:LocalResource.GTT_FS_CB_ITEM_VALUE_GREATER_THAN}"  Style="{StaticResource RadibuttonNormal}" HorizontalAlignment="Stretch" Margin="0,2,50,2"></RadioButton>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <RadioButton Name="checkbox_less_or_equal1"  Content="{x:Static res:LocalResource.GTT_FS_CB_ITEM_VALUE_LESS_THAN_OR_EQUAL_TO}"  Style="{StaticResource RadibuttonNormal}" IsChecked="True"></RadioButton>
                            <RadioButton Name="checkbox_less" Content="{x:Static res:LocalResource.GTT_FS_CB_ITEM_VALUE_LESS_THAN}" Style="{StaticResource RadibuttonNormal}"></RadioButton>
                        </StackPanel>
                    </Grid>
                    
                    <Grid Grid.Row="1" Margin="6,0,6,0">
                        <DataGrid  x:Name="data_grid" Style="{StaticResource Datagrid_normal_NoPadding}" BorderBrush="#FFE1E1E1" RowHeight="25" HeadersVisibility="All"  RowHeaderWidth="0" IsEnabled="True"  Grid.Column="1" AutoGenerateColumns="False"
                                   CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserSortColumns="False" CopyingRowClipboardContent="Data_grid_CopyingRowClipboardContent" IsMouseCaptureWithinChanged="Data_grid_IsMouseCaptureWithinChanged"
                                   CanUserAddRows="False" HorizontalGridLinesBrush="#FFADADAD" VerticalGridLinesBrush="#FFADADAD" SelectionMode="Extended" ColumnHeaderStyle="{StaticResource Datagrid_Header_Style}" PreviewKeyDown="HandleCopyPaste" PreviewKeyUp="Data_grid_PreviewKeyUp" FocusVisualStyle="{x:Null}">
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                            <DataTrigger.Setters>
                                                <Setter Property="Background" Value="#F6F6F6" />
                                                <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                            </DataTrigger.Setters>
                                        </DataTrigger>

                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#e5f3fb" />
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">

                                            <Setter Property="Background" Value="#CBE8F6"/>
                                            <Setter Property="BorderBrush" Value="#70c0e7"/>
                                        </Trigger>
                                    </Style.Triggers>

                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>

                                <DataGridTextColumn  x:Name="txt_choicesIndex" Width="32" IsReadOnly="True"  Binding="{Binding Id}"  CanUserResize="False">
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                            <Setter Property="Background" Value="#FFF0F0F0"/>
                                            <Style.Triggers>
                                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                    <Setter Property="BorderBrush">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="Transparent"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="Foreground"  Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#FFF0F0F0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>

                                    </DataGridTextColumn.CellStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="#FF333333" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn x:Name="txt_dataGrid_choice" Header="{x:Static res:LocalResource.LABEL_CHOICE}" Binding="{Binding Choice}" Width="150" CanUserResize="False"  >
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0,0,0" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="#FF333333" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChoiceEmpty}" Value="true">
                                                    <Setter Property="BorderBrush" Value="Red" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static res:LocalResource.GRID_LBL_INTEGRATE_LOWER_LIMIT}" Width="83"  Binding="{Binding LowerLimit}" CanUserResize="False">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0,0,0" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowerLimitInvalid}" Value="true">
                                                    <Setter Property="Foreground" Value="Red" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsLowerLimitInvalid}" Value="false">
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowerLimitEmpty}" Value="true">
                                                    <Setter Property="BorderBrush" Value="Red" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn  x:Name="tild" Width="30" IsReadOnly="True" Binding="{Binding Tild}"  CanUserResize="False" >
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                            <Setter Property="Background" Value="#FFF0F0F0"/>
                                            <Style.Triggers>
                                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                    <Setter Property="BorderBrush">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="Transparent"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="Foreground"  Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#FFF0F0F0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>

                                    </DataGridTextColumn.CellStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="#FF333333" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn x:Name="txt_dataGrid_upper_limit" Header="{x:Static res:LocalResource.GRID_LBL_INTEGRATE_UPPER_LIMIT}" Binding="{Binding UpperLimit}" Width="*" CanUserResize="False">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,0,0,0" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUpperLimitInvalid}" Value="true">
                                                    <Setter Property="Foreground" Value="Red" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUpperLimitInvalid}" Value="false">
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUpperLimitEmpty}" Value="true">
                                                    <Setter Property="BorderBrush" Value="Red" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" Background="#FFF0F0F0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10">
                <Button Name="setChoiceLabels" Style="{StaticResource NormalButton}" Content="{x:Static res:LocalResource.BTN_SET_CHOICE_LABELS}" HorizontalAlignment="Right" Margin="0,0,110,0" Click="SetChoiceLabels_Click" ToolTip="{x:Static res:LocalResource.TOOLTIP_CLASS_SET_CHOICE_LABELS}"></Button>
                <Button Name="Save"  Style="{StaticResource NormalButton}"  Content="{x:Static res:LocalResource.BTN_SAVE}" HorizontalAlignment="Right" Width="100" Height="25" Margin="6,0,0,0" Click="Save_Click"/>
                <Button Name="CloseBtn"  Style="{StaticResource NormalButton}" Content="{x:Static res:LocalResource.BTN_CLOSE}" HorizontalAlignment="Right" Width="100" Height="25" Click="CloseBtn_Click" Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
