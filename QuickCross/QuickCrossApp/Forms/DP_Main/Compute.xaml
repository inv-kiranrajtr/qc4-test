<Window x:Class="Qc4Launcher.Forms.DP_Main.Compute"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.DP_Main"
         xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        mc:Ignorable="d"
        xmlns:res="clr-namespace:Qc4Launcher"
        Title="{x:Static res:LocalResource.DATAPROCESS_FORM_NAME}"  Height="615" Width="810" ResizeMode="NoResize" 
		MouseRightButtonDown="DisableRightMenu" MouseRightButtonUp="DisableRightMenu"
        WindowStartupLocation="CenterScreen" BorderBrush="#ADADAD" BorderThickness="1" Background="#FFF0F0F0" Loaded="Window_Loaded" Closed="Window_Closed">
    <Window.Resources>
        <Style x:Key="myHeaderStyle" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
        <Style TargetType="TextBox">
           

        </Style>
       
    </Window.Resources>
    <Grid>
        <Grid Background="#FFFFFFFF" Margin="8">
            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="241*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.2*"/>
                <RowDefinition Height="6.5*"/>
                <RowDefinition Height=".7*"/>
            </Grid.RowDefinitions>
            <Border BorderBrush="#FFE1E1E1" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
            <Grid Grid.Row="0" Margin="10" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="5.2*"/>
                    <ColumnDefinition Width=".9*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="7*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_PROCESSING_METHOD}" Style="{StaticResource TextBlockNormalWithCenterAligned}" TextWrapping="Wrap"></TextBlock>
                    <TextBox IsTabStop="False" Name="lb_recode" Grid.Row="0" Grid.Column="1" Height="25" Margin="2,0,0,2" IsReadOnly="True" Style="{StaticResource NormalTextBox}" TabIndex="0"></TextBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_COMMAND}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                    <TextBox IsTabStop="False" Name="lb_command" Grid.Row="1" Grid.Column="1" Height="25" Margin="2,2,0,0" Style="{StaticResource NormalTextBox_READONLY_Command}" TabIndex="1"></TextBox>
                </Grid>
                <TextBlock Grid.Column="1" TextWrapping="Wrap" Margin="16,0,0,0" Style="{StaticResource TextBlockNormal}" Text="{x:Static res:LocalResource.LABEL_COMPUTE}"></TextBlock>

            </Grid>

            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Margin="10 5 10 5" Grid.Row="0"  BorderBrush="#FFE1E1E1" BorderThickness="1" Height="auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="6.5*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Column="0" Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="3.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Grid.Row="0" Margin="10,6,6,2" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                                <TextBox Name="txt_new_variable" Margin="6,6,6,2" MaxLength="25"  Height="25" SelectionChanged="Txt_new_variable_SelectionChanged" Width="150"  Style="{StaticResource NormalTextBox}"></TextBox>

                                <Button Padding="0" IsTabStop="False" Name="NewItemSearchbutton" Style="{StaticResource SmallButton}"  Click="NewItemSearchbutton_Click"  Width="25" Height="25" Margin="0 4 0 0">
                                    <uc:MagnifyingGlassButton    x:Name="MagnifyingGlassButton" Title= "COMPUTE"  ></uc:MagnifyingGlassButton>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="3.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="10,14,6,10" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"/>

                            <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="6" Grid.ColumnSpan="2">
                                <TextBox IsTabStop="False" Name="Text_New_Item"  Grid.Column="1" Text="N"  Height="25" Width="85" Style="{StaticResource ROTxtBox}" VerticalContentAlignment="Center"  RenderTransformOrigin="0.471,1.25" ></TextBox>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Column="1" Grid.RowSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="6.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Grid.Column="0" Grid.Row="2" Margin="6,6,6,6" Padding="0,6,0,0" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}" Style="{StaticResource TextBlockNormal}"></TextBlock>
                            <TextBox AcceptsReturn="True" Name="Text_NewItem_Question" Style="{StaticResource NormalTextBoxMultiLine}" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Grid.Column="1" Grid.Row="2"  Margin="6 6 10 6"  Height="60" />

                        </Grid>
                    </Grid>
                </Border>
                <Border Margin="10 5 10 10" Grid.Row="1" BorderBrush="#FFE1E1E1" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <StackPanel>
                                <TextBlock  Margin="10,10,6,2"  Text="{x:Static res:LocalResource.COMPUTE_FORMULA}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                                <TextBox  TextChanged="Text_Formula_TextChanged"  Name="Text_Formula" Style="{StaticResource NormalTextBoxMultiLine1}" VerticalScrollBarVisibility="Auto"  Margin="10 5 10 0"  Height="65" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock  Margin="10,8,0,1" VerticalAlignment="Center" Text="{x:Static res:LocalResource.LBL_GROUP_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" Width="80" />

                                <ComboBox ItemsSource="{Binding}"  Style="{StaticResource NonEditableComboformat}"                
                                        Name="Combo_OriginItem_ListFilter" Margin="0,10,0,0"                       
                                        HorizontalAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Center" IsEnabled="True"           
                                        IsSynchronizedWithCurrentItem="True" SelectionChanged="Combo_OriginItem_ListFilter_SelectionChanged"
                                        Width="50" Height="25" />
                                <Button x:Name="ButtonSingleRightArrow"  Style="{StaticResource SmallButton}"  Margin="30 10 0 0" Width="30" Height="30" Click="ButtonSingleRightArrow_Click"  ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_INSERTBTN}">
                                    <Image x:Name="ButtonSingleRightArrowImage"  Source="/img/triangle.png" Width="12"   Stretch="Uniform"/>
                                </Button>
                            </StackPanel>

                        </Grid>
                        <Grid Grid.Row="2">
                            <TextBlock Grid.Row="0" Margin="10,0,0,2" Text="{x:Static res:LocalResource.LBL_GROUP_SOURCE_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center"  />
                        </Grid>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50*"/>
                                <ColumnDefinition Width="25*"/>
                                <ColumnDefinition Width="25*"/>
                            </Grid.ColumnDefinitions>


                            <DataGrid  x:Name="List_OriginItem_ChoiceList1" Grid.Column="0" ItemsSource="{Binding}" BorderBrush="#FFE1E1E1" Margin="10 0 0 10"  RowHeight="21" HeadersVisibility="None"  AutoGenerateColumns="False" TabIndex="2"
                                       MouseDoubleClick="List_OriginItem_ChoiceList1_MouseDoubleClick"
                                        CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" HorizontalGridLinesBrush="White" IsEnabled="True" IsReadOnly="True" Background="White" 
                                        VerticalGridLinesBrush="White"  ScrollViewer.CanContentScroll="True"  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" CanUserResizeColumns="False" CanUserResizeRows="False" Padding="3,0,0,0"
                                       CurrentCellChanged="Grid_CurrentCellChanged" PreviewKeyDown="Grid_OriginItem_ChoiceList1_PreviewKeyDown" 
                                       >      
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" >
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Background" Value="#F6F6F6" />
                                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5f3fb" />
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <!--<Setter Property="Background" Value="#CBE8F6"/>-->
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns >
                                    <DataGridTextColumn Width="*"  Binding="{Binding Variable}" x:Name="No1" CanUserResize="False" CanUserSort="False" ScrollViewer.CanContentScroll="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="Foreground" Value="#FF333333" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*"  Binding="{Binding AnswerType}" x:Name="qST" CanUserResize="False" CanUserSort="False" ScrollViewer.CanContentScroll="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="Foreground" Value="#FF333333" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*"  Binding="{Binding Question}" x:Name="Ans" CanUserResize="False" CanUserSort="False" ScrollViewer.CanContentScroll="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="Foreground" Value="#FF333333" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            
                            <Border  Grid.Column="1" Margin="5 0 0 10" BorderBrush="#FFE1E1E1" BorderThickness="1">
                                <Grid>
                              
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="25"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>


                                    <TextBlock Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_FOUR_ARTHMETIC}" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Button x:Name="Plus_Indicator" Grid.Row="0" Grid.Column="1" FontWeight="Bold" FontSize="18" ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_ADD}" Width="30" Height="30" Content="+" Click="Button_Click_1" Style="{StaticResource SmallButton}"  VerticalAlignment="Center"/>
                                        <TextBlock HorizontalAlignment="Center" Grid.Row="0" Grid.Column="2" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_ADD}" VerticalAlignment="Center" ></TextBlock>

                                        <Button Grid.Row="1" Grid.Column="1" FontWeight="Bold" FontSize="18" ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_SUBSTRACT}" Click="Button_Click_2" Width="30" Height="30" Content="-"  VerticalAlignment="Center" Style="{StaticResource SmallButton}"/>
                                        <TextBlock HorizontalAlignment="Center" Grid.Row="1" Grid.Column="2" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_SUBSTRACT}" VerticalAlignment="Center"></TextBlock>

                                        <Button Grid.Row="2" Grid.Column="1" FontWeight="Bold" VerticalContentAlignment="Center" FontSize="18" ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_MULTIPLY}" Click="Button_Click_3" Width="30" Height="30" Content="*"  VerticalAlignment="Center" Style="{StaticResource SmallButton}"/>
                                        <TextBlock HorizontalAlignment="Center" Grid.Row="2" Grid.Column="2" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_MULTIPLY}" VerticalAlignment="Center"></TextBlock>

                                        <Button Grid.Row="3" Grid.Column="1" FontWeight="ExtraBlack" FontSize="18" ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_DIV}" Click="Button_Click_4" Width="30" Height="30" Content="/"  VerticalAlignment="Center" Style="{StaticResource SmallButton}"/>
                                        <TextBlock HorizontalAlignment="Center" Grid.Row="3" Grid.Column="2" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_DEVIDE}" VerticalAlignment="Center"></TextBlock>


                                    </Grid>



                                </Grid>
                            </Border>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"></RowDefinition>
                                    <RowDefinition Height="auto"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Border Margin="5 0 10 10" Grid.Row="0" BorderBrush="#FFE1E1E1" BorderThickness="1">
                                    <Grid>
                                     
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_PRECEDENCE}" HorizontalAlignment="Center" VerticalAlignment="Center" ></TextBlock>
                                        <Grid Grid.Row="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="24*"/>
                                                <RowDefinition Height="24*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button FontWeight="Bold" FontSize="18" Grid.Column="0" Grid.Row="0" ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_LEFT}" Click="Button_Click_5" Width="30" Height="30" Content="(" Margin="5 3 5 5" VerticalAlignment="Center" Style="{StaticResource SmallButton}"/>
                                            <TextBlock HorizontalAlignment="Center" Grid.Column="1" Grid.Row="0" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_LEFTBRACKET}" VerticalAlignment="Center" ></TextBlock>
                                            <Button FontWeight="Bold" FontSize="18" Grid.Column="0" Grid.Row="1" ToolTip="{x:Static res:LocalResource.COMPUTE_TOOLTIP_RIGHT}" Click="Button_Click_6" Style="{StaticResource SmallButton}" Width="30" Height="30" Content=")" Margin="5 3 5 5" VerticalAlignment="Center"/>
                                            <TextBlock HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.COMPUTE_RIGHT_BRACKET}" VerticalAlignment="Center"></TextBlock>
                                        </Grid>

                                       
                                    </Grid>
                                </Border>
                                <Button ToolTip="{x:Static res:LocalResource.COMPUTE_CLEAR_FORMULA_TOOLTIP}" Click="Button_Click" Grid.Row="1" Content="{x:Static res:LocalResource.COMPUTE_CLEAR_FORMULA}" Width="100" Height="25" Margin="10" Style="{StaticResource NormalButton}"/>
                            </Grid>
                        </Grid>

                    </Grid>

                </Border>

            </Grid>
            <Grid Grid.Row="3" Background="#FFF0F0F0" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="30*"/>
                    <ColumnDefinition Width="30*"/>
                </Grid.ColumnDefinitions>
                <Button Name="Command_Entry" Grid.Column="2" Margin="12,0,0,0" Content="{x:Static res:LocalResource.BTN_SAVE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center"  Height="25" Width="100"  Click="Command_Entry_Click"/>
                <Button Name="Command_Cancel" Grid.Column="3" Margin="12,0,0,0" Content="{x:Static res:LocalResource.LABEL_CLOSE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" Width="100" Click="Command_Close_Click"/>
            </Grid>
        </Grid>


    </Grid>
</Window>
