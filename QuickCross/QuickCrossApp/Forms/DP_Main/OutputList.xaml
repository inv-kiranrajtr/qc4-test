<Window x:Class="Qc4Launcher.Forms.DP_Main.OutputList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:Qc4Launcher"
        xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        mc:Ignorable="d"
        Title = "{x:Static res:LocalResource.PROCESSING_TYPE_OUTPUT_LIST}" Height="615" Width="810" ResizeMode="NoResize" BorderBrush="#ADADAD" BorderThickness="1"
			WindowStartupLocation="CenterScreen" Background="#FFF0F0F0" Loaded="Window_Loaded" >
    <Window.Resources>
        <DataTemplate x:Key="QuestionVariable">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Text="{Binding Question}"></TextBlock>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="#FFFFFFFF" Margin="5">
        <Grid.RowDefinitions>
            <!-- Divide whole window into three rows-->
            <RowDefinition Height="103*"/>
            <RowDefinition Height="417*"/>
            <RowDefinition Height="56*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1,1,1,0"/>
        <Grid Grid.Row="0" Margin="10,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25*"/>
                <ColumnDefinition Width="100*"/>
                <ColumnDefinition Width="100*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{x:Static res:LocalResource.LBL_GROUP_PROCESSING_METHOD}" Style="{StaticResource TxtblockformatWithoutBg}" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Text="{x:Static res:LocalResource.LBL_GROUP_COMMAND}" Style="{StaticResource TxtblockformatWithoutBg}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" />

            </Grid>
            <Grid Grid.Column="1" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <TextBox Name="Textbox_ProcessMethod" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Left" Text="{x:Static res:LocalResource.PROCESSING_TYPE_OUTPUT_LIST}" Style="{StaticResource ROTxtBox}" 
                             Width="320" Height="25" TextWrapping="Wrap" Background="#FFFFFFFF" IsTabStop="False"/>
                <TextBox Name="Textbox_Command" Grid.Row="1"  Style="{StaticResource ROTxtBox3}" Text="{x:Static res:LocalResource.LABEL_LISTUP}"  Height="25" Width="320" HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" IsTabStop="False" ></TextBox>
            </Grid>
            <Grid Grid.Column="2" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <TextBlock Name="Text_Method_Desc" Grid.Row="0" Text="{x:Static res:LocalResource.LISTUP_TITLE_TEXT}" Style="{StaticResource TxtblockformatWithoutBg}" Background="#FFFFFFFF" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" />
            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width=".85*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"  Margin="10,5,10,10" BorderThickness="1"  BorderBrush="#FFE1E1E1">
                <Grid Grid.Column="0">
                    <uc:CriteriaControl x:Name="Criteria_Control" ></uc:CriteriaControl>
                </Grid>
            </Border>
            <Border Grid.Column="1"  Margin="0,5,10,10" BorderThickness="1"  BorderBrush="#FFE1E1E1">
                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50*"/>
                        <RowDefinition Height="70*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="57*"/>
                            <RowDefinition Height="188*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,101" Grid.RowSpan="2">

                            <TextBlock  Margin="22,10,0,0" Text="{x:Static res:LocalResource.LISTUP_TEXT}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Width="150" />


                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="7.5*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="8,5,10,-18" Height="180" VerticalAlignment="Top" Grid.RowSpan="2" >
                                <Grid.RowDefinitions>

                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Margin="15,10,0,0" Text="{x:Static res:LocalResource.LBL_GROUP_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Width="80" />
                                <TextBlock Grid.Row="1" Margin="15,-12,0,10" Text="{x:Static res:LocalResource.LBL_GROUP_QUESTION}" Style="{StaticResource TextBlockNormal}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" />

                            </Grid>
                            <Grid Grid.Column="1" Margin="0,5,5,-18" Height="180" VerticalAlignment="Top" Grid.RowSpan="2" >
                                <Grid.RowDefinitions>

                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>


                                <Grid Grid.Row="0" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="85*"/>
                                        <ColumnDefinition Width="70*"/>
                                        <ColumnDefinition Width="158*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Name="Text_OriginItem_AnswerType"  Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Width="80"  Style="{StaticResource NormalTextBox_READONLY}" Margin="0,6,0,5" IsTabStop="False" />
                                    <TextBlock Name="Lbl_No_of_Choices" Grid.Column="1" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LBL_GROUP_N0_OF_CHOICES}" Style="{StaticResource TextBlockNormalWithCenterAligned}" Background="#FFFFFFFF"
                                           HorizontalAlignment="Center" Margin="0,11,0,11"/>
                                    <TextBox Name="Text_OriginItem_SelectCount"  Style="{StaticResource NormalTextBox_READONLY}"  Grid.Column="2" HorizontalAlignment="Left" Width="85" Height="25" Margin="0,6,0,4" IsTabStop="False" />
                                </Grid>

                                <TextBox Name="Text_OriginItem_Question"  Style="{StaticResource NormalTextBoxMultiLine_READONLY}" Grid.Row="1" HorizontalAlignment="Left" HorizontalContentAlignment="Left"  Margin="0,10,0,15" Width="237" TextWrapping="Wrap" IsTabStop="False" />

                            </Grid>

                        </Grid>

                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40*"/>
                            <ColumnDefinition Width="10*"/>
                            <ColumnDefinition Width="40*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">

                            <DataGrid  Name="data_grid" Margin="15,5,9,5" Width="148" Height="217" BorderBrush="#FFE1E1E1" Style="{StaticResource Datagrid_GT_Font_Style}"
                                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" CurrentCellChanged="grid_CurrentCellChanged"
                                           AutoGenerateColumns="False" CanUserReorderColumns="False"  RowHeight="16.5" FontFamily="Arial" SelectionChanged="Data_grid_SelectionChanged"
                                           CanUserDeleteRows="False"  CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Disabled"
                                           HorizontalAlignment="Left" VerticalAlignment="Center" SelectionUnit="FullRow" SelectionMode="Extended"  PreviewKeyDown="data_grid_PreviewKeyDown" GotMouseCapture="Data_grid_GotMouseCapture" >
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" >
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Background" Value="#F6F6F6" />
                                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5f3fb" />
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                        </Style.Triggers>

                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn  Width="*" Binding="{Binding Choice}" CanUserResize="False" CanUserSort="False"  IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <Grid Grid.Column="1" Height="250">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="2" Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Style="{StaticResource SmallButton}" x:Name="Command_OriginItem_Add"  Click="Command_OriginItem_Add_Click" TabIndex="29" PreviewKeyDown="Command_OriginItem_Add_PreviewKeyDown" />
                            <Button Grid.Row="5" Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" Style="{StaticResource SmallButton}"  x:Name="Command_OriginItem_Remove" Click="Command_OriginItem_Remove_Click" TabIndex="31" PreviewKeyDown="Command_OriginItem_Remove_PreviewKeyDown" />
                        </Grid>

                        <Grid Grid.Column="2">
                            <DataGrid  Name="selecteditems_data_grid" Margin="15,5,9,5" Width="148" Height="217" BorderBrush="#FFE1E1E1" Style="{StaticResource Datagrid_GT_Font_Style}"
                                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" CurrentCellChanged="grid_CurrentCellChanged" 
                                           AutoGenerateColumns="False" CanUserReorderColumns="False"  RowHeight="16.5" FontFamily="Arial" DataContextChanged="selecteditems_data_grid_DataContextChanged"
                                           CanUserDeleteRows="False"  CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Disabled" SelectionChanged="Selecteditems_data_grid_SelectionChanged"
                                           HorizontalAlignment="Left" VerticalAlignment="Center" SelectionUnit="FullRow" SelectionMode="Extended"  PreviewKeyDown="selecteditems_data_grid_PreviewKeyDown" GotMouseCapture="Selecteditems_data_grid_GotMouseCapture"  >
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" >
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Background" Value="#F6F6F6" />
                                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5f3fb" />
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                
                                <DataGrid.Columns>
                                    <DataGridTextColumn  Width="*" Binding="{Binding Choice}" CanUserResize="False" CanUserSort="False"  IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>

                </Grid>
            </Border>
        </Grid>


        <Border BorderBrush="#FFE1E1E1" BorderThickness="1,0,1,1" Grid.Row="1"/>
        <Grid Grid.Row="2" Background="#FFF0F0F0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="30*"/>
            </Grid.ColumnDefinitions>

            <Button Name="Command_Entry" Grid.Column="2" Margin="10,0,0,0" Content="{x:Static res:LocalResource.BTN_SAVE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center"  Height="25" Width="100" IsEnabled="False" Click="Command_Entry_Click" TabIndex="33"/>
            <Button Name="Command_Cancel" Grid.Column="3" Margin="5,0,5,0" Content="{x:Static res:LocalResource.LABEL_CLOSE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" Width="100" Click="Command_Cancel_Click" TabIndex="34" PreviewKeyDown="Command_Cancel_PreviewKeyDown"/>
        </Grid>

    </Grid>
</Window>
