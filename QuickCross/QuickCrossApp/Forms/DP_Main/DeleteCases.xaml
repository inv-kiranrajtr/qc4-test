<Window x:Class="Qc4Launcher.Forms.DP_Main.DeleteCases"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:res="clr-namespace:Qc4Launcher"
        xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        mc:Ignorable="d"
        Title = "{x:Static res:LocalResource.LBL_DELETE_CASES}" Height="615" Width="810" ResizeMode="NoResize" PreviewMouseRightButtonDown="DisableRightMenu" PreviewMouseRightButtonUp="DisableRightMenu"
			WindowStartupLocation="CenterScreen" Background="#FFF0F0F0"  Loaded="Window_Loaded" BorderBrush="#ADADAD" BorderThickness="1" Closed="Window_Closed">
    <Grid Background="#FFFFFFFF" Margin="5">
        <Grid.RowDefinitions>
            <!-- Divide whole window into three rows-->
            <RowDefinition Height="12*"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <!--1st row with Processing Method, Command, Description and radio buttons to specify the case-->
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1,1,1,0"/>
        <Grid Grid.Row="0" Margin="13,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100*"/>
                <ColumnDefinition Width="100*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:LocalResource.LBL_GROUP_PROCESSING_METHOD}" Style="{StaticResource TxtblockformatWithoutBg}" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:LocalResource.LBL_GROUP_COMMAND}" Style="{StaticResource TxtblockformatWithoutBg}" Background="#FFFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <RadioButton Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Radibuttoncommon}" Name="Specify_Criteria" GroupName="SpecifyDeleteCase" Content="{x:Static res:LocalResource.LABEL_CRITERIA1}" TabIndex="1"
                          Margin="5,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" VerticalContentAlignment="Center" Click="OnRadioButtonClick"/>
                <TextBox Name="Textbox_ProcessMethod" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" TextAlignment="Left" Text="{x:Static res:LocalResource.LBL_DELETE_CASES}" Style="{StaticResource NormalTextBox_READONLY_WhiteBG}" 
                             Width="300" Height="25" TextWrapping="Wrap" Background="#FFFFFFFF" IsTabStop="False"/>
                <TextBox Name="Textbox_Command" Grid.Row="1" Grid.Column="1" Style="{StaticResource ROTxtBox3}" Text="{x:Static res:LocalResource.LABEL_DELETE}"  Height="25" Width="300" IsTabStop="False" 
                         HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" ></TextBox>
            </Grid>

            <Grid Grid.Column="1" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
            </Grid>

            <Grid Grid.Column="2" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <TextBlock Name="Text_Method_Desc" Grid.Row="0" Text="{x:Static res:LocalResource.LBL_DELETE_CASES_DESCRIPTION}" Style="{StaticResource TxtblockformatWithoutBg}" Background="#FFFFFFFF" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" Margin="15,0,0,0" />
                <RadioButton Grid.Row="2" Style="{StaticResource Radibuttoncommon}" Name="Specify_SampleID" GroupName="SpecifyDeleteCase" Content="{x:Static res:LocalResource.LABEL_SPFY_SAMPLEID}" 
                          Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" VerticalContentAlignment="Center" Click="OnRadioButtonClick" TabIndex="30"/>
            </Grid>
        </Grid>

        <!-- 2nd row with Criteria Control(1st column) and SampleID cases (2nd column) -->
        <Border BorderBrush="#FFE1E1E1" BorderThickness="1,0,1,1" Grid.Row="1">
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=".85*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"  Margin="10,5,15,10" BorderThickness="1" BorderBrush="#FFE1E1E1">
                    <Grid Grid.Column="0">
                        <uc:CriteriaControl x:Name="Criteria_Control" Margin="0,0,0,0" ></uc:CriteriaControl>
                    </Grid>
                </Border>
                
                <!-- Specify SampleID case -->
                <Border Grid.Column="1"  Margin="0,5,10,10" BorderThickness="1" BorderBrush="#FFE1E1E1">
                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3*"></RowDefinition>
                            <RowDefinition Height="5*"></RowDefinition>
                            <RowDefinition Height="6*"></RowDefinition>
                            <RowDefinition Height="6*"></RowDefinition>
                            <RowDefinition Height="50*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock Name="Label_SampleIDListFile" Grid.Row="1" Margin="2,0,0,0" Text="{x:Static res:LocalResource.LABEL_SAMPLEID_LISTFILE}" Style="{StaticResource TxtblockformatWithoutBg}" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" IsEnabled="False" Foreground="#ADADAD" />
                        <Button Name="Button_ReadFile" Grid.Row="2" Content="{x:Static res:LocalResource.LABEL_READFILE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Left" VerticalAlignment="Center"  Height="25" Width="100" IsEnabled="False" Foreground="#ADADAD" Click="Button_ReadFile_Click" TabIndex="31" PreviewKeyDown="Button_ReadFile_PreviewKeyDown"/>
                        <TextBox Name="Textbox_ShowCases" Grid.Row="3" Style="{StaticResource NormalTextBox_READONLY}" HorizontalAlignment="Left" VerticalAlignment="Center" Width="195" Height="25" IsEnabled="False" IsTabStop="False"/>
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid  Name="Grid_SampleIDList" Margin="0,5,0,0" Grid.Column="0" Width="195" Height="275" Style="{StaticResource Datagrid_GT_Font_Style}" TabIndex="32"
                                           ItemsSource="{Binding}" HeadersVisibility="None" IsEnabled="True" CurrentCellChanged="Grid_CurrentCellChanged" RowHeight="16" HorizontalGridLinesBrush="Transparent" VerticalGridLinesBrush="Transparent"
                                           AutoGenerateColumns="False" CanUserReorderColumns="False" FontFamily="Arial" Background="#FFF0F0F0" SelectionChanged="Grid_SampleIDList_SelectionChanged"
                                           CanUserDeleteRows="False"  CanUserSortColumns="False" CanUserAddRows="False" HorizontalScrollBarVisibility="Disabled" DataContextChanged="Grid_SampleIDList_DataContextChanged"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" SelectionUnit="FullRow" SelectionMode="Extended"  PreviewKeyDown="Grid_SampleIDList_PreviewKeyDown"  >
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" >
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="true" >
                                                <Setter Property="Foreground" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                <DataTrigger.Setters>
                                                    <Setter Property="Background" Value="#F6F6F6" />
                                                    <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                </DataTrigger.Setters>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#e5f3fb" />
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="BorderBrush" Value="#70c0e7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#FFF0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn  Width="*" Binding="{Binding SampleID}" CanUserResize="False" CanUserSort="False"  IsReadOnly="True">
                                        <DataGridTextColumn.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="5*"></RowDefinition>
                                    <RowDefinition Height="2*"></RowDefinition>
                                    <RowDefinition Height="6*"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Border Grid.Column="1" Grid.Row="0" Margin="0,5,10,0" BorderThickness="1" BorderBrush="#FFE1E1E1">
                                    <StackPanel Orientation="Vertical" Grid.Row="0" Margin="1" >
                                        <TextBlock Name ="Label_SpecifyID"  Text="{x:Static res:LocalResource.LABEL_SPFY_SAMPLEID1}" Style="{StaticResource TxtblockformatWithoutBg}" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,15,0,0" IsEnabled="False" Foreground="#ADADAD" />
                                        <TextBox Name="Textbox_SampleID" Style="{StaticResource NormalTextBox}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0" Width="130" Height="25" IsEnabled="False" Background="#F0F0F0" TextChanged="Textbox_SampleID_TextChanged" TabIndex="33" />
                                        <Button Name="Button_Add" Content="{x:Static res:LocalResource.QS_SUBTOTAL_ADD}" Style="{StaticResource NormalButton}" Margin="0,10,8,0" HorizontalAlignment="Right" VerticalAlignment="Center" Height="25" Width="100" IsEnabled="False" Foreground="#ADADAD" Click="Button_Add_Click" TabIndex="34" />
                                    </StackPanel>
                                </Border>
                                <Button Name="Button_Delete" Grid.Column="1" Grid.Row="1" Content="{x:Static res:LocalResource.QUSI_DELETE}" Style="{StaticResource NormalButton}" Margin="0,0,20,0" HorizontalAlignment="Right" VerticalAlignment="Center" Height="25" Width="100" IsEnabled="False" Foreground="#ADADAD" Click="Button_Delete_Click" TabIndex="35"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 3rd row with Save and close buttons-->
        <Grid Grid.Row="2" Background="#FFF0F0F0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="30*"/>
            </Grid.ColumnDefinitions>

            <Button Name="Command_Entry" Grid.Column="2" Margin="10,0,0,0" Content="{x:Static res:LocalResource.BTN_SAVE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center"  Height="25" Width="100" Click="Command_Entry_Click" IsEnabled="False" TabIndex="36" />
            <Button Name="Command_Cancel" Grid.Column="3" Margin="5,0,5,0" Content="{x:Static res:LocalResource.LABEL_CLOSE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" Width="100" Click="Command_Cancel_Click" TabIndex="37" PreviewKeyDown="Command_Cancel_PreviewKeyDown"/>
        </Grid>
    </Grid>
</Window>
