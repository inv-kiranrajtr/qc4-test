<Window x:Class="Qc4Launcher.Forms.DP_Main.ADD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.DP_Main"
        mc:Ignorable="d"
        xmlns:res="clr-namespace:Qc4Launcher"
        xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        WindowStartupLocation="CenterScreen" 
        Title="{x:Static res:LocalResource.DATAPROCESS_FORM_NAME}" Loaded="Window_Loaded"  Height="680" Width="805" Background="#FFF0F0F0"
        
        ResizeMode="NoResize" BorderBrush="#ADADAD" BorderThickness="1"  PreviewMouseRightButtonDown="DisableRightMenu" PreviewMouseRightButtonUp="DisableRightMenu">
    <Grid>
        <Grid Background="#FFFFFFFF" Margin="6">
            <Grid.RowDefinitions>
                <!-- Divide whole window into three rows-->
                <RowDefinition Height="6*"/>
                <RowDefinition Height="30*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
          
            <Border BorderBrush="#FFE1E1E1" BorderThickness="1,1,1,0" >
                <Grid Grid.Row="0" Margin="10,5,10,5">

                    <!-- 1st row with processing method and command-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="21.8*"/>
                        <ColumnDefinition Width="100*"/>
                        <ColumnDefinition Width="100*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,10,0" Text="{x:Static res:LocalResource.LBL_GROUP_PROCESSING_METHOD}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" Background="#FFFFFFFF" />
                        <TextBlock Grid.Row="1" Margin="0,0,10,0" Text="{x:Static res:LocalResource.LBL_GROUP_COMMAND}" Style="{StaticResource TextBlockNormalWithCenterAligned}"  HorizontalAlignment="Left"  />

                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                    
                        <TextBox Width="326" HorizontalAlignment="Left"  IsTabStop="False" Name="Textbox_ProcessMethod" Grid.Row="0"  Grid.Column="1" Height="25" Margin="2,2,0,0" Style="{StaticResource NormalTextBox}" Text="{x:Static res:LocalResource.LBL_COMMAND_ADD_PROCESS}" ></TextBox>
                        <TextBox Width="326" HorizontalAlignment="Left" Text="{x:Static res:LocalResource.ADD_PROCESS_TYPE}" IsTabStop="False" Name="lb_command"    Grid.Row="1" Grid.Column="1" Height="25" Margin="2,2,0,0" Style="{StaticResource NormalTextBox_READONLY_Command}" ></TextBox>

                    </Grid>
                    <Grid Grid.Column="2">

                        <TextBlock Name="Text_Command_Desc"  Text="{x:Static res:LocalResource.LBL_COMMAND_ADD_DESC}" Style="{StaticResource TextBlockNormal}" Background="#FFFFFFFF" Margin="5,10,0,0"  TextWrapping="Wrap" />


                    </Grid>

                </Grid>
            </Border>



            <!--2nd row with source variable and new variable details-->
            <Border Grid.Row="1" BorderBrush="#FFE1E1E1" BorderThickness="1,0,1,1"  >
                <Grid Grid.Row="1"  Grid.ColumnSpan="2" Margin="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"  Margin="5,5,0,5"  BorderThickness="1" BorderBrush="#FFE1E1E1">
                        <!-- Grid for source variable-->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2.3*"/>
                                <RowDefinition Height="4*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="12,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1.2*"/>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="2.5*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.Row="1" Margin="0,0,6,0" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_SOURCE_VARIABLE}"></TextBlock>
                                <TextBlock Grid.Column="0" Grid.Row="0" Margin="0,0,6,0" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Grid.ColumnSpan="2" Text="{x:Static res:LocalResource.ADD_SPECIFY_SOURCE_VARIABLE}"></TextBlock>

                                <TextBox  Name="Text_OriginItem_Item" Grid.Row="1"  Grid.Column="1" Margin="6,0,4,0"  IsTabStop="False" HorizontalAlignment="Left" VerticalAlignment="Center" Width="200" Height="25"  Style="{StaticResource NormalTextBox_READONLY}" />


                                <TextBlock Grid.Column="0" Grid.Row="2" Margin="0,0,0,6" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}"></TextBlock>

                                <Grid Grid.Column="1" Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox IsTabStop="False" Grid.Column="0" x:Name="txt_answerType"  Height="25" Margin="6,0,4,0"  Style="{StaticResource NormalTextBox_READONLY}"></TextBox>
                                    <TextBlock Grid.Column="1" Grid.Row="1" Margin="6,0,6,0" TextWrapping="Wrap" HorizontalAlignment="Left" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LBL_NO_OF_CHOICES}" Width="56"></TextBlock>

                                    <TextBox IsTabStop="False" Grid.Column="2"  x:Name="txt_answerTypeWithChoiceCount"  Height="25" Margin="0,0,12,0"  Style="{StaticResource NormalTextBox_READONLY}"></TextBox>

                                </Grid>
                               

                                <TextBlock Grid.Column="0" Grid.Row="3" Margin="0,6,6,6" Style="{StaticResource TextBlockNormal}" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}"></TextBlock>
                                <TextBox IsTabStop="False" x:Name="txt_source_Question" Grid.Column="1" TextWrapping="Wrap" Grid.Row="3" Margin="6,6,12,6" Style="{StaticResource NormalTextBoxMultiLine_READONLY}"  VerticalScrollBarVisibility="Auto"  ></TextBox>

                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>

                                <Grid Margin="0 10 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40*"/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition Width="40*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"  Margin="0" TextWrapping="Wrap" HorizontalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_SOURCE_VARIABLE}" VerticalAlignment="Bottom"  ></TextBlock>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Bottom"  Margin="0" TextWrapping="Wrap" HorizontalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LBL_SOURCE_MERGE}"   ></TextBlock>


                                </Grid>
                                
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40*"/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition Width="40*"/>
                                    </Grid.ColumnDefinitions>



                                    <DataGrid KeyboardNavigation.TabNavigation="Continue" KeyboardNavigation.TabIndex="1" TabIndex="1" KeyboardNavigation.IsTabStop="True"  x:Name="Grid_OriginItem_ChoiceList1" Grid.Column="0" ItemsSource="{Binding}" BorderBrush="#FFE1E1E1" Margin="9" RowHeight="17" HeadersVisibility="None"  AutoGenerateColumns="False"    
                                       SelectionUnit="FullRow" SelectionMode="Extended"
                                               
                                               CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" FocusVisualStyle="{x:Null}"  HorizontalGridLinesBrush="White" IsEnabled="True" IsReadOnly="True" Background="White" 
                                        VerticalGridLinesBrush="White"  ScrollViewer.CanContentScroll="True"  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" CanUserResizeColumns="False" CanUserResizeRows="False" Padding="3,0,0,0"
                                        SelectionChanged="Grid_OriginItem_ChoiceList1_SelectionChanged"  CurrentCellChanged="Grid_CurrentCellChanged" PreviewKeyDown="Grid_OriginItem_ChoiceList1_PreviewKeyDown" GotMouseCapture="Grid_OriginItem_ChoiceList1_GotMouseCapture" >
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell" >
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                        </DataGrid.Resources>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                        <DataTrigger.Setters>
                                                            <Setter Property="Background" Value="#F6F6F6" />
                                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                        </DataTrigger.Setters>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#e5f3fb" />
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                       
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.Columns >
                                            <DataGridTextColumn Width="*" Binding="{Binding Variable}" x:Name="No1" CanUserResize="False" CanUserSort="False" >
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="true" >
                                                                <Setter Property="Foreground" Value="Black" />
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>


                                    <Grid Grid.Column="1" Height="250">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="45"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                            <RowDefinition Height="25"/>
                                        </Grid.RowDefinitions>
                                        <Button  TabIndex="2"  Grid.Row="2" Content="{x:Static res:LocalResource.LABEL_SINGLE_RIGHT_ARROW}" Style="{StaticResource SmallButton}"  x:Name="Command_OriginItem_Add"  Click="Command_OriginItem_Add_Click"  />
                                        <Button TabIndex="4" Grid.Row="5" Content="{x:Static res:LocalResource.LABEL_SINGLE_LEFT_ARROW}" Style="{StaticResource SmallButton}"  x:Name="Command_OriginItem_Remove" Click="Command_OriginItem_Remove_Click" />
                                    </Grid>


                                    <DataGrid  x:Name="Grid_OriginItem_ChoiceList2" Grid.Column="2" ItemsSource="{Binding}" BorderBrush="#FFE1E1E1" Margin="9" RowHeight="17" HeadersVisibility="None" Padding="3,0,0,0"
                                        CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" HorizontalGridLinesBrush="White" IsEnabled="True" IsReadOnly="True" TabIndex="3" 
                                        IsTabStop="True" SelectionUnit="FullRow" SelectionMode="Extended"
                                               HorizontalScrollBarVisibility="Disabled" 
                                               VerticalGridLinesBrush="White"  VerticalScrollBarVisibility="Auto" CanUserResizeColumns="False" CanUserResizeRows="False"
                                        Background="White"  AutoGenerateColumns="False" SelectionChanged="Grid_OriginItem_ChoiceList2_SelectionChanged" DataContextChanged="Grid_OriginItem_ChoiceList2_DataContextChanged" 
                                         CurrentCellChanged="Grid_CurrentCellChanged" PreviewKeyDown="Grid_OriginItem_ChoiceList2_PreviewKeyDown" GotMouseCapture="Grid_OriginItem_ChoiceList2_GotMouseCapture" LoadingRow="Grid_OriginItem_ChoiceList2_LoadingRow">
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell" >
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="true" >
                                                        <Setter Property="Foreground" Value="Black" />
                                                    </Trigger>
                                                </Style.Triggers>
                                                <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                        </DataGrid.Resources>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                        <DataTrigger.Setters>
                                                            <Setter Property="Background" Value="#F6F6F6" />
                                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                        </DataTrigger.Setters>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#e5f3fb" />
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.Columns >
                                            <DataGridTextColumn Width="*" Binding="{Binding Variable}" x:Name="No2" CanUserResize="False" CanUserSort="False" >
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="true" >
                                                                <Setter Property="Foreground" Value="Black" />
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                        <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                </Grid>
                                <Grid Grid.Row="2">
                                    <CheckBox x:Name="exclude_chk" Content="{x:Static res:LocalResource.ADD_CHECKBOX_EXCLUDE}" HorizontalAlignment="Center" VerticalAlignment="Center" TabIndex="5" Margin="0,10,0,10" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>


                    <Border Grid.Column="1"  Margin="5,5,5,5"  BorderThickness="1" BorderBrush="#FFE1E1E1">
                        <!--Grid for new variable-->
                        <Grid Grid.Column="1" Margin="8 0 8 8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2.3*" />
                                <RowDefinition Height="4*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="2.5*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.Row="0" Margin="6,2,6,2" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                              
                                <Grid Grid.Column="1" Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox TabIndex="6"  Grid.Column="0" Name="txt_new_variable" Margin="6,2,6,2" MaxLength="25" Background="#FFF0F0F0" Height="25" TextChanged="Txt_new_variable_TextChanged" SelectionChanged="Txt_new_variable_SelectionChanged" Style="{StaticResource NormalTextBox_Disabled}"></TextBox>
                                    <Button TabIndex="7" Padding="0" Name="NewItemSearchbutton" Style="{StaticResource SmallButton}" Grid.Column="1" HorizontalAlignment="Left"  Click="NewItemSearchbutton_Click"  Width="25" Height="25" >
                                        <uc:MagnifyingGlassButton   x:Name="MagnifyingGlassButton" Title= "ADD"  ></uc:MagnifyingGlassButton>
                                    </Button>
                                  

                                </Grid>


                                <TextBlock Grid.Column="0" Grid.Row="1" Margin="6,10,6,6" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                                <Grid Grid.Column="1" Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3.6*"/>
                                        <ColumnDefinition Width="2.4*"/>
                                        <ColumnDefinition Width="4*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox   Name="Text_NewItem_AnswerType"  Grid.Column="0" Height="25"  Style="{StaticResource NormalTextBox_READONLY}"  IsTabStop="False" Margin="6 2 6 2" HorizontalAlignment="Left"   Width="80" />

                                    <TextBlock TextWrapping="Wrap" x:Name="txtach" Grid.Column="1" Margin="6,2,6,2" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_NO_OF_CHOICES}"></TextBlock>
                                    <ComboBox TabIndex="8" x:Name="choicesCount" Margin="0 0 5 0" Grid.Column="2" HorizontalAlignment="Left" IsEditable="True" Style="{StaticResource NormalComboBox_Editable}" PreviewKeyUp="ChoicesCount_PreviewKeyUp" SelectionChanged="ChoicesCount_SelectionChanged" Width="88" Height="25" SelectedIndex="0" ></ComboBox>

                                </Grid>
                              
                                <TextBlock Grid.Column="0" Grid.Row="2" Margin="6,6,6,6" Padding="0,6,0,0" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}" Style="{StaticResource TextBlockNormal}"></TextBlock>
                                <TextBox TabIndex="9" MaxLength="32767" AcceptsReturn="True" TextWrapping="Wrap" Name="Text_NewItem_Question" Width="238" HorizontalAlignment="Left" Background="#FFF0F0F0" Style="{StaticResource NormalTextBoxMultiLine}" VerticalScrollBarVisibility="Auto" Grid.Column="1" Grid.Row="2"  Margin="6 6 5 6" />

                            </Grid>
                            
                            <Grid Grid.Row="1" x:Name="Grid_Hidden">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="12*"/>
                                </Grid.RowDefinitions>
                               

                                <Grid Grid.Row="1" Margin="5,14.5,5,0">

                                    <DataGrid FocusVisualStyle="{x:Null}"  KeyboardNavigation.TabIndex="10" KeyboardNavigation.TabNavigation="Local"  x:Name="data_grid" Style="{StaticResource Datagrid_normal_NoPadding}" BorderBrush="#FFE1E1E1" RowHeight="25" HeadersVisibility="All"  RowHeaderWidth="0" IsEnabled="True"  Grid.Column="1" AutoGenerateColumns="False"
                                   CanUserReorderColumns="False"  CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" HorizontalGridLinesBrush="#FFADADAD" 
                                   VerticalGridLinesBrush="#FFADADAD"  ColumnHeaderStyle="{StaticResource Datagrid_Header_Style}" 
                                              PreviewKeyDown="HandleCopyPaste"  PreviewKeyUp="Data_grid_PreviewKeyUp" CopyingRowClipboardContent="Data_grid_CopyingRowClipboardContent" IsMouseCaptureWithinChanged="Data_grid_IsMouseCaptureWithinChanged" >
                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                            <Style TargetType="DataGrid">
                                                <Setter Property="TextBox.TextWrapping" Value="NoWrap" />
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Style.Triggers>
                                                    <Trigger Property="IsReadOnly" Value="True">
                                                        <Setter Property="IsTabStop" Value="False"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                        <DataTrigger.Setters>
                                                            <Setter Property="Background" Value="#F6F6F6" />
                                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                        </DataTrigger.Setters>
                                                    </DataTrigger>

                                                    <Trigger Property="IsMouseOver"
                           Value="True">
                                                        <Setter Property="Background"
                               Value="#e5f3fb" />
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">

                                                        <Setter Property="Background" Value="#CBE8F6"/>
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                </Style.Triggers>

                                            </Style>
                                        </DataGrid.RowStyle>
                                      
                                        <DataGrid.Columns>
                                           
                                            <DataGridTextColumn  x:Name="txt_choicesIndex" Width="32" IsReadOnly="True"  Binding="{Binding Id}" CanUserResize="False">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                        <Setter Property="Background" Value="#FFF0F0F0"/>
                                                        <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
                                                        <Style.Triggers>
                                                            <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                                <Setter Property="BorderBrush">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="Transparent"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="Foreground"
                            Value="{DynamicResource
                                   {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#FFF0F0F0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                        
                                                    </Style>

                                                </DataGridTextColumn.CellStyle>
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Foreground" Value="#FF333333" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn  x:Name="txt_dataGrid_choice" Header="{x:Static res:LocalResource.LABEL_CHOICE}" Width="*" Binding="{Binding Choice}" CanUserResize="False"  >

                                                <DataGridTextColumn.ElementStyle>
                                                    
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Padding" Value="6,0,0,0" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Foreground" Value="#FF333333" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChoiceEmpty}" Value="true">
                                                                <Setter Property="BorderBrush" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                           
                                        </DataGrid.Columns>
                                    </DataGrid>

                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 3rd row with Save and close button-->
            <Grid Grid.Row="2" Background="#FFF0F0F0" Margin="0,1,0,0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="30*"/>
                    <ColumnDefinition Width="30*"/>
                </Grid.ColumnDefinitions>
                <Button TabIndex="11" Name="Save" Grid.Column="2" Margin="12,0,0,0"  Content="{x:Static res:LocalResource.BTN_SAVE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center"  Height="25" Width="100" IsEnabled="False" Click="Save_Click_1" />
                <Button TabIndex="12" Name="Command_Cancel" Grid.Column="3" Margin="12,0,0,0"  Content="{x:Static res:LocalResource.LABEL_CLOSE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" Width="100" PreviewKeyDown="Command_Cancel_PreviewKeyDown" Click="Command_Close_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
