<Window x:Class="Qc4Launcher.Forms.DP_Main.COUNT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher.Forms.DP_Main"
        mc:Ignorable="d"
        xmlns:uc="clr-namespace:Qc4Launcher.Forms.UserControls"
        xmlns:res="clr-namespace:Qc4Launcher"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Title="{x:Static res:LocalResource.DATAPROCESS_FORM_NAME}"  Height="700" Width="810" ResizeMode="NoResize"
		WindowStartupLocation="CenterScreen" MouseRightButtonDown="DisableRightMenu" MouseRightButtonUp="DisableRightMenu" Loaded="Window_Loaded" Background="#FFF0F0F0" BorderBrush="#ADADAD" BorderThickness="1">
    <Grid>
        <Grid Background="#FFFFFFFF" Margin="6">
            <Grid.RowDefinitions>
                <!-- Divide whole window into three rows-->
                <RowDefinition Height="6*"/>
                <RowDefinition Height="30*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <Border BorderBrush="#FFE1E1E1" BorderThickness="1,1,1,0" >
                <Grid Grid.Row="0" Margin="10,5,10,5">

                    <!-- 1st row with processing method and command-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="23*"/>
                        <ColumnDefinition Width="100*"/>
                        <ColumnDefinition Width="100*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,0,0" Text="{x:Static res:LocalResource.LBL_GROUP_PROCESSING_METHOD}" Style="{StaticResource TextBlockNormalWithCenterAligned}" HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap" Background="#FFFFFFFF" />
                        <TextBlock Grid.Row="1" Margin="0,0,0,0" Text="{x:Static res:LocalResource.LBL_GROUP_COMMAND}" Style="{StaticResource TextBlockNormalWithCenterAligned}"  HorizontalAlignment="Left"  />

                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox  IsTabStop="False" Name="Textbox_ProcessMethod" Grid.Row="0"  Grid.Column="1" Height="25" Margin="2,2,0,0" Style="{StaticResource NormalTextBox}" Text="{x:Static res:LocalResource.TEXT_COUNT_PROCESSING_METHOD}"  ></TextBox>
                        <TextBox  IsTabStop="False" Name="lb_command"    Grid.Row="1" Grid.Column="1" Height="25" Margin="2,2,0,0" Style="{StaticResource NormalTextBox_READONLY_Command}" TabIndex="1"></TextBox>

                    </Grid>
                    <Grid Grid.Column="2">

                        <TextBlock Name="Text_Command_Desc"  Text="{x:Static res:LocalResource.LBL_COMMAND_COUNT_DESC}" Style="{StaticResource TextBlockNormal}" Background="#FFFFFFFF" Margin="5,10,0,0"  TextWrapping="Wrap" />


                    </Grid>

                </Grid>
            </Border>



            <!--2nd row with source variable and new variable details-->
            <Border Grid.Row="1" BorderBrush="#FFE1E1E1" BorderThickness="1,0,1,1"  >
                <Grid Grid.Row="1"  Grid.ColumnSpan="2" Margin="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"  Margin="5,5,0,5"  BorderThickness="1" BorderBrush="#FFE1E1E1">
                        <!-- Grid for source variable-->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.8*"/>
                                <RowDefinition Height="4*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="12,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="1.8*"/>
                                    <RowDefinition Height="2.5*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.Row="0" Margin="0,4,6,0" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_SOURCE_VARIABLE}"></TextBlock>

                                <ComboBox  GotFocus="Combo_sourceVariable_GotFocus_1" TabIndex="0" Name="Combo_sourceVariable" ItemsSource="{Binding Path=SourceVariableListView}"  Grid.Column="1" Grid.Row="0" Margin="6,6,6,2" Height="25"
                                IsTextSearchEnabled="True" TextSearch.TextPath="Variable" 
                                HorizontalAlignment="Left" IsEnabled="True" GotKeyboardFocus="Combo_sourceVariable_GotKeyboardFocus"           
                                IsSynchronizedWithCurrentItem="True" DropDownClosed="Combo_sourceVariable_DropDownOpened" PreviewKeyUp="Combo_sourceVariable_PreviewKeyUp" PreviewKeyDown="Combo_sourceVariable_PreviewKeyDown"
                                Width="150" Style="{StaticResource NormalComboBox_Editable}" SelectionChanged="Combo_sourceVariable_SelectionChanged" >
                                    <ComboBox.Resources>
                                        <Style TargetType="Popup">
                                            <Setter Property="MaxWidth" Value="508"/>
                                        </Style>
                                    </ComboBox.Resources>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="2" Text="{Binding Variable}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBox.ItemContainerStyle >
                                        <Style TargetType="{x:Type ComboBoxItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <Grid x:Name="gd" TextElement.Foreground="Black">
                                                            <Grid.ColumnDefinitions >
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Width="150" Margin="5" Grid.Column="0" Text="{Binding Variable}"/>
                                                            <TextBlock Width="80" Margin="5" Grid.Column="1" Text="{Binding AnswerTypeWithNoOfChoices}"/>
                                                            <TextBlock Width="auto" Margin="5" Grid.Column="2" Text="{Binding Question}"/>
                                                        </Grid>
                                                        
                                                        <ControlTemplate.Triggers >
                                                            <Trigger Property="ComboBoxItem.IsSelected" Value="True">
                                                                <Setter TargetName="gd"  Property="Background" Value="#F6F6F6"></Setter>
                                                                <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                            </Trigger>
                                                            <Trigger Property="ComboBoxItem.IsMouseOver" Value="True">
                                                                <Setter TargetName="gd"  Property="Background" Value="#e5f3fb"></Setter>
                                                                <Setter TargetName="gd"  Property="TextElement.Foreground" Value="#FF333333"></Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>

                                                    </ControlTemplate>

                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>



                                <TextBlock Grid.Column="0" Grid.Row="1" Margin="0,10,6,6" TextWrapping="Wrap" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_ANSWER_TYPE}"></TextBlock>

                                <Grid Grid.Column="1" Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox IsTabStop="False" Grid.Column="0" x:Name="txt_answerType"  Height="25" Margin="6,0,0,0" IsEnabled="False" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>
                                    <TextBlock Grid.Column="1" Grid.Row="1" Margin="6,8,6,6" TextWrapping="Wrap" HorizontalAlignment="Left" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LBL_NO_OF_CHOICES}" Width="56"></TextBlock>

                                    <TextBox IsTabStop="False" Grid.Column="2"  x:Name="txt_answerTypeWithChoiceCount"  Height="25" Margin="0,0,12,0" IsEnabled="False" Style="{StaticResource NormalTextBox_READONLY}"></TextBox>

                                </Grid>

                                <TextBlock Grid.Column="0" Grid.Row="2" Margin="0,6,6,6" Style="{StaticResource TextBlockNormal}" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}"></TextBlock>
                                <TextBox IsTabStop="False" x:Name="txt_source_Question" Grid.Column="1" TextWrapping="Wrap" Grid.Row="2" Margin="5,0,12,6" Style="{StaticResource NormalTextBoxMultiLine_READONLY}"  IsEnabled="False" VerticalScrollBarVisibility="Auto" Height="55" VerticalAlignment="Bottom"></TextBox>

                            </Grid>
                            <Grid Grid.Row="1">
                                <DataGrid CanUserResizeRows="False" x:Name="choices_grid"  BorderBrush="#FFE1E1E1"  Style="{StaticResource Datagrid_normal_NoPadding}"  ItemsSource="{Binding}" HeadersVisibility="Row" IsEnabled="False" IsTabStop="False" KeyboardNavigation.IsTabStop="False"
                                   Background="#FFF0F0F0"  AutoGenerateColumns="False" CanUserReorderColumns="False" CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" VerticalScrollBarVisibility="Auto" PreviewKeyDown="Choices_grid_PreviewKeyDown"
                                   CurrentCellChanged="Choices_grid_CurrentCellChanged" HorizontalScrollBarVisibility="Hidden" Margin="12,5,12,10" RowHeaderWidth="0" RowHeight="20" HorizontalGridLinesBrush="Transparent" VerticalGridLinesBrush="Transparent" CopyingRowClipboardContent="Choices_grid_CopyingRowClipboardContent" >
                                    <DataGrid.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                    </DataGrid.Resources>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="{x:Type DataGridRow}">
                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                    <DataTrigger.Setters>
                                                        <Setter Property="Background" Value="LightGray" />
                                                    </DataTrigger.Setters>
                                                </DataTrigger>

                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#e5f3fb" />
                                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                </Trigger>
                                            </Style.Triggers>

                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns >
                                        <DataGridTextColumn Binding="{Binding Index, Mode=OneWay}" CanUserResize="False" CanUserSort="False" Header="No"  Width="32" IsReadOnly="False">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                                    <Setter Property="BorderBrush" Value="#FFE1E1E1"/>
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="Foreground" Value="#FF333333" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn  Binding="{Binding Choice, Mode=OneWay}" CanUserResize="False" CanUserSort="False" Header="Choice"  Width="*" IsReadOnly="False">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource Datagrid_GT_Cell_Style_qs}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="true" >
                                                            <Setter Property="Foreground" Value="Black" />
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                    <EventSetter Event="PreviewMouseDown" Handler="b1SetColor"/>
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Border>


                    <Border Grid.Column="1"  Margin="5,5,5,5"  BorderThickness="1" BorderBrush="#FFE1E1E1">
                        <!--Grid for new variable-->
                        <Grid Grid.Column="1" Margin="8 0 8 8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.75*" />
                                <RowDefinition Height="4*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="4*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="1.4*"/>
                                    <RowDefinition Height="2.5*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Grid.Row="0" Margin="6,2,6,2" TextWrapping="Wrap" Text="{x:Static res:LocalResource.LABEL_NEW_VARIABLE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>

                                <Grid Grid.Column="1" Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox  HorizontalAlignment="Left" Grid.Column="0" Name="txt_new_variable" Margin="6,2,6,2" MaxLength="25" Background="#FFF0F0F0" Height="25" Width="150" IsEnabled="False" Style="{StaticResource NormalTextBox_Disabled}" TextChanged="Txt_new_variable_TextChanged"></TextBox>
                                    <Button  BorderThickness="0" Padding="0" Name="NewItemSearchbutton" Style="{StaticResource SmallButton}" Grid.Column="1" HorizontalAlignment="Left"  Click="NewItemSearchbutton_Click"  Width="25" Height="25" IsTabStop="False" >
                                        <uc:MagnifyingGlassButton    x:Name="MagnifyingGlassButton" Title= "COUNT"  ></uc:MagnifyingGlassButton>
                                    </Button>

                                </Grid>


                                <TextBlock Grid.Column="0" Grid.Row="1" Margin="6,10,6,6" TextWrapping="Wrap"  Text="{x:Static res:LocalResource.LABEL_ANSWERTYPE}" Style="{StaticResource TextBlockNormalWithCenterAligned}"></TextBlock>
                                <Grid Grid.Column="1" Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2.4*"/>
                                        <ColumnDefinition Width="4.6*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox  Grid.Column="0" SelectionChanged="AnswerType_SelectionChanged" IsEnabled="False" x:Name="answerType"  Margin="6 2 0 2" HorizontalAlignment="Left"   Width="80" Height="25" SelectedIndex="0" ></ComboBox>
                                    <TextBlock TextWrapping="Wrap" x:Name="txtach" Grid.Column="1" Margin="6,2,6,2" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource TextBlockNormalWithCenterAligned}" Text="{x:Static res:LocalResource.LABEL_NO_OF_CHOICES}"></TextBlock>
                                    <ComboBox  x:Name="choicesCount" Margin="0 0 5 0" Grid.Column="2" HorizontalAlignment="Left" IsEditable="True" Style="{StaticResource NormalComboBox_Editable}" PreviewKeyUp="ChoicesCount_PreviewKeyUp" SelectionChanged="ChoicesCount_SelectionChanged" Width="86" Height="25" SelectedIndex="0" ></ComboBox>

                                </Grid>

                                <TextBlock Grid.Column="0" Grid.Row="2" Margin="6,6,6,6" Padding="0,6,0,0" Text="{x:Static res:LocalResource.ADDQS_QUESTION_LABEL}" Style="{StaticResource TextBlockNormal}"></TextBlock>
                                <TextBox  AcceptsReturn="True" TextWrapping="Wrap" Name="Text_NewItem_Question" Width="244" HorizontalAlignment="Left" Background="#FFF0F0F0" Style="{StaticResource NormalTextBoxMultiLine}" VerticalScrollBarVisibility="Auto" Grid.Column="1" Grid.Row="2"  Margin="6 6 5 6"  IsEnabled="False" />

                            </Grid>
                            <Grid Grid.Row="1" x:Name="Grid_Hidden">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="12*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3.1*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Row="0" Grid.Column="0">
                                        <TextBlock x:Name="choicerangetxt" Margin="5 0 0 5" Text="{x:Static res:LocalResource.COUNT_CHOICE_RANGE}" Style="{StaticResource TextBlockNormal}"/>
                                    </Grid>
                                    <ComboBox  Grid.Column="0" HorizontalAlignment="Left" Grid.Row="1" IsReadOnly="True"  x:Name="choiceRange1" IsEditable="True" Margin="5 2 2 2"  Width="60" Height="25" SelectedIndex="0" ></ComboBox>
                                    <TextBlock x:Name="choicerangetxt1" Margin="75,0,106,0" VerticalAlignment="Center" Grid.Column="0" Grid.Row="1" Text="-" Style="{StaticResource TextBlockNormal}"/>
                                    <Grid Grid.Row="0" Grid.Column="1">
                                        <TextBlock x:Name="choiceranget" Margin="6 0 0 5" Text="{x:Static res:LocalResource.COUNT_INPUT_ASSIST}" Style="{StaticResource TextBlockNormal}"/>
                                    </Grid>
                                    <ComboBox  IsReadOnly="True" Grid.Column="0" HorizontalAlignment="Left" Grid.Row="1"  x:Name="choiceRange2" IsEditable="True" Margin="90 2 2 2"   Width="60" Height="25"  ></ComboBox>
                                    <ComboBox  SelectionChanged="Input_axilary_comb_SelectionChanged"  Grid.Column="1" HorizontalAlignment="Left" Grid.Row="1"   x:Name="input_axilary_comb" IsEditable="True" Margin="6 2 2 2"   Width="124" Height="25" PreviewKeyDown="Input_axilary_comb_PreviewKeyDown"  ></ComboBox>

                                </Grid>

                                <Grid Grid.Row="1" Margin="5,6,5,0">
                                    <DataGrid  x:Name="data_grid" TabIndex="9" MouseRightButtonDown="DisableRightMenu" MouseRightButtonUp="DisableRightMenu"  PreviewMouseRightButtonDown="Data_grid_PreviewMouseRightButtonDown" CopyingRowClipboardContent="Data_grid_CopyingRowClipboardContent"  Style="{StaticResource Datagrid_normal_NoPadding}" BorderBrush="#FFE1E1E1" RowHeight="24.9" HeadersVisibility="All"  RowHeaderWidth="0" IsEnabled="True"  Grid.Column="1" AutoGenerateColumns="False"
                                   CanUserReorderColumns="False"  CanUserDeleteRows="False" CanUserSortColumns="False" CanUserAddRows="False" HorizontalGridLinesBrush="#FFADADAD" VerticalGridLinesBrush="#FFADADAD" SelectionMode="Extended" ColumnHeaderStyle="{StaticResource Datagrid_Header_Style}" PreviewKeyDown="HandleCopyPaste" PreviewKeyUp="Data_grid_PreviewKeyUp" IsMouseCaptureWithinChanged="Data_grid_IsMouseCaptureWithinChanged" FocusVisualStyle="{x:Null}">

                                        <DataGrid.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F6F6F6"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#CBE8F6"/>
                                        </DataGrid.Resources>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Path=Selectable}" Value="False">
                                                        <DataTrigger.Setters>
                                                            <Setter Property="Background" Value="#F6F6F6" />
                                                            <Setter Property="BorderBrush" Value="#F1F1F1"/>
                                                        </DataTrigger.Setters>
                                                    </DataTrigger>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#e5f3fb" />
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">

                                                        <Setter Property="Background" Value="#CBE8F6"/>
                                                        <Setter Property="BorderBrush" Value="#70c0e7"/>
                                                    </Trigger>
                                                </Style.Triggers>

                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>

                                            <DataGridTextColumn ScrollViewer.CanContentScroll="False"  x:Name="txt_choicesIndex" Width="32" IsReadOnly="True"  Binding="{Binding Id}" CanUserResize="False">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                        <Setter Property="Background" Value="#FFF0F0F0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                                <Setter Property="BorderBrush">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="Transparent"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="Foreground" Value="{DynamicResource  {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#FFF0F0F0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>

                                                </DataGridTextColumn.CellStyle>
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Foreground" Value="#FF333333" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn x:Name="txt_dataGrid_choice" Header="{x:Static res:LocalResource.LABEL_CHOICE}" Width="150" Binding="{Binding Choices}" CanUserResize="False"  >
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Padding" Value="6,0,0,0" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Foreground" Value="#FF333333" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChoiceEmpty}" Value="true">
                                                                <Setter Property="BorderBrush" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.COUNT_LOWER_LIMIT}" ClipboardContentBinding="{Binding SelectedOperator}" IsReadOnly="True" Width="*" CanUserResize="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox x:Name="cmb_dataGrid_operator1" BorderThickness="0" IsEditable="False" Background="White"  KeyDown="Cmb_dataGrid_operator1_KeyDown" DropDownOpened="Cmb_dataGrid_operator1_DropDownOpened"
                                                                  ItemsSource="{Binding Operator,Mode=TwoWay}"  BorderBrush="White" SelectedItem="{Binding SelectedOperator,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                  >
                                                            <ComboBox.Style>
                                                                <Style TargetType="ComboBox">
                                                                    <Setter Property="TextElement.Foreground" Value="#FF333333"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLowerInvalid}" Value="true">
                                                                            <Setter Property="TextElement.Foreground" Value="Red"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsLowerInvalid}" Value="false">
                                                                            <Setter Property="TextElement.Foreground" Value="#FF333333"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ComboBox.Style>
                                                        </ComboBox>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLowerEmpty}" Value="true">
                                                                <Setter Property="BorderBrush" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTemplateColumn.CellStyle>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn IsReadOnly="True" x:Name="txt_dataGrid_criteria"  Width="30" Binding="{Binding Tild}" CanUserResize="False">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                        <Setter Property="Background" Value="#FFF0F0F0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="DataGridCell.IsSelected" Value="True">
                                                                <Setter Property="BorderBrush">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="Transparent"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#FFF0F0F0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>

                                                </DataGridTextColumn.CellStyle>
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Foreground" Value="#FF333333" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTemplateColumn Header="{x:Static res:LocalResource.COUNT_UPPER_LIMIT}" ClipboardContentBinding="{Binding SelectedOperator1}" IsReadOnly="True" Width="*" CanUserResize="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox x:Name="cmb_dataGrid_operator1" BorderThickness="0"  KeyDown="Cmb_dataGrid_operator1_KeyDown" ItemsSource="{Binding Operator1,Mode=TwoWay}" IsEditable="False" Background="White"  BorderBrush="White" SelectedItem="{Binding SelectedOperator1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" DropDownOpened="Cmb_dataGrid_operator1_DropDownOpened">
                                                            <ComboBox.Style>
                                                                <Style TargetType="ComboBox">
                                                                    <Setter Property="TextElement.Foreground" Value="#FF333333"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUpperInvalid}" Value="true">
                                                                            <Setter Property="TextElement.Foreground" Value="Red"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsUpperInvalid}" Value="false">
                                                                            <Setter Property="TextElement.Foreground" Value="#FF333333"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ComboBox.Style>
                                                        </ComboBox>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUpperEmpty}" Value="true">
                                                                <Setter Property="BorderBrush" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTemplateColumn.CellStyle>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 3rd row with Save and close button-->
            <Grid Grid.Row="2" Background="#FFF0F0F0" Margin="0,1,0,0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="30*"/>
                    <ColumnDefinition Width="30*"/>
                </Grid.ColumnDefinitions>
                <Button  Name="choicebtn" Grid.Column="1" Margin="12,0,0,0"  Content="{x:Static res:LocalResource.BTN_SET_CHOICE_LABELS}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                         Height="25" Width="100" IsEnabled="False" Click="Choicebtn_Click" ToolTip="{x:Static res:LocalResource.TOOLTIP_CLASS_SET_CHOICE_LABELS}" />
                <Button Name="Save" Grid.Column="2" Margin="12,0,0,0"  Content="{x:Static res:LocalResource.BTN_SAVE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center"  Height="25" Width="100" IsEnabled="False" Click="Save_Click" />
                <Button Name="Command_Cancel" Grid.Column="3" Margin="12,0,0,0"  Content="{x:Static res:LocalResource.LABEL_CLOSE}" Style="{StaticResource NormalButton}" HorizontalAlignment="Center" VerticalAlignment="Center" Height="25" Width="100" Click="Command_Close_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
