                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <!--<TextBox x:Name="DiferenceValue"  VerticalAlignment="Center"   HorizontalContentAlignment="Right" />
                                            <Button x:Name="upBtn" Content="▲"  FontSize="8"  Margin="10,0,29,36"/>
                                            <Button x:Name="downBtn" Content="▼"   FontSize="8"  Margin="10,40,29,-4"/>-->
