                            <Grid Grid.Row="0" Grid.Column="1"  Margin="0,0,0,0">

                                <CheckBox Style="{StaticResource CheckBoxNormal}" Margin="4 5 0 0" Grid.Column="0" x:Name="OutputUnweightbackedTotalCheck"  Unchecked="OutputUnweightbackedTotalCheck_Checked" Checked="OutputUnweightbackedTotalCheck_Checked" Content="{x:Static res:LocalResource.LABEL_OUTPUT_UNWEIGHT_BACKED_TOTAL}"  IsEnabled="True"    HorizontalAlignment="Left" VerticalAlignment="Center" />
