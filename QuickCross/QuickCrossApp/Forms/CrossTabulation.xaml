                                <CheckBox  Grid.Column="1" x:Name="Check_Output_Cross_N" Checked="Check_Output_Settings_Unchecked" TabIndex="4" Unchecked="Check_Output_Settings_Unchecked" Content="{x:Static res:LocalResource.LABEL_N_}"  IsEnabled="True" Margin="0,5,10,5"   HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource CheckBoxCommon}" />
