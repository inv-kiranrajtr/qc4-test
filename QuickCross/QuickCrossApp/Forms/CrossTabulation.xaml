                                <CheckBox  Grid.Column="0" x:Name="Check_Summary_Mark_Ratio1" Unchecked="Check_Difference_Marking_Checked" Checked="Check_Difference_Marking_Checked" Style="{StaticResource CheckBoxCommon}"  Content="{x:Static res:LocalResource.LABEL_DIFFERENCE_BETWEEN}"   Margin="4,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center" Height="16"  Grid.ColumnSpan="2"/>

