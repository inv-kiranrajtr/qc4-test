                                            <Button x:Name="downBtn" Content="▼"   FontSize="8"  Margin="10,40,29,-4"/>-->
                                        <CheckBox   Grid.Column="0" x:Name="Check_Summary_Rate_Difference1" Unchecked="Check_Summary_Rate_Difference1_Checked" Checked="Check_Summary_Rate_Difference1_Checked"       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,10" Height="14" Width="16" />
