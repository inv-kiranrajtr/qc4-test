                                <RowDefinition Height=".5*"/>
                                <RowDefinition Height=".5*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12*"/>
                                    <ColumnDefinition Width="24*"/>
                                    <ColumnDefinition Width="244*"/>
                                </Grid.ColumnDefinitions>
                                <!--LostFocus-->
                                <TextBlock Style="{StaticResource TxtblockformatWithoutBg}"  x:Name="Label_Summary_Mark_N_Equal" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_N}" Margin="4,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Center"  />
