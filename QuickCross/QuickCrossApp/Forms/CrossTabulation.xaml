                                                <Setter Property="MaxWidth" Value="508"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="2" Text="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                </StackPanel>

                            </Grid>
                            <Grid Grid.Row="3" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12*"/>
                                    <ColumnDefinition Width="38*"/>

                                </Grid.ColumnDefinitions>
                                <CheckBox VerticalContentAlignment="Center" Style="{StaticResource CheckBoxNormal}" x:Name="Check_Summary_SignificantDifferece_Test" Unchecked="Check_Summary_SignificantDifferece_Test_Checked" Checked="Check_Summary_SignificantDifferece_Test_Checked" Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_TEST}"  IsEnabled="True" Margin="4,13,0,17"   HorizontalAlignment="Left" Grid.ColumnSpan="2" />
                                <ComboBox VerticalContentAlignment="Center" Style="{StaticResource NonEditableComboformat}" IsEnabled="True"  SelectionChanged="Combo_SignificantDifference_Test_SelectionChanged" Margin="0,10,36,15" Visibility="Visible" x:Name="Combo_SignificantDifference_Test" HorizontalAlignment="Left"  Width="264" Grid.Column="1"  >
                                    <ComboBoxItem IsSelected="True" Content="{x:Static res:LocalResource.TEST_OVERALL_DIFFERENCE}"/>
                                    <ComboBoxItem Content="{x:Static res:LocalResource.TEST_FOR_DIFFERENT_BETWEEN_AXIS_ITEMS}"/>

                                </ComboBox>
                            </Grid>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
