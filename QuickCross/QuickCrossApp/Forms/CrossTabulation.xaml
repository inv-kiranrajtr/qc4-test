                                        <StackPanel Orientation="Horizontal" Grid.Column="2" >
                                            <TextBox VerticalContentAlignment="Center"  x:Name="Text_Summary_Rate_Difference1" LostFocus="text_LostFocus" CommandManager.PreviewExecuted="textBox_PreviewExecuted" PreviewTextInput="NumberValidationTextBox" x:FieldModifier="private" Margin="10,5,0,5" Width="30" Text="0" TextAlignment="Center" />

