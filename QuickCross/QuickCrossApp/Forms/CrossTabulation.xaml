                                <TextBlock Style="{StaticResource TxtblockformatWithoutBg}"  x:Name="Label_Summary_Mark_Above" Grid.Column="2" Text="{x:Static res:LocalResource.LABEL_EQUALTO_MORETHAN}"  Margin="0,4,0,8" HorizontalAlignment="Left" VerticalAlignment="Center"   />
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="19*"/>
                                </Grid.RowDefinitions>
