                                    <ColumnDefinition Width="45*"/>
                                    <ColumnDefinition Width="140*"/>
                                    <!--<ColumnDefinition Width="64*"/>-->
                                </Grid.ColumnDefinitions>
                                <!--Checked="Check_Significance_Level_Checked"-->

                                <TextBlock x:Name="Label_Summary_SignificantDifferece" Style="{StaticResource TextBlockNormal}" Grid.Column="0" Text="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL}" Margin="4,14,0,9" HorizontalAlignment="Left"  Grid.ColumnSpan="2"/>
                                <CheckBox  Grid.Column="1" x:Name="Check_Par_99"      Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL1}"  IsEnabled="True" Margin="26,13,0,12"   HorizontalAlignment="Left" Width="36"/>
                                <CheckBox  Grid.Column="2" x:Name="Check_Par_95"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL5}"  IsEnabled="True" Margin="19,13,0,12"   HorizontalAlignment="Left" RenderTransformOrigin="-0.308,-0.2" Width="36"/>
                                <CheckBox  Grid.Column="3" x:Name="Check_Par_90"  Content="{x:Static res:LocalResource.LABEL_SIGNIFICANCE_LEVEL10}"  IsEnabled="True" Margin="12,12,0,13"   HorizontalAlignment="Left" RenderTransformOrigin="-2,-0.3" Width="43"/>
                            </Grid>
                        </Grid>

