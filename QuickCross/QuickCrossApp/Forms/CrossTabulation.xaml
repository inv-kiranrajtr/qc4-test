                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="450"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0"  Margin="5 10 0 5 " >
                        <GroupBox.Header>
                            <TextBlock Text="{x:Static res:LocalResource.LABEL_ST_TABULATE}" Style="{StaticResource  TxtblockformatWithoutBg}" Margin="7,0,0,1"/>
                        </GroupBox.Header>

                        <Grid Grid.Row="0"  Margin="5">
