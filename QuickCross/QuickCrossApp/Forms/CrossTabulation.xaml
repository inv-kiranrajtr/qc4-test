                                <RadioButton VerticalContentAlignment="Center" Style="{StaticResource Radibuttoncommon}" Content="{x:Static res:LocalResource.RB_OUTPUT_SHEET_TYPE_PLURAL}" x:Name="Option_Output_SheetType_Plural"  Grid.Row="1" Margin="0,5,0,0" TabIndex="2"  VerticalAlignment="Center" HorizontalAlignment="Left" Height="15"  Checked="Option_Output_SheetType_Plural_Checked" Unchecked="Option_Output_SheetType_Plural_Checked"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
