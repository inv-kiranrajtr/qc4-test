                                        <ComboBox  x:Name="Combo_Summary_Rate_Difference2"  Margin="0 0 0 7"  Visibility="Visible" Grid.Column="1" Height="20" VerticalAlignment="Bottom" Style="{StaticResource NormalComboBox}" HorizontalAlignment="Left" Width="38" >

