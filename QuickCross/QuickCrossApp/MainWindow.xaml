<Window x:Class="Qc4Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher"
        mc:Ignorable="d"
        Title="MainWindow" Height="480" Width="700" ResizeMode="NoResize" WindowStyle="None" 
			WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown" Loaded="Window_Loaded" Closing="Window_Closing" Activated="MainWindowOnActivated" BorderBrush="#ADADAD" BorderThickness="1">
    <Window.Resources>
        <ResourceDictionary>
            
            <Style x:Key="CenteredHeaderGroupBoxStyle" TargetType="{x:Type GroupBox}">
                <Setter Property="BorderBrush" Value="#D5DFE5"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type GroupBox}">
                            <Grid SnapsToDevicePixels="true">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="6"/>
                                </Grid.RowDefinitions>
                                <Border BorderBrush="Transparent" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Grid.ColumnSpan="4" Grid.Column="0" CornerRadius="4" Grid.Row="1" Grid.RowSpan="3"/>
                                <Border Grid.ZIndex="2" x:Name="Header" Grid.Column="2" HorizontalAlignment="Center" Padding="3,1,3,0" Grid.Row="0" Grid.RowSpan="2">
                                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                                <ContentPresenter Grid.ColumnSpan="2" Grid.Column="1" Margin="{TemplateBinding Padding}" Grid.Row="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <Border RenderTransformOrigin="0.5,0.5" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}" Grid.ColumnSpan="4" CornerRadius="4" Grid.Row="1" Grid.RowSpan="3">
                                    <Border.OpacityMask>
                                        <MultiBinding ConverterParameter="7" Converter="{StaticResource CenterBorderGapMaskConverter}">
                                            <Binding ElementName="Header" Path="ActualWidth"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                                        </MultiBinding>
                                    </Border.OpacityMask>
                                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                        <Border BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2"/>
                                    </Border>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Header" TargetType="{x:Type Grid}">
                <Setter Property="Background" Value="#0051A3"/>
            </Style>
            <Style x:Key="HeaderText" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Text" Value="QuickCross"/>
                <Setter Property="Padding" Value="60,10"/>
                <Setter Property="FontSize" Value="30"/>
                <Setter Property="FontWeight" Value="Normal"/>
            </Style>
            <Style x:Key="Versiontext" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Text" Value="v0.1 β"/>
                <Setter Property="Padding" Value="0,30"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style TargetType="Button" x:Key="Button">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="0" Padding="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#aeaeae"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="Button" x:Key="Button_help">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"  BorderThickness="0" Padding="5" CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#aeaeae"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ButtonBlue">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="White" BorderBrush="#3467b0" CornerRadius="5" BorderThickness="2" Padding="5" >
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#ffffff"/>
                        <!--Value="#3467b0"-->
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="White" BorderBrush="#3467b0" CornerRadius="5" BorderThickness="2" Padding="5" Opacity=".5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#3467b0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#3467b0" BorderBrush="#3467b0" CornerRadius="5" BorderThickness="2" Padding="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="ButtonCircle">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="Button" x:Key="ButtonEnd">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Height" Value="25"/>
                <Setter Property="Width" Value="80"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="true">
                        <Setter Property="Background" Value="#f15a24"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="60*"/>
            <RowDefinition Height="60*"/>
            <RowDefinition Height="275*"/>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="35*"/>
        </Grid.RowDefinitions>
        <Grid  Grid.Row="0"  MouseDown="DragableGridMouseDown" Style="{StaticResource Header}">
            <Image Source="img/app_icon.png" Height="35" HorizontalAlignment="left" Margin="24,0,0,0" VerticalAlignment="Center"/>
            <Image Source="img/textlogo.png" Height="25" HorizontalAlignment="left" Margin="70,0,0,0" VerticalAlignment="Center"/>
            <!--<TextBlock Style="{StaticResource HeaderText}"/>-->
            <ComboBox Name="Combo_Language" SelectionChanged="Combo_Language_SelectionChanged" Height="25" Background="White" VerticalAlignment="Center" Margin="0,0,150,0" HorizontalAlignment="Right"  Width="94" IsEditable="False"
 IsReadOnly="True"
 Text="Languages" >
                <ComboBoxItem Content="English"/>
                <ComboBoxItem Content="日本語"/>
            </ComboBox>           
            <TextBlock Style="{StaticResource Versiontext}" Width="104" Name="txt_version" Margin="0,5,140,0" VerticalAlignment="Center"/>
            <Button Name="btn_help" Width="75" Height="25" Style="{StaticResource Button_help}" Content="{x:Static local:LocalResource.BTN_HELP}" HorizontalAlignment="Right" Margin="0,0,58,0" Click="help_Btn_Click"></Button>
            <Image Source="img/logo.png" Height="22" Width="20" HorizontalAlignment="Right" Margin="0,0,25, 0"/>
        </Grid>
        <Grid Grid.Row="1" Margin="24,0">
            <Grid.ColumnDefinitions >
                <ColumnDefinition Width="95*"/>
                <ColumnDefinition Width="73*"/>
                <ColumnDefinition Width="378*"/>
                <ColumnDefinition Width="102*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btn_DataMerge" Style="{StaticResource Button}" Grid.Column="0" Height="30" Background="#024468" Click="btn_DataMerge_Click" Margin="0,12">
                <StackPanel Orientation="Horizontal">
                    <Image Source="img/buttontop1.png" Grid.Row="0" Width="15" Height="15"/>
                    <TextBlock VerticalAlignment="Center" Name="txtblk_merge" Text="{x:Static local:LocalResource.BTN_DATA_MERGE}" />
                </StackPanel>
            </Button>
            <TextBlock Text="{x:Static local:LocalResource.LBL_FILE_NAME}" Name="txtblk_file_name" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,0,0"/>
            <TextBox  x:Name="txt_FileName"  Margin="0,0,0,0" VerticalAlignment="Center" Width="379" Height="30" Grid.Column="2" VerticalContentAlignment="Center" Text="">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="BorderBrush" Value="#aeaeae"/>
                        <Setter Property="CornerRadius" Value="5"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <Button  x:Name="btn_Open" Style="{StaticResource Button}" Grid.Column="3" Height="30" Width="71" HorizontalAlignment="Left" Margin="10,0" Content="{x:Static local:LocalResource.BTN_OPEN}" Click="btn_Open_Click"/>
            <!--<Button Style="{StaticResource ButtonCircle}" Grid.Column="3" Height="15" Width="15" Background="#aeaeae" HorizontalAlignment="Right" Margin="10,0,0,15">?</Button>-->
        </Grid>
        <Grid Grid.Row="2" Margin="12,0,15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="100"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border1}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border1" CornerRadius="10,10,0,0" Background="#ffe6e6e6" />
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Width="auto" Name="txtblk_group1" FontSize="13" Text="{x:Static local:LocalResource.MAINWINDOW_GROUP_HEADER1}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border2}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border2" CornerRadius="0,0,10,10" Background="#fff5f5f5" />
                        <Button x:Name="btn_Question_setting" Style="{StaticResource ButtonBlue}" Width="80" Height="120" Click="Qs_Click" HorizontalAlignment="Left" Margin="30,0,0,2" MouseEnter="Qs_mouse_Enter" MouseLeave="Qs_mouse_Leave" >
                            <StackPanel Orientation="Vertical">
                                <Image x:Name="img_qs" Source="img/qs.png" Width="40" Height="40" Margin="0,0,0,0"/>
                                <TextBlock x:Name="lbl_qs" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_QS}" FontSize="13" TextWrapping="Wrap"  Foreground="#3467b0" Margin="0,15,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_Data_Browsing" Style="{StaticResource ButtonBlue}" Width="80" Height="120" Click="btn_DataBrowsing" HorizontalAlignment="Center" MouseEnter="Data_Browse_mouse_enter" Margin="4,0,0,2"  MouseLeave="Data_Browse_mouse_leave">
                            <StackPanel Orientation="Vertical">
                                <Image x:Name="img_data_browse" Source="img/databrowse.png" Width="40" Height="40" Margin="0,10,0,0"/>
                                <TextBlock x:Name="lbl_data_browse" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_DATABROWSE}" FontSize="13" Width="55" TextWrapping="Wrap"  Foreground="#3467b0" Margin="10,10,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_Data_Processing" Style="{StaticResource ButtonBlue}" Width="80" Height="120" Click="Btn_Data_Processing_Click"  HorizontalAlignment="Right" Margin="0,0,26,2" MouseEnter="Data_process_mouse_enter" MouseLeave="Data_process_mouse_leave">
                            <StackPanel Orientation="Vertical">
                                <Image x:Name="img_data_process" Source="img/dataprocess.png" Width="40" Height="40" Margin="0,10,0,0"/>
                                <TextBlock x:Name="lbl_data_process" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_DATAPROCESSING}" FontSize="13" TextWrapping="Wrap" Width="63" Foreground="#3467b0" Margin="5,10,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border3}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border3" CornerRadius="10,10,0,0" Background="#ffe6e6e6" />
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Width="auto"  FontSize="13" Name="txtblk_group3" Text="{x:Static local:LocalResource.MAINWINDOW_GROUP_HEADER3}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border4}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border4" CornerRadius="0,0,10,10" Background="#fff5f5f5" />
                        <Button x:Name="btn_DataOutput" Style="{StaticResource ButtonBlue}" Width="270" Height="50" Click="btn_DataOutput_Click" HorizontalAlignment="Center" MouseEnter="Data_output_mouse_enter" VerticalAlignment="Center"  MouseLeave="Data_output_mouse_leave" >
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="img_data_export" Source="img/dataexport.png" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lbl_data_export" Text="{x:Static local:LocalResource.BTN_DATA_OUTPUT}" FontSize="13" TextWrapping="Wrap"  Foreground="#3467b0" VerticalAlignment="Center" Margin="10,0,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="100"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border5}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border5" CornerRadius="10,10,0,0" Background="#ffe6e6e6" />
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Width="auto" Name="txtblk_group2" FontSize="13" Text="{x:Static local:LocalResource.MAINWINDOW_GROUP_HEADER2}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border6}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border6" CornerRadius="0,0,10,10" Background="#fff5f5f5" />

                        <Button x:Name="btn_Gttable" Style="{StaticResource ButtonBlue}" Width="80" Height="120" Click="Btn_Gttable_Click" HorizontalAlignment="Left" Margin="30,0,0,2" MouseEnter="Gttable_mouse_enter" MouseLeave="Gttable_mouse_leave">
                            <StackPanel Orientation="Vertical">
                                <Image x:Name="img_gt_table" Source="img/gttable.png" Width="40" Height="40" Margin="0,10,0,0"/>
                                <TextBlock x:Name="lbl_gt_table" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_GT_TABLE}" FontSize="13" Width="40" TextWrapping="Wrap"  Foreground="#3467b0" Margin="10,10,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_Cross_table_report" Style="{StaticResource ButtonBlue}" Width="80" Height="120" Click="Btn_Cross_table_report_Click" HorizontalAlignment="Center" Margin="4,0,0,2" MouseEnter="Crosstable_mouse_enter" MouseLeave="Crosstable_mouse_leave" >
                            <StackPanel Orientation="Vertical">
                                <Image x:Name="img_cross" Source="img/crosschrt.png" Width="40" Height="40" Margin="0,10,0,0"/>
                                <TextBlock x:Name="lbl_cross" Text="&#160;&#160;&#160;Cross/&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Charts" HorizontalAlignment="Center" FontSize="13" Width="65" TextWrapping="Wrap"  Foreground="#3467b0" Margin="5,10,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btn_Falist" Style="{StaticResource ButtonBlue}" Width="80" Height="120" HorizontalAlignment="Right" Click="btn_Falist_Click" Margin="0,0,26,2" MouseEnter="falist_mouse_enter" MouseLeave="falist_mouse_leave">
                            <StackPanel Orientation="Vertical">
                                <Image x:Name="img_falist" Source="img/falist.png" Width="40" Height="40"/>
                                <TextBlock x:Name="lbl_falist" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_FA_LIST}" Width="65" FontSize="13" TextWrapping="Wrap"  Foreground="#3467b0" Margin="5,10,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
                <Grid Grid.Row="1" Margin="0,12,0,0" >

                    <!--<Grid.RowDefinitions>
                        <RowDefinition Height="30"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>-->
                    <!--<Grid Grid.Row="0">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border7}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border7" CornerRadius="10,10,0,0" Background="#ffe6e6e6" />
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Width="auto"  FontSize="15" Text="{x:Static local:LocalResource.MAINWINDOW_GROUP_HEADER4}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border8}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border8" CornerRadius="0,0,10,10" Background="#fff5f5f5" />
                        <Button x:Name="btn_Multivaries" Style="{StaticResource ButtonBlue}" Width="300" Height="50" HorizontalAlignment="Center"  Visibility="Visible" MouseEnter="Multi_mouse_enter" MouseLeave="Multi_mouse_leave" Click="Btn_Multivaries_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="img_multi" Source="img/multivarint.png" Width="50" Height="40" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lbl_damulti" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_MULTI_VARIOUS}" FontSize="15" TextWrapping="Wrap"  Foreground="#3467b0" VerticalAlignment="Center"></TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>-->

                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border3}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border7" CornerRadius="10,10,0,0" Background="#ffe6e6e6" />
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Width="auto"  FontSize="13" Name="txtblk_group4" Text="{x:Static local:LocalResource.MAINWINDOW_GROUP_HEADER4}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=Border8}" />
                        </Grid.OpacityMask>
                        <Border x:Name="Border8" CornerRadius="0,0,10,10" Background="#fff5f5f5" />
                        <Button x:Name="btn_Multivaries" Style="{StaticResource ButtonBlue}" Width="270" Height="50"  HorizontalAlignment="Center" VerticalAlignment="Center"  MouseEnter="Multi_mouse_enter" MouseLeave="Multi_mouse_leave" Click="Btn_Multivaries_Click" >
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="img_multi" Source="img/multivarint.png" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lbl_damulti" Text="{x:Static local:LocalResource.MAINWINDOW_BUTTON_MULTI_VARIOUS}" FontSize="13" TextWrapping="Wrap"  Foreground="#3467b0" VerticalAlignment="Center" Margin="10,0,0,0"></TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>
        <Grid Grid.Row="3" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btn_Save"  Style="{StaticResource Button}" Grid.Column="1" Height="30" Width="90" HorizontalAlignment="Left"  Click="btn_Save_Click" Content="{x:Static local:LocalResource.BTN_SAVE2}"></Button>
            <Button x:Name="btn_Save_As" Style="{StaticResource Button}" Grid.Column="2" Height="30" Width="90" HorizontalAlignment="Left"  Margin="0" Click="btn_Save_As_Click" Content="{x:Static local:LocalResource.BTN_SAVE_AS}"></Button>
            <Button x:Name="btn_Close_File" Style="{StaticResource Button}" Grid.Column="3" Height="30" Width="90" HorizontalAlignment="Left"  Margin="0" Click="btn_Close_File_Click"  Content="{x:Static local:LocalResource.BTN_CLOSE_FILE}"></Button>
            <Button x:Name="btn_Exit" Style="{StaticResource Button}" Grid.Column="4" Height="30" Width="90" HorizontalAlignment="Left"  Margin="0" Click="btn_Exit_Click" Content="{x:Static local:LocalResource.BTN_EXIT}"></Button>
            <Grid Grid.Column="5"  HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Button x:Name="btn_Swap_Data" Style="{StaticResource ButtonEnd}" Grid.Row="0"  Margin="0,5,0,0" Content="{x:Static local:LocalResource.BTN_SWAP_DATA}" Click="btn_Swap_Data_Click"></Button>
                <Button x:Name="btn_ToSheet" Style="{StaticResource ButtonEnd}" Grid.Row="1"  Margin="0,0,0,5" Content="{x:Static local:LocalResource.BTN_TOSHEET}" Click="btn_ToSheet_Click"></Button>
            </Grid>
           
        </Grid>
        <Grid Grid.Row="4" Margin="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1"  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtExpiry" Grid.Column="0" IsReadOnly="True" FontSize="13"  Foreground="Red" Text="Expiration Date: 2020/12/01" Padding="0,2,0,0" Height="25" Width="170"  Margin="30,2,0,5" IsTabStop="False" Focusable="False"/>
                <TextBox x:Name="txtVersion" Grid.Column="1" IsReadOnly="True"  Foreground="Red" Text="{x:Static local:LocalResource.LABEL_VERSION_TYPE}" Padding="7,0,0,0" Height="20" Width="60" HorizontalContentAlignment="Center"  Margin="8,2,0,10" IsTabStop="False" Focusable="False"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
