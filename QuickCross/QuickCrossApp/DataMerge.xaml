<Window x:Class="Qc4Launcher.DataMerge"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qc4Launcher"
        mc:Ignorable="d"
        Title="DataMerge"  Height="480" Width="700" ResizeMode="NoResize" WindowStyle="None" 
			WindowStartupLocation="CenterScreen">
	<Window.Resources>
		<Style TargetType="Button" x:Key="Button">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="5" BorderThickness="0" Padding="5">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"></ContentPresenter>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsEnabled" Value="true">
					<Setter Property="Background" Value="#aeaeae"/>
					<Setter Property="Cursor" Value="Hand"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>
	<Grid>
		<Grid >
			<Grid.RowDefinitions>
				<RowDefinition Height="30*"/>
				<RowDefinition Height="385*"/>
				<RowDefinition Height="75*"/>
			</Grid.RowDefinitions>
			<Grid  Grid.Row="0"  MouseDown="DragableGridMouseDown" Height="30" Width="700"></Grid>
			<Grid  Grid.Row="1" Margin="24,0" >
				<Border CornerRadius="10" Background="#f5f5f5">
					<Grid Margin="10">
						<Grid.RowDefinitions>
							<RowDefinition Height="1*"/>
							<RowDefinition Height="1*"/>
							<RowDefinition Height="1*"/>
							<RowDefinition Height="1*"/>
							<RowDefinition Height="1*"/>
							<RowDefinition Height="1*"/>
						</Grid.RowDefinitions>
						<Grid Grid.Row="0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="225*"/>
								<ColumnDefinition Width="430*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="btn_ExternalData" Style="{StaticResource Button}" Height="40" Width="205" Background="#3467b0" Grid.Column="0" Click="btn_ExternalData_Click">
								<StackPanel Orientation="Horizontal" Width="190">
									<Image Source="img/externalData.png" Width="15" Height="15" Margin="10,0,5,0"/>
									<TextBlock VerticalAlignment="Center" FontSize="12" Text="外部データ追加"/>
								</StackPanel>
							</Button>
							<TextBlock Grid.Column="1"  Height="40" TextWrapping="WrapWithOverflow" Margin="5">ここに説明文章が入ります。文字が小さ目なので、もう少し大きい方が良いかもしれないですね。この文章はダミー用の文章です。</TextBlock>
						</Grid>
						<Grid Grid.Row="1">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="225*"/>
								<ColumnDefinition Width="430*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="btn_CombineSideWays" Style="{StaticResource Button}" Height="40" Width="205" Background="#3467b0" Grid.Column="0" Click="btn_CombineSideWays_Click">
								<StackPanel Orientation="Horizontal" Width="190">
									<Image Source="img/CombineSideWays.png" Width="16" Height="13" Margin="10,0,5,0" />
									<TextBlock VerticalAlignment="Center" FontSize="12" Text="横に結合（qcファイル同士）"/>
								</StackPanel>
							</Button>
							<TextBlock Grid.Column="1"  TextWrapping="WrapWithOverflow" Height="40" Margin="5">ここに説明文章が入ります。文字が小さ目なので、もう少し大きい方が良いかもしれないですね。この文章はダミー用の文章です。</TextBlock>
						</Grid>
						<Grid Grid.Row="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="225*"/>
								<ColumnDefinition Width="430*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="btn_CombineVertically" Style="{StaticResource Button}" Height="40" Background="#3467b0" Grid.Column="0" Margin="6,10" Click="btn_CombineVertically_Click">
								<StackPanel Orientation="Horizontal" Width="190">
									<Image Source="img/CombineVerticallypng.png" Margin="9,0,5,0" Width="17" Height="15"/>
									<TextBlock VerticalAlignment="Center" FontSize="12" Text="縦に結合（qcファイル同士）"/>
								</StackPanel>
							</Button>
							<TextBlock Grid.Column="1"  TextWrapping="WrapWithOverflow" Height="40" Margin="5">ここに説明文章が入ります。文字が小さ目なので、もう少し大きい方が良いかもしれないですね。この文章はダミー用の文章です。</TextBlock>
						</Grid>
						<Grid Grid.Row="3">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="225*"/>
								<ColumnDefinition Width="430*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="btn_ScreeningMatch" Style="{StaticResource Button}" Height="40" Width="205" Background="#3467b0" Grid.Column="0" Click="btn_ScreeningMatch_Click">
								<StackPanel Orientation="Horizontal" Width="190">
									<Image Source="img/ScreeningMatch.png" Height="17" Width="17" Margin="9,0,5,0" />
									<TextBlock VerticalAlignment="Center" FontSize="12" Text="スクリーニングマッチ"/>
								</StackPanel>
							</Button>
							<TextBlock Grid.Column="1"  TextWrapping="WrapWithOverflow" Height="40" Margin="5">ここに説明文章が入ります。文字が小さ目なので、もう少し大きい方が良いかもしれないですね。この文章はダミー用の文章です。</TextBlock>
						</Grid>
						<Grid Grid.Row="4">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="225*"/>
								<ColumnDefinition Width="430*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="btn_CreateNewQCFile" Style="{StaticResource Button}" Height="40" Width="205" Background="#3467b0" Grid.Column="0" Click="btn_CreateNewQCFile_Click">
								<StackPanel Orientation="Horizontal" Width="190">
									<Image Source="img/CreateNew.png" Height="16" Width="14" Margin="10,0,5,0" />
									<TextBlock VerticalAlignment="Center" FontSize="12" Text="新規qcファイル作成"/>
								</StackPanel>
							</Button>
							<TextBlock Grid.Column="1"  TextWrapping="WrapWithOverflow" Height="40" Margin="5">ここに説明文章が入ります。文字が小さ目なので、もう少し大きい方が良いかもしれないですね。この文章はダミー用の文章です。</TextBlock>
						</Grid>
					</Grid>
				</Border>
			</Grid>
			<Grid Grid.Row="2" Margin="24,0">
				<Button x:Name="btn_Close" Style="{StaticResource Button}" Grid.Column="4" Height="30" Width="90" HorizontalAlignment="Right" Content="閉じる" Click="btn_Close_Click"></Button>
			</Grid>
		</Grid>
	</Grid>
</Window>
