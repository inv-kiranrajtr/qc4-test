    <Border BorderThickness="1"  BorderBrush="#707070">
        <Grid Background="#fffffe" Height="120" Width="652">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.2*"/>
                <RowDefinition Height=".8*"/>
                <RowDefinition Height="1.7*"/>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#3467b0" MouseDown="DragableGridMouseDown">
                <TextBlock Text="QuickCross" HorizontalAlignment="Left" Margin="24,0" VerticalAlignment="Center" FontSize="15" Foreground="White"/>
            </Grid>
            <Grid Grid.Row="1">
                <TextBlock Name="status_text" Text="{x:Static res:CommonResource.LOADING }"  VerticalAlignment="Bottom" Margin="50,0" Foreground="#3467b0" FontSize="13"/>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88*"/>
                    <ColumnDefinition Width="12*"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Margin="50,0,0,0" Grid.Column="0" Height="30" Name="progressBar" Minimum="0" Maximum="100" Value="0" BorderBrush="#3467b0" BorderThickness="1"
					 Background="White" Foreground="YellowGreen" />
                <TextBlock Name="progress_text" Grid.Column="1" Text="0%" VerticalAlignment="Center" Margin="5,0" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20" Foreground="#3467b0"/>

            </Grid>
            <Grid Grid.Row="3">
                <TextBlock  VerticalAlignment="Top" HorizontalAlignment="Right" Margin="52,0"/>
                <Button Visibility="Collapsed"  Name="Command_Cancel" Content="{x:Static res:CommonResource.BTN_CANCEL}" HorizontalAlignment="Right" Width="100" Height="25"  Margin="0,2,78,9" Click="Command_Cancel_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
